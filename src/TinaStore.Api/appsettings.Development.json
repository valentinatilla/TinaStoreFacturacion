{
  // ═══════════════════════════════════════════════════════════════
  //  TinaStore API — Configuración DESARROLLO LOCAL
  //  Este archivo se usa cuando ASPNETCORE_ENVIRONMENT = Development
  //  Es seguro subirlo al repositorio porque NO contiene secretos reales.
  //  La clave JWT de desarrollo solo sirve en tu computadora local.
  // ═══════════════════════════════════════════════════════════════
  "ConnectionStrings": {
    // Base de datos SQLite local para desarrollo
    // El archivo tinastore-dev.db está en .gitignore y no se sube al repo
    "DefaultConnection": "Data Source=tinastore-dev.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Jwt": {
    // Clave de desarrollo local únicamente. Para producción usar variable de entorno.
    "Key": "TinaStore-Dev-Key-Solo-Para-Desarrollo-Local-2025!",
    "Issuer": "TinaStore",
    "Audience": "TinaStoreClients",
    "ExpiresInMinutes": 1440
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "Email": {
    // En desarrollo se usa una cuenta de prueba o se simulan los correos
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "SmtpUser": "dev@tinastore.local",
    "SmtpPassword": "SET_VIA_USER_SECRETS",
    "FromAddress": "dev@tinastore.local",
    "FromName": "Tina Store (Desarrollo)"
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:5173",
    "https://localhost:7173",
    "http://localhost:5174",
    "https://localhost:7174"
  ]
}
