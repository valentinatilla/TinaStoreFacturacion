{
  // ═══════════════════════════════════════════════════════════════
  //  TinaStore API — Configuración BASE
  //  Este archivo contiene valores por defecto seguros.
  //  Los secretos reales se configuran con variables de entorno
  //  o con dotnet user-secrets en desarrollo local.
  //  NUNCA pongas contraseñas reales en este archivo.
  // ═══════════════════════════════════════════════════════════════
  "ConnectionStrings": {
    // En producción, esta cadena se sobreescribe con la variable de entorno:
    // ConnectionStrings__DefaultConnection
    "DefaultConnection": "Data Source=tinastore.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Jwt": {
    // En producción, Jwt__Key se configura como variable de entorno segura.
    // Debe tener al menos 32 caracteres aleatorios. Nunca use este valor en producción.
    "Key": "SET_VIA_ENV_VAR_OR_USER_SECRETS",
    "Issuer": "TinaStore",
    "Audience": "TinaStoreClients",
    "ExpiresInMinutes": 480
  },
  "AllowedHosts": "*"
}
