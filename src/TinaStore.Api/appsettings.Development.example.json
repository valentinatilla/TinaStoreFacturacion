{
  // ─────────────────────────────────────────────────────────────────────────
  //  ARCHIVO DE EJEMPLO — copia esto a appsettings.Development.json y
  //  luego configura los secretos con dotnet user-secrets:
  //
  //  cd src/TinaStore.Api
  //  dotnet user-secrets init
  //  dotnet user-secrets set "Jwt:Key" "TU_CLAVE_ALEATORIA_DE_32_CHARS_MINIMO"
  //  dotnet user-secrets set "Google:ClientId" "TU_CLIENT_ID.apps.googleusercontent.com"
  //
  //  Para generar una clave JWT segura en PowerShell:
  //  [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
  // ─────────────────────────────────────────────────────────────────────────
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=tinastore-dev.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Jwt": {
    "Key": "SET_VIA_USER_SECRETS — ver instrucciones arriba",
    "Issuer": "TinaStore",
    "Audience": "TinaStoreClients",
    "ExpiresInMinutes": 1440
  },
  "Email": {
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "SmtpUser": "dev@tinastore.local",
    "SmtpPassword": "SET_VIA_USER_SECRETS",
    "FromAddress": "dev@tinastore.local",
    "FromName": "Tina Store (Desarrollo)"
  },
  "AllowedHosts": "*",
  "Google": {
    "ClientId": "SET_VIA_USER_SECRETS",
    "AllowedEmails": [
      "tu-correo@gmail.com"
    ]
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "https://localhost:7173"
  ]
}
