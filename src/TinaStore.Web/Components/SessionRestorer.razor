@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject SessionStateService Session
@inject IJSRuntime JS
@inject TinaStoreApiClient Api
@inject SessionRestoreGate Gate

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Session.IsAuthenticated) return;

            // Lee el JWT almacenado en la cookie HTTP-only (vÃ­a endpoint server-side)
            var token = await JS.InvokeAsync<string>("tinaSession.get");
            if (string.IsNullOrWhiteSpace(token)) return;

            // Valida el token llamando al perfil de la API para obtener los datos del usuario
            var profile = await Api.GetPerfilAsync(token);
            if (profile is null) return;

            Session.RestoreSession(token, profile.FullName, profile.Email, profile.Role);
        }
        finally
        {
            // SeÃ±aliza que terminÃ³, con o sin Ã©xito, para que Routes pueda renderizar
            Gate.SignalDone();
        }
    }
}
