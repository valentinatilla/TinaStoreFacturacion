<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tina Store — Sistema de facturación, inventario y gestión de tienda" />
    <meta name="theme-color" content="#F472B6" />
    <base href="/" />
    <ResourcePreloader />
    <!-- Google Fonts: Nunito (tipografía kawaii redondeada) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["TinaStore.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <!-- PWA: manifest e íconos para instalación móvil -->
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="icons/icon-192.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Tina Store" />
    <HeadOutlet @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
</head>

<body>
    <SessionRestorer />
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    <ReconnectModal />
    <script src="@Assets["lib/bootstrap/dist/js/bootstrap.bundle.min.js"]"></script>
    <script>
        window.downloadFileFromBase64 = function(base64, fileName, mimeType) {
            const link = document.createElement('a');
            link.href = 'data:' + mimeType + ';base64,' + base64;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
    </script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Helpers para persistir y borrar la cookie de sesión (HTTP-only) desde Blazor
        window.tinaSession = {
            save: (token) => fetch('/session/set', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token })
            }),
            clear: () => fetch('/session/clear', { method: 'POST' }),
            get: () => fetch('/session/get')
                .then(r => r.ok ? r.json() : { token: '' })
                .then(d => d.token || '')
        };
    </script>
    <script>
        // ── Zona de imagen: drag-drop + clic totalmente desde JS ────────────────
        // Se usa un <input type="file"> NATIVO oculto fuera del div.
        // Ningún evento de archivo pasa por Blazor/SignalR: todo va por FileReader
        // y llega al componente con invokeMethodAsync('RecibirDropBase64', ...).
        window.tinaDropZone = {
            _readAndSend: function (file, dotNetRef) {
                var reader = new FileReader();
                reader.onload = function (ev) {
                    var dataUrl = ev.target.result;
                    var comma   = dataUrl.indexOf(',');
                    var base64  = dataUrl.substring(comma + 1);
                    var mime    = dataUrl.substring(5, comma);
                    dotNetRef.invokeMethodAsync('RecibirDropBase64', base64, mime, file.name, file.size);
                };
                reader.readAsDataURL(file);
            },

            init: function (zoneEl, inputId, dotNetRef) {
                if (!zoneEl) return;

                var nativeInput = document.getElementById(inputId);
                zoneEl._tinaDotNet = dotNetRef;

                // Clic en la zona → abrir el selector de archivos nativo
                var handleClick = function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    if (nativeInput) nativeInput.click();
                };

                // Selección con el diálogo nativo
                var handleChange = function () {
                    var file = nativeInput && nativeInput.files && nativeInput.files[0];
                    if (file) {
                        window.tinaDropZone._readAndSend(file, dotNetRef);
                        nativeInput.value = ''; // permitir re-selección del mismo archivo
                    }
                };

                var handleDragOver = function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    zoneEl.classList.add('ts-drag-active');
                };

                var handleDragLeave = function (e) {
                    var rect = zoneEl.getBoundingClientRect();
                    if (e.clientX <= rect.left || e.clientX >= rect.right ||
                        e.clientY <= rect.top  || e.clientY >= rect.bottom) {
                        zoneEl.classList.remove('ts-drag-active');
                    }
                };

                var handleDrop = function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    zoneEl.classList.remove('ts-drag-active');
                    var file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
                    if (file) window.tinaDropZone._readAndSend(file, dotNetRef);
                };

                zoneEl._tinaH = { handleClick: handleClick, handleChange: handleChange,
                                  handleDragOver: handleDragOver, handleDragLeave: handleDragLeave,
                                  handleDrop: handleDrop, nativeInput: nativeInput };

                zoneEl.addEventListener('click',     handleClick);
                zoneEl.addEventListener('dragover',  handleDragOver);
                zoneEl.addEventListener('dragleave', handleDragLeave);
                zoneEl.addEventListener('drop',      handleDrop);
                if (nativeInput) nativeInput.addEventListener('change', handleChange);
            },

            dispose: function (zoneEl) {
                if (!zoneEl || !zoneEl._tinaH) return;
                var h = zoneEl._tinaH;
                zoneEl.removeEventListener('click',     h.handleClick);
                zoneEl.removeEventListener('dragover',  h.handleDragOver);
                zoneEl.removeEventListener('dragleave', h.handleDragLeave);
                zoneEl.removeEventListener('drop',      h.handleDrop);
                if (h.nativeInput) h.nativeInput.removeEventListener('change', h.handleChange);
                delete zoneEl._tinaH;
                delete zoneEl._tinaDotNet;
            }
        };
    </script>
</body>

</html>
