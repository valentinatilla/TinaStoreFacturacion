@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject SessionStateService Session

<div class="ts-wrapper">
    @if (Session.IsAuthenticated)
    {
        <!-- Sidebar -->
        <nav class="ts-sidebar" id="sidebar">
            <div class="ts-brand">
                <i class="bi bi-bag-heart-fill me-2"></i>
                <span>Tina Store</span>
            </div>
            <NavMenu />
        </nav>

        <!-- Contenido principal -->
        <div class="ts-main">
            <!-- Header -->
            <header class="ts-header d-flex align-items-center justify-content-between px-4">
                <button class="btn btn-sm btn-outline-secondary d-lg-none" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@Session.UserName</span>
                    <button class="btn btn-sm btn-outline-danger" @onclick="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i>Salir
                    </button>
                </div>
            </header>

            <main class="ts-content p-4">
                @Body
            </main>
        </div>
    }
    else
    {
        @Body
    }
</div>

@code {
    private void Logout()
    {
        Session.Clear();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
