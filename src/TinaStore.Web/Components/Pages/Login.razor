@page "/login"
@layout EmptyLayout
@inject TinaStoreApiClient Api
@inject SessionStateService Session
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IConfiguration Config
@inject IWebHostEnvironment Env

<div class="login-page">
    <div class="login-card">
        <div class="text-center mb-4">
            <div class="login-logo">
                <i class="bi bi-bag-heart-fill"></i>
            </div>
            <h4 class="fw-bold mb-0" style="color: var(--ts-text-main); letter-spacing: -.01em;">Tina Store</h4>
            <small style="color: var(--ts-text-soft);">Panel Administrativo</small>
            <div class="login-version-row">
                <span class="login-version-badge">v@(Config["AppVersion"] ?? string.Empty)</span>
                @if (Env.IsDevelopment())
                {
                    <span class="login-env-badge login-env-dev">DEV</span>
                }
                else if (string.Equals(Env.EnvironmentName, "Staging", StringComparison.OrdinalIgnoreCase))
                {
                    <span class="login-env-badge login-env-staging">STAGING</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2 small d-flex align-items-center gap-2 mb-3" style="border-radius: 12px;">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@_error</span>
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label small fw-semibold">Correo electrónico</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                    <InputText class="form-control" @bind-Value="_model.Email" placeholder="admin@tinastore.com" autocomplete="email" />
                </div>
                <ValidationMessage For="@(() => _model.Email)" class="text-danger small mt-1" />
            </div>
            <div class="mb-4">
                <label class="form-label small fw-semibold">Contraseña</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <InputText type="@(_mostrarPassword ? "text" : "password")" class="form-control" @bind-Value="_model.Password" placeholder="••••••••" autocomplete="current-password" />
                    <button type="button" class="btn-password-toggle" @onclick="() => _mostrarPassword = !_mostrarPassword" tabindex="-1" title="@(_mostrarPassword ? "Ocultar contraseña" : "Ver contraseña")">
                        <i class="bi @(_mostrarPassword ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-login-primary w-100" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2" style="border-color: rgba(255,255,255,.5); border-right-color: transparent;"></span>
                }
                <i class="bi bi-box-arrow-in-right me-1"></i>Ingresar
            </button>
        </EditForm>

        <div class="login-divider">
            <span>o</span>
        </div>

        <a href="/auth/google" class="btn btn-google w-100 fw-semibold d-flex align-items-center justify-content-center gap-2">
            <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Continuar con Google
        </a>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;
    private bool _mostrarPassword;

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
            Nav.NavigateTo("/", forceLoad: false);

        _error = ErrorParam switch
        {
            "google_failed"           => "No se pudo completar el inicio de sesión con Google. Intenta de nuevo.",
            "no_id_token"             => "Google no devolvió un token válido. Intenta de nuevo.",
            "google_not_configured"   => "El inicio de sesión con Google no está disponible en este momento.",
            _                         => null
        };
    }

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;
        _mostrarPassword = false;
        try
        {
            var response = await Api.LoginAsync(_model.Email, _model.Password);
            if (response is null)
            {
                _error = "Credenciales inválidas. Verifique su correo y contraseña.";
                return;
            }
            Session.SetSession(response.AccessToken, response.User.FullName, response.User.Email, response.User.Role);
            await SessionStateService.PersistAsync(JS, response.AccessToken);
            Nav.NavigateTo("/", forceLoad: false);
        }
        catch
        {
            _error = "No se pudo conectar con el servidor. Verifique que la API esté en ejecución.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "El correo es obligatorio.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Ingresa un correo electrónico válido.")]
        public string Email { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "La contraseña es obligatoria.")]
        public string Password { get; set; } = "";
    }
}
