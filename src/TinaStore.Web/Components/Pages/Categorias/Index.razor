@page "/categorias"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@using System.Globalization

<PageTitle>Categorías " Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h4 class="fw-bold mb-0"><i class="bi bi-tags me-2 text-purple"></i>Categorías de Productos</h4>
    <button class="btn bg-purple text-white" @onclick="() => AbrirModal()">
        <i class="bi bi-plus-lg me-1"></i>Nueva categoría
    </button>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">
        @_mensaje
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <!-- Barra de búsqueda -->
    <div class="ts-filter-bar">
        <div class="row g-2 align-items-end">
            <div class="col">
                <label class="form-label">Buscar</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control form-control-sm" placeholder="Buscar categoría..."
                           value="@_busqueda"
                           @oninput="e => { _busqueda = e.Value?.ToString() ?? string.Empty; }" />
                </div>
            </div>
            <div class="col-auto d-flex align-items-end">
                <button class="btn-limpiar" @onclick="LimpiarFiltro">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>

    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => OrdenarPor("nombre")'>
                            Nombre <i class="@SortIconClass("nombre") ms-1 small"></i>
                        </th>
                        <th class="ts-table-hide-mobile">Descripción</th>
                        <th style="cursor:pointer" @onclick='() => OrdenarPor("productos")'>
                            Productos <i class="@SortIconClass("productos") ms-1 small"></i>
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in CategoriasOrdenadas)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @cat.Name
                                @if (cat.Id == 99)
                                {
                                    <span class="badge bg-secondary ms-2" title="Categoría del sistema, no se puede eliminar">
                                        <i class="bi bi-lock-fill me-1"></i>Sistema
                                    </span>
                                }
                            </td>
                            <td class="text-muted ts-table-hide-mobile">@cat.Description</td>
                            <td><span class="badge bg-secondary">@cat.ProductCount</span></td>
                            <td class="text-end">
                                @if (cat.Id != 99)
                                {
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirEditar(cat)" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => AbrirConfirmarEliminar(cat)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    @if (!CategoriasOrdenadas.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Sin categorías</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editandoId > 0 ? "Editar" : "Nueva") categoría</h5>
                    <button class="btn-close" @onclick="() => _mostrarModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_errorModal))
                    {
                        <div class="alert alert-danger py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>@_errorModal
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Nombre *</label>
                        <input class="form-control" @bind="_nombre" @onkeydown="HandleKeyDown" maxlength="30" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Descripción</label>
                        <input class="form-control" @bind="_descripcion" @onkeydown="HandleKeyDown" maxlength="200" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModal = false">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_mostrarModalEliminar)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Eliminar categoría
                    </h5>
                    <button class="btn-close" @onclick="() => _mostrarModalEliminar = false"></button>
                </div>
                <div class="modal-body">
                    @if (_catAEliminar?.ProductCount > 0)
                    {
                        <div class="alert alert-warning py-2 small mb-3">
                            <i class="bi bi-box-seam me-1"></i>
                            Esta categoría tiene <strong>@_catAEliminar.ProductCount</strong> producto(s) asociado(s).
                            Si la eliminas, esos productos pasarán automáticamente a <strong>"Sin categoría"</strong>.
                            ¿Deseas continuar?
                        </div>
                    }
                    else
                    {
                        <p class="mb-1">¿Estás seguro de eliminar la categoría <strong>@_catAEliminar?.Name</strong>?</p>
                        <p class="text-muted small mb-0">Esta acción no se puede deshacer.</p>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModalEliminar = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarEliminar" @ref="_btnConfirmarEliminar">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CategoriaDto> _categorias = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private int _editandoId;
    private string _nombre = "";
    private string? _descripcion;
    private string? _mensaje;
    private bool _exito;
    private string? _errorModal;
    private string _busqueda = "";
    private string _ordenCampo = "";
    private bool   _ordenDesc;

    // -- Modal de confirmación de eliminación ----------------------------------
    private bool _mostrarModalEliminar;
    private CategoriaDto? _catAEliminar;

    private IEnumerable<CategoriaDto> CategoriasOrdenadas
    {
        get
        {
            var comparer = StringComparer.Create(new CultureInfo("es-CO"), ignoreCase: true);
            var lista = _categorias.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_busqueda))
                lista = lista.Where(c => c.Name.Contains(_busqueda, StringComparison.OrdinalIgnoreCase)
                                      || (c.Description?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
            return _ordenCampo switch
            {
                "nombre"    => _ordenDesc ? lista.OrderByDescending(c => c.Name, comparer)        : lista.OrderBy(c => c.Name, comparer),
                "productos" => _ordenDesc ? lista.OrderByDescending(c => c.ProductCount)          : lista.OrderBy(c => c.ProductCount),
                _           => lista
            };
        }
    }

    private void OrdenarPor(string campo)
    {
        if (_ordenCampo == campo) _ordenDesc = !_ordenDesc;
        else { _ordenCampo = campo; _ordenDesc = true; }
    }

    private string SortIconClass(string campo) =>
        _ordenCampo != campo ? "bi bi-arrow-down-up text-muted" :
        _ordenDesc            ? "bi bi-sort-down text-purple"   :
                                "bi bi-sort-up text-purple";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await Cargar();
        if (_focusBtnEliminar) { _focusBtnEliminar = false; await _btnConfirmarEliminar.FocusAsync(); }
    }

    private async Task Cargar()
    {
        _loading = true;
        _categorias = await Api.GetCategoriasAsync() ?? [];
        _loading = false;
        StateHasChanged();
    }

    private void AbrirModal() { _editandoId = 0; _nombre = ""; _descripcion = null; _errorModal = null; _mostrarModal = true; }

    private void AbrirEditar(CategoriaDto cat)
    {
        _editandoId  = cat.Id;
        _nombre      = cat.Name;
        _descripcion = cat.Description;
        _errorModal  = null;
        _mostrarModal = true;
        _mensaje = null;
    }

    private void LimpiarFiltro()
    {
        _busqueda   = string.Empty;
        _ordenCampo = string.Empty;
        _ordenDesc  = false;
    }

    private void AbrirConfirmarEliminar(CategoriaDto cat)
    {
        _catAEliminar       = cat;
        _mostrarModalEliminar = true;
        _focusBtnEliminar   = true;
    }

    private async Task ConfirmarEliminar()
    {
        if (_catAEliminar is null) return;
        _mostrarModalEliminar = false;
        var (ok, error) = await Api.DeleteCategoriaAsync(_catAEliminar.Id);
        _exito   = ok;
        _mensaje = ok ? "Categoría eliminada correctamente." : (error ?? "No se pudo eliminar la categoría.");
        if (ok) await Cargar();
        _catAEliminar = null;
    }

    private async Task Guardar()
    {
        _errorModal = null;
        if (string.IsNullOrWhiteSpace(_nombre)) { _errorModal = "El nombre es obligatorio."; return; }

        bool ok;
        string? error;

        if (_editandoId > 0)
        {
            var cat = _categorias.FirstOrDefault(c => c.Id == _editandoId);
            (ok, error) = await Api.UpdateCategoriaAsync(_editandoId, new UpdateCategoriaDto(_nombre, _descripcion, cat?.IsActive ?? true));
            if (ok) { _exito = true; _mensaje = "Categoría actualizada."; _mostrarModal = false; await Cargar(); }
            else { _errorModal = error ?? "Error al actualizar la categoría."; }
        }
        else
        {
            (ok, error) = await Api.CreateCategoriaAsync(new CreateCategoriaDto(_nombre, _descripcion));
            if (ok) { _exito = true; _mensaje = "Categoría creada."; _mostrarModal = false; await Cargar(); }
            else { _errorModal = error ?? "Error al crear la categoría."; }
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Guardar();
    }

    private ElementReference _btnConfirmarEliminar;
    private bool _focusBtnEliminar;
}
