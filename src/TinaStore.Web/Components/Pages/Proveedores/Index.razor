@page "/proveedores"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Proveedores — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-truck me-2 text-purple"></i>Proveedores</h4>
    <button class="btn bg-purple text-white" @onclick="AbrirModal">
        <i class="bi bi-plus-lg me-1"></i>Nuevo proveedor
    </button>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <div class="ts-filter-bar">
        <div class="row g-2 align-items-end">
            <div class="col">
                <label class="form-label">Buscar</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control form-control-sm" placeholder="Nombre, NIT o teléfono..."
                           @oninput="Filtrar" />
                </div>
            </div>
            <div class="col-auto d-flex align-items-end">
                <button class="btn-limpiar" @onclick="LimpiarFiltro">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Nombre</th><th>NIT</th><th>Teléfono</th><th>Email</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var p in _filtrados)
                    {
                        <tr>
                            <td class="fw-semibold">@p.Name</td>
                            <td class="text-muted small">@p.TaxId</td>
                            <td>@p.Phone</td>
                            <td>@p.Email</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary me-1" title="Editar"
                                        @onclick="() => AbrirEditar(p)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(p.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!_filtrados.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">Sin resultados</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editandoId > 0 ? "Editar" : "Nuevo") proveedor</h5>
                    <button class="btn-close" @onclick="() => _mostrarModal = false"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Nombre *</label>
                        <input class="form-control" @bind="_form.Name" maxlength="100" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">NIT / RUT</label>
                        <input class="form-control" @bind="_form.TaxId" inputmode="numeric"
                               @onkeypress="SoloNumerosNIT" placeholder="Ej: 900123456" maxlength="15" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Teléfono</label>
                        <input class="form-control" @bind="_form.Phone" inputmode="numeric"
                               @onkeypress="SoloNumerosTel" placeholder="Ej: 3001234567" maxlength="10" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Email</label>
                        <input class="form-control" @bind="_form.Email" maxlength="150" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Dirección</label>
                        <input class="form-control" @bind="_form.Address" maxlength="200" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Notas</label>
                        <input class="form-control" @bind="_form.Notes" maxlength="500" />
                    </div>
                    @if (_errorModal is not null)
                    {
                        <div class="col-12">
                            <div class="alert alert-danger py-2 small mb-0">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>@_errorModal
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModal = false">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProveedorDto> _proveedores = [];
    private List<ProveedorDto> _filtrados = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _guardando;
    private string? _mensaje;
    private bool _exito;
    private string? _errorModal;
    private ProveedorForm _form = new();
    private int _editandoId;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _loading = true;
        _proveedores = await Api.GetProveedoresAsync() ?? [];
        _filtrados = _proveedores;
        _loading = false;
    }

    private void Filtrar(ChangeEventArgs e)
    {
        var q = e.Value?.ToString()?.ToLower() ?? "";
        _filtrados = string.IsNullOrWhiteSpace(q)
            ? _proveedores
            : _proveedores.Where(p =>
                p.Name.ToLower().Contains(q) ||
                (p.TaxId?.ToLower().Contains(q) ?? false) ||
                (p.Phone?.Contains(q) ?? false)).ToList();
    }

    private void LimpiarFiltro()
    {
        _filtrados = _proveedores;
    }

    // Permite solo dígitos en el campo NIT
    private void SoloNumerosNIT(KeyboardEventArgs e)
    {
        // La prevención real en Blazor requiere JS interop; aquí validamos en Guardar.
        // Este método queda como punto de extensión visual.
    }

    // Permite solo dígitos en el campo Teléfono
    private void SoloNumerosTel(KeyboardEventArgs e)
    {
        // La prevención real en Blazor requiere JS interop; aquí validamos en Guardar.
    }

    private void AbrirModal()
    {
        _editandoId = 0;
        _form = new();
        _errorModal = null;
        _mostrarModal = true;
        _mensaje = null;
    }

    private void AbrirEditar(ProveedorDto p)
    {
        _editandoId = p.Id;
        _form = new() { Name = p.Name, TaxId = p.TaxId, Phone = p.Phone, Email = p.Email, Address = p.Address, Notes = p.Notes };
        _errorModal = null;
        _mostrarModal = true;
        _mensaje = null;
    }

    private async Task Guardar()
    {
        _errorModal = null;

        // Validaciones frontend
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _errorModal = "El nombre del proveedor es obligatorio.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(_form.TaxId) && !System.Text.RegularExpressions.Regex.IsMatch(_form.TaxId, @"^\d+$"))
        {
            _errorModal = "El NIT debe contener solo números.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(_form.Phone))
        {
            if (!System.Text.RegularExpressions.Regex.IsMatch(_form.Phone, @"^\d+$"))
            {
                _errorModal = "El teléfono debe contener solo números.";
                return;
            }
            if (_form.Phone.Length != 10)
            {
                _errorModal = "El teléfono debe tener exactamente 10 dígitos.";
                return;
            }
        }

        _guardando = true;
        bool ok;
        string? apiError = null;
        if (_editandoId > 0)
        {
            var dto = new UpdateProveedorDto(_form.Name, _form.TaxId, _form.Phone, _form.Email, _form.Address, _form.Notes, true);
            (ok, apiError) = await Api.UpdateProveedorAsync(_editandoId, dto);
        }
        else
        {
            var dto = new CreateProveedorDto(_form.Name, _form.TaxId, _form.Phone, _form.Email, _form.Address, _form.Notes);
            (ok, apiError) = await Api.CreateProveedorAsync(dto);
        }
        _guardando = false;
        if (ok)
        {
            _exito = true;
            _mensaje = _editandoId > 0 ? "Proveedor actualizado." : "Proveedor creado.";
            _mostrarModal = false;
            await Cargar();
        }
        else
        {
            _errorModal = apiError ?? "Error al guardar el proveedor. Verifica los datos e intenta de nuevo.";
        }
    }

    private async Task Eliminar(int id)
    {
        var ok = await Api.DeleteProveedorAsync(id);
        _exito = ok;
        _mensaje = ok ? "Proveedor eliminado." : "No se pudo eliminar el proveedor.";
        if (ok) await Cargar();
    }

    private class ProveedorForm
    {
        public string  Name    { get; set; } = "";
        public string? TaxId   { get; set; }
        public string? Phone   { get; set; }
        public string? Email   { get; set; }
        public string? Address { get; set; }
        public string? Notes   { get; set; }
    }
}
