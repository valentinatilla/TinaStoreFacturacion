@page "/productos/importar"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Importar Productos " Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-file-earmark-spreadsheet me-2 text-purple"></i>Importación Masiva de Productos
    </h4>
    <a href="/productos" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2 mb-3">
        <i class="bi bi-@(_exito ? "check-circle" : "exclamation-triangle") me-2"></i>@_mensaje
    </div>
}

<!-- -- Paso 1: Subir archivo -------------------------------------------- -->
@if (_paso == 1)
{
    <div class="card border-0 shadow-sm p-4" style="max-width: 600px;">
        <h6 class="fw-bold mb-3 text-purple">
            <i class="bi bi-upload me-2"></i>Paso 1 " Selecciona el archivo Excel
        </h6>
        <p class="text-muted small mb-3">
            El archivo debe seguir la plantilla oficial.
            <a href="#" @onclick="DescargarPlantilla" @onclick:preventDefault class="@(_descargandoPlantilla ? "disabled text-muted" : "")">
                @if (_descargandoPlantilla) { <span class="spinner-border spinner-border-sm me-1" style="width:.9rem;height:.9rem;"></span> }
                else { <i class="bi bi-download me-1"></i> }
                @(_descargandoPlantilla ? "Descargando..." : "Descargar plantilla")
            </a>
        </p>

        <InputFile id="excelInput" OnChange="SeleccionarArchivo" accept=".xlsx,.xls"
                   class="form-control mb-3" />

        <button class="btn bg-purple text-white px-4"
                @onclick="Previsualizar"
                disabled="@(_archivo is null || _cargando)">
            @if (_cargando)
            { <span class="spinner-border spinner-border-sm me-2"></span>@("Analizando...") }
            else
            { <i class="bi bi-eye me-1"></i>@("Previsualizar") }
        </button>
    </div>
}

<!-- -- Paso 2: Tabla de previsualización ------------------------------- -->
@if (_paso == 2 && _preview is not null)
{
    <div class="card border-0 shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0 text-purple">
                <i class="bi bi-table me-2"></i>Paso 2 " Revisa y edita las filas antes de importar
            </h6>
            <div class="d-flex gap-2">
                <span class="badge bg-success">@_preview.Count(r => r.Valido) válidas</span>
                <span class="badge bg-danger">@_preview.Count(r => !r.Valido) con error</span>
            </div>
        </div>

        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-sm table-bordered align-middle ts-table">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="width:50px;">#</th>
                        <th>Nombre *</th>
                        <th>SKU</th>
                        <th style="width:110px;">Costo *</th>
                        <th style="width:110px;">Venta *</th>
                        <th style="width:80px;">Stock</th>
                        <th style="width:80px;">Mín.</th>
                        <th>Categoría</th>
                        <th>Proveedor</th>
                        <th style="width:80px;">Imagen</th>
                        <th style="width:40px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fila in _preview)
                    {
                        <tr class="@(fila.Valido ? "" : "table-danger")">
                            <td class="text-center align-top pt-2">
                                @if (!fila.Valido)
                                {
                                    <span title="@fila.MensajeError" style="cursor:help;">
                                        <i class="bi bi-exclamation-circle text-danger"></i>
                                    </span>
                                    @if (!EsErrorDeNombre(fila.MensajeError) && !EsErrorDeSku(fila.MensajeError) && fila.CategoriaId != 0)
                                    {
                                        <div class="text-danger mt-1" style="font-size:.7rem;white-space:normal;max-width:90px;">@fila.MensajeError</div>
                                    }
                                }
                                else
                                {
                                    <i class="bi bi-check-circle text-success"></i>
                                }
                            </td>
                            <td>
                                <input class="form-control form-control-sm @(!fila.Valido && EsErrorDeNombre(fila.MensajeError) ? "is-invalid" : "")"
                                       value="@fila.Nombre"
                                       @onchange="e => ActualizarFila(fila, nameof(fila.Nombre), e.Value?.ToString())" />
                                @if (!fila.Valido && EsErrorDeNombre(fila.MensajeError))
                                {
                                    <div class="text-danger" style="font-size:.72rem;">@fila.MensajeError</div>
                                }
                            </td>
                            <td>
                                <input class="form-control form-control-sm @(!fila.Valido && EsErrorDeSku(fila.MensajeError) ? "is-invalid" : "")"
                                       value="@fila.Sku"
                                       @onchange="e => ActualizarFila(fila, nameof(fila.Sku), e.Value?.ToString())" />
                                @if (!fila.Valido && EsErrorDeSku(fila.MensajeError))
                                {
                                    <div class="text-danger" style="font-size:.72rem;">@fila.MensajeError</div>
                                }
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm"
                                       value="@fila.PrecioCosto"
                                       @onchange="e => ActualizarFilaDecimal(fila, nameof(fila.PrecioCosto), e.Value?.ToString())" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm"
                                       value="@fila.PrecioVenta"
                                       @onchange="e => ActualizarFilaDecimal(fila, nameof(fila.PrecioVenta), e.Value?.ToString())" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm" min="0"
                                       value="@fila.StockInicial"
                                       @onchange="e => ActualizarFilaInt(fila, nameof(fila.StockInicial), e.Value?.ToString())" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm" min="0"
                                       value="@fila.StockMinimo"
                                       @onchange="e => ActualizarFilaInt(fila, nameof(fila.StockMinimo), e.Value?.ToString())" />
                            </td>
                            <td>
                                <select class="form-select form-select-sm @(!fila.Valido && fila.CategoriaId == 0 ? "is-invalid" : "")"
                                        @onchange="e => ActualizarCategoria(fila, e.Value?.ToString())">
                                    <option value="0">-- Selecciona --</option>
                                    @foreach (var cat in _categorias)
                                    {
                                        <option value="@cat.Id" selected="@(fila.CategoriaId == cat.Id)">@cat.Name</option>
                                    }
                                </select>
                                @if (!fila.Valido && fila.CategoriaId == 0)
                                {
                                    <div class="text-danger" style="font-size:.72rem;">Selecciona una categoría válida.</div>
                                }
                            </td>
                            <td>
                                <span class="small text-muted">@(fila.ProveedorNombre ?? "-")</span>
                            </td>
                            <td class="text-center">
                                @{
                                    var imgKey = fila.Fila;
                                    var tieneImg = _imagenesPreview.TryGetValue(imgKey, out var imgData);
                                }
                                @if (tieneImg)
                                {
                                    <div class="d-flex flex-column align-items-center gap-1">
                                        <img src="@imgData!.PreviewUrl" alt="preview"
                                             style="width:36px;height:36px;object-fit:cover;border-radius:4px;border:1px solid #e2e8f0;" />
                                        <button type="button" class="btn btn-link btn-sm text-danger p-0"
                                                style="font-size:.65rem;"
                                                @onclick="() => QuitarImagenPreview(imgKey)">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <label class="btn btn-outline-secondary btn-sm mb-0 p-1" style="cursor:pointer;font-size:.68rem;">
                                        <i class="bi bi-image"></i>
                                        <InputFile OnChange="e => SeleccionarImagenFila(e, imgKey)"
                                                   accept=".jpg,.jpeg,.png,.webp,.avif" class="d-none" />
                                    </label>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger p-1"
                                        title="Quitar fila"
                                        @onclick="() => QuitarFila(fila)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-outline-secondary" @onclick="Reiniciar">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Cambiar archivo
            </button>
            <button class="btn bg-purple text-white px-4"
                    @onclick="Confirmar"
                    disabled="@(_guardando || !_preview.Any(r => r.Valido))">
                @if (_guardando)
                { <span class="spinner-border spinner-border-sm me-2"></span> }
                <i class="bi bi-cloud-upload me-1"></i>Importar @_preview.Count(r => r.Valido) producto(s)
            </button>
        </div>
    </div>
}

<!-- -- Paso 3: Resultado ------------------------------------------------ -->
@if (_paso == 3 && _resultado is not null)
{
    <div class="card border-0 shadow-sm p-4" style="max-width: 500px;">
        <h6 class="fw-bold mb-3 text-purple">
            <i class="bi bi-clipboard-check me-2"></i>Resultado de la importación
        </h6>
        <ul class="list-group mb-4">
            <li class="list-group-item d-flex justify-content-between">
                <span>Total filas procesadas</span>
                <strong>@_resultado.TotalFilas</strong>
            </li>
            <li class="list-group-item d-flex justify-content-between text-success">
                <span><i class="bi bi-check-circle me-1"></i>Importados correctamente</span>
                <strong>@_resultado.Importados</strong>
            </li>
            <li class="list-group-item d-flex justify-content-between text-danger">
                <span><i class="bi bi-x-circle me-1"></i>Errores</span>
                <strong>@_resultado.Errores</strong>
            </li>
        </ul>

        @if (_resultado.MensajesError.Count > 0)
        {
            <div class="alert alert-warning py-2">
                <strong>Detalle de errores:</strong>
                <ul class="mb-0 mt-1">
                    @foreach (var err in _resultado.MensajesError)
                    {
                        <li class="small">@err</li>
                    }
                </ul>
            </div>
        }

        <div class="d-flex gap-2 flex-wrap">
            @if (_resultado.Errores > 0 && _preview is not null)
            {
                <button class="btn btn-warning text-dark" @onclick="CorregirErrores">
                    <i class="bi bi-pencil-square me-1"></i>Corregir errores
                </button>
            }
            <button class="btn btn-outline-secondary" @onclick="Reiniciar">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Nueva importación
            </button>
            <a href="/productos" class="btn bg-purple text-white">
                <i class="bi bi-box-seam me-1"></i>Ver productos
            </a>
        </div>
    </div>
}

@code {
    private int _paso = 1;
    private IBrowserFile? _archivo;
    private List<ImportPreviewRowDto>? _preview;
    private ExcelImportResultDto? _resultado;
    private bool _cargando;
    private bool _guardando;
    private bool _descargandoPlantilla;
    private string? _mensaje;
    private bool _exito;
    private List<CategoriaDto> _categorias = [];

    // Imágenes asignadas a filas de la preview (clave = número de fila del Excel)
    private Dictionary<int, FilaImagen> _imagenesPreview = [];

    // Copia mutable de las filas para edición en tabla
    private List<FilaEditable> _filas = [];

    protected override async Task OnInitializedAsync()
    {
        var cats = await Api.GetCategoriasAsync();
        _categorias = cats?.Where(c => c.IsActive).OrderBy(c => c.Name).ToList() ?? [];
    }

    private void SeleccionarArchivo(InputFileChangeEventArgs e)
    {
        _archivo = e.File;
        _mensaje = null;
    }

    private async Task Previsualizar()
    {
        if (_archivo is null) return;
        _cargando = true;
        _mensaje  = null;
        try
        {
            // El stream de IBrowserFile no es seekable en Blazor Server;
            // hay que volcarlo a MemoryStream antes de enviarlo por HttpClient.
            using var ms = new MemoryStream();
            await using var browserStream = _archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            await browserStream.CopyToAsync(ms);
            ms.Position = 0;
            var result = await Api.PrevisualizarImportacionAsync(ms, _archivo.Name);
            if (result is null || result.Count == 0)
            {
                _exito   = false;
                _mensaje = "No se encontraron filas en el archivo o el formato no es válido.";
            }
            else
            {
                _preview = result;
                _paso    = 2;
            }
        }
        catch (Exception ex)
        {
            _exito   = false;
            _mensaje = $"Error al leer el archivo: {ex.Message}";
        }
        finally { _cargando = false; }
    }

    private async Task Confirmar()
    {
        if (_preview is null) return;
        _guardando = true;
        _mensaje   = null;
        try
        {
            var filasValidas = _preview.Where(r => r.Valido).ToList();
            var resultado    = await Api.ImportarProductosAsync(filasValidas);
            if (resultado is not null)
            {
                _resultado = resultado;
                _paso      = 3;
                _exito     = resultado.Errores == 0;
                _mensaje   = resultado.Errores == 0
                    ? $"Se importaron {resultado.Importados} productos correctamente."
                    : $"Se importaron {resultado.Importados} de {resultado.TotalFilas} productos. Revisa los errores.";

                // Subir imágenes asignadas a filas válidas
                if (_imagenesPreview.Count > 0 && resultado.Importados > 0)
                    await SubirImagenesImportadasAsync(filasValidas);
            }
            else
            {
                _exito   = false;
                _mensaje = "Error al confirmar la importación.";
            }
        }
        catch
        {
            _exito   = false;
            _mensaje = "Error al comunicarse con la API.";
        }
        finally { _guardando = false; }
    }

    /// <summary>Sube las imágenes asignadas a filas, haciendo match por nombre del producto.</summary>
    private async Task SubirImagenesImportadasAsync(List<ImportPreviewRowDto> filasValidas)
    {
        // Obtener los productos recién creados para obtener sus IDs
        var productosActualizados = await Api.GetProductosAsync();
        if (productosActualizados is null) return;

        foreach (var (filaNum, img) in _imagenesPreview)
        {
            var fila = filasValidas.FirstOrDefault(f => f.Fila == filaNum);
            if (fila is null || string.IsNullOrEmpty(fila.Nombre)) continue;

            var producto = productosActualizados.FirstOrDefault(p =>
                string.Equals(p.Name, fila.Nombre, StringComparison.OrdinalIgnoreCase));
            if (producto is null) continue;

            try
            {
                using var ms = new MemoryStream(img.Bytes);
                await Api.SubirImagenProductoAsync(producto.Id, ms, img.NombreArchivo);
            }
            catch { /* no bloquear si falla una imagen */ }
        }

        _imagenesPreview = [];
    }

    private async Task SeleccionarImagenFila(InputFileChangeEventArgs e, int filaNum)
    {
        const long maxBytes = 2 * 1024 * 1024;
        var archivo = e.File;
        var ext = Path.GetExtension(archivo.Name).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp" or ".avif")) return;
        if (archivo.Size > maxBytes) return;

        try
        {
            using var ms = new MemoryStream();
            await using var stream = archivo.OpenReadStream(maxBytes);
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var contentType = ext switch { ".png" => "image/png", ".webp" => "image/webp", ".avif" => "image/avif", _ => "image/jpeg" };
            var previewUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
            _imagenesPreview[filaNum] = new FilaImagen(bytes, archivo.Name, previewUrl);
        }
        catch { }
    }

    private void QuitarImagenPreview(int filaNum)
    {
        _imagenesPreview.Remove(filaNum);
    }

    private class FilaImagen(byte[] bytes, string nombreArchivo, string previewUrl)
    {
        public byte[] Bytes { get; } = bytes;
        public string NombreArchivo { get; } = nombreArchivo;
        public string PreviewUrl { get; } = previewUrl;
    }

    private void QuitarFila(ImportPreviewRowDto fila)
    {
        _preview?.Remove(fila);
    }

    private void Reiniciar()
    {
        _paso    = 1;
        _archivo = null;
        _preview = null;
        _resultado = null;
        _mensaje = null;
        _exito   = false;
        _imagenesPreview = [];
    }

    private void CorregirErrores()
    {
        if (_resultado is null) return;
        _paso      = 2;
        _resultado = null;
        _mensaje   = null;
    }

    private async Task DescargarPlantilla()
    {
        _descargandoPlantilla = true;
        try
        {
            var bytes = await Api.DescargarPlantillaExcelAsync();
            if (bytes is null) return;
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", "plantilla_productos.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
        }
        finally { _descargandoPlantilla = false; }
    }    private static bool EsErrorDeNombre(string? msg) =>
        msg is not null && (
            msg.Contains("nombre", StringComparison.OrdinalIgnoreCase) ||
            msg.Contains("producto llamado", StringComparison.OrdinalIgnoreCase) ||
            msg.Contains("obligatorio", StringComparison.OrdinalIgnoreCase));

    // Errores que corresponden al campo SKU
    private static bool EsErrorDeSku(string? msg) =>
        msg is not null && msg.Contains("SKU", StringComparison.OrdinalIgnoreCase);

    private void ActualizarCategoria(ImportPreviewRowDto fila, string? valor)
    {
        if (_preview is null) return;
        var idx = _preview.IndexOf(fila);
        if (idx < 0) return;
        if (!int.TryParse(valor, out var catId) || catId == 0)
        {
            _preview[idx] = fila with { CategoriaId = 0, CategoriaNombre = null, Valido = false, MensajeError = "Selecciona una categoría válida." };
            return;
        }
        var cat = _categorias.FirstOrDefault(c => c.Id == catId);
        var f   = fila with { CategoriaId = catId, CategoriaNombre = cat?.Name };
        _preview[idx] = RevalidarFila(f, idx);
    }

    private void ActualizarFila(ImportPreviewRowDto fila, string campo, string? valor)
    {
        if (_preview is null) return;
        var idx = _preview.IndexOf(fila);
        if (idx < 0) return;
        var f = campo switch
        {
            nameof(fila.Nombre) => fila with { Nombre = valor },
            nameof(fila.Sku)    => fila with { Sku    = valor },
            _                   => fila
        };
        _preview[idx] = RevalidarFila(f, idx);
        if (campo == nameof(fila.Sku))
            RevalidarDuplicadosSku();
    }

    private void ActualizarFilaDecimal(ImportPreviewRowDto fila, string campo, string? valor)
    {
        if (_preview is null || !decimal.TryParse(valor, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v)) return;
        var idx = _preview.IndexOf(fila);
        if (idx < 0) return;
        var f = _preview[idx];
        f = campo switch
        {
            nameof(fila.PrecioCosto) => f with { PrecioCosto = v },
            nameof(fila.PrecioVenta) => f with { PrecioVenta = v },
            _                        => f
        };
        _preview[idx] = RevalidarFila(f, idx);
    }

    private void ActualizarFilaInt(ImportPreviewRowDto fila, string campo, string? valor)
    {
        if (_preview is null || !int.TryParse(valor, out var v)) return;
        var idx = _preview.IndexOf(fila);
        if (idx < 0) return;
        var f = _preview[idx];
        f = campo switch
        {
            nameof(fila.StockInicial) => f with { StockInicial = v },
            nameof(fila.StockMinimo)  => f with { StockMinimo  = v },
            _                         => f
        };
        _preview[idx] = RevalidarFila(f, idx);
    }

    private ImportPreviewRowDto RevalidarFila(ImportPreviewRowDto f, int idx)
    {
        if (string.IsNullOrWhiteSpace(f.Nombre))
            return f with { Valido = false, MensajeError = "El nombre es obligatorio." };
        if (f.PrecioVenta <= 0)
            return f with { Valido = false, MensajeError = "El precio de venta debe ser mayor que 0." };
        if (f.CategoriaId <= 0)
            return f with { Valido = false, MensajeError = "La categoría no es válida." };

        if (!string.IsNullOrWhiteSpace(f.Sku))
        {
            var skuDup = _preview!
                .Select((row, i) => (row, i))
                .Any(x => x.i != idx
                       && !string.IsNullOrWhiteSpace(x.row.Sku)
                       && string.Equals(x.row.Sku, f.Sku, StringComparison.OrdinalIgnoreCase));
            if (skuDup)
                return f with { Valido = false, MensajeError = $"El SKU '{f.Sku}' ya existe en otra fila de esta lista. Edítalo para que sea único." };
        }

        return f with { Valido = true, MensajeError = null };
    }

    private void RevalidarDuplicadosSku()
    {
        if (_preview is null) return;
        for (var i = 0; i < _preview.Count; i++)
            _preview[i] = RevalidarFila(_preview[i], i);
    }

    private class FilaEditable { }
}
