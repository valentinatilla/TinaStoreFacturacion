@page "/productos"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS

<PageTitle>Productos — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-box-seam me-2 text-purple"></i>Productos</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="DescargarPlantilla" title="Descargar plantilla Excel">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Plantilla
        </button>
        <button class="btn btn-outline-success btn-sm" @onclick="() => _mostrarModalImportar = true">
            <i class="bi bi-file-earmark-arrow-up me-1"></i>Importar Excel
        </button>
        <button class="btn btn-outline-success btn-sm" @onclick="ExportarExcel">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
        </button>
        <button class="btn bg-purple text-white" @onclick="() => AbrirModal(0)">
            <i class="bi bi-plus-lg me-1"></i>Nuevo producto
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <div class="mb-3">
        <input class="form-control" style="max-width:320px" placeholder="🔍 Buscar producto o SKU..." @oninput="Filtrar" />
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>SKU</th><th>Producto</th><th>Categoría</th>
                        <th class="text-end">Precio venta</th>
                        <th class="text-center">Stock</th><th>Estado</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _filtrados)
                    {
                        <tr>
                            <td class="text-muted small">@p.Sku</td>
                            <td class="fw-semibold">@p.Name</td>
                            <td>@p.CategoryName</td>
                            <td class="text-end">@p.SalePrice.ToString("C0")</td>
                            <td class="text-center">
                                <span class="badge @(p.CurrentStock == 0 ? "badge-sin-stock" : p.IsLowStock ? "badge-bajo-stock" : "bg-success")">@p.CurrentStock</span>
                            </td>
                            <td>
                                @if (!p.IsActive)
                                {
                                    <span class="badge badge-estado-inactivo">Inactivo</span>
                                }
                                else if (p.CurrentStock == 0)
                                {
                                    <span class="badge badge-sin-stock">Sin stock</span>
                                }
                                else if (p.IsLowStock)
                                {
                                    <span class="badge badge-bajo-stock">Stock bajo</span>
                                }
                                else
                                {
                                    <span class="badge badge-estado-activo">Activo</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(p.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(p.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") producto</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-9">
                        <label class="form-label small fw-semibold">Nombre *</label>
                        <input class="form-control" @bind="_form.Name" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">SKU</label>
                        <input class="form-control" @bind="_form.Sku" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descripción</label>
                        <input class="form-control" @bind="_form.Description" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de venta *</label>
                        <input type="number" class="form-control" @bind="_form.SalePrice" min="0" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de costo</label>
                        <input type="number" class="form-control" @bind="_form.PurchasePrice" min="0" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock inicial</label>
                        <input type="number" class="form-control" @bind="_form.CurrentStock" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock mínimo</label>
                        <input type="number" class="form-control" @bind="_form.MinimumStock" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Unidad</label>
                        <input class="form-control" @bind="_form.Unit" placeholder="Ej: unidad, kg…" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Categoría *</label>
                        <select class="form-select" @bind="_form.CategoryId">
                            <option value="0">Seleccione...</option>
                            @foreach (var c in _categorias)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Proveedor</label>
                        <select class="form-select" @bind="_form.SupplierId">
                            <option value="">Sin proveedor</option>
                            @foreach (var s in _proveedores)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal importar Excel -->
@if (_mostrarModalImportar)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-arrow-up text-success me-2"></i>Importar productos desde Excel</h5>
                    <button class="btn-close" @onclick="CerrarModalImportar"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">
                        Sube un archivo <strong>.xlsx</strong> con las columnas de la plantilla.
                        Descarga la plantilla con el botón <i class="bi bi-file-earmark-arrow-down"></i> si aún no la tienes.
                    </p>
                    <InputFile id="importInput" OnChange="SeleccionarArchivoImportar"
                               accept=".xlsx,.xls" class="form-control mb-2" />
                    @if (_resultadoImport is not null)
                    {
                        <div class="alert @(_resultadoImport.Errores == 0 ? "alert-success" : "alert-warning") py-2 mt-2">
                            <strong>@_resultadoImport.Importados</strong> productos importados
                            @if (_resultadoImport.Errores > 0)
                            {
                                <span> · <strong class="text-danger">@_resultadoImport.Errores errores</strong></span>
                            }
                        </div>
                        @if (_resultadoImport.MensajesError.Any())
                        {
                            <ul class="small text-danger mb-0" style="max-height:120px;overflow-y:auto;">
                                @foreach (var e in _resultadoImport.MensajesError)
                                {
                                    <li>@e</li>
                                }
                            </ul>
                        }
                    }
                    @if (!string.IsNullOrEmpty(_errorImport))
                    {
                        <div class="text-danger small mt-1">@_errorImport</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModalImportar">Cerrar</button>
                    <button class="btn btn-success btn-sm" @onclick="EjecutarImportacion" disabled="@(_archivoImport is null || _importando)">
                        @if (_importando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-cloud-upload me-1"></i>Importar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductoDto> _productos = [];
    private List<ProductoDto> _filtrados = [];
    private List<CategoriaDto> _categorias = [];
    private List<ProveedorDto> _proveedores = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _editando;
    private bool _guardando;
    private int _editandoId;
    private string? _mensaje;
    private bool _exito;
    private bool _mostrarModalImportar;
    private bool _importando;
    private IBrowserFile? _archivoImport;
    private ImportResultDto? _resultadoImport;
    private string? _errorImport;
    private ProductoForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(Cargar(), CargarCatalogos());
    }

    private async Task Cargar()
    {
        _loading = true;
        _productos = await Api.GetProductosAsync() ?? [];
        _filtrados = _productos;
        _loading = false;
    }

    private async Task CargarCatalogos()
    {
        _categorias = await Api.GetCategoriasAsync() ?? [];
        _proveedores = await Api.GetProveedoresAsync() ?? [];
    }

    private void Filtrar(ChangeEventArgs e)
    {
        var q = e.Value?.ToString()?.ToLower() ?? "";
        _filtrados = string.IsNullOrWhiteSpace(q)
            ? _productos
            : _productos.Where(p => p.Name.ToLower().Contains(q) || (p.Sku?.ToLower().Contains(q) ?? false)).ToList();
    }

    private async Task AbrirModal(int id)
    {
        _editando = id > 0;
        _editandoId = id;
        _mensaje = null;
        if (_editando)
        {
            var p = await Api.GetProductoAsync(id);
            _form = p is null
                ? new()
                : new() { Name = p.Name, InternalCode = p.InternalCode, Sku = p.Sku, Description = p.Description, Unit = p.Unit, SalePrice = p.SalePrice, PurchasePrice = p.PurchasePrice, CurrentStock = p.CurrentStock, MinimumStock = p.MinimumStock, CategoryId = p.CategoryId, SupplierId = p.SupplierId };
        }
        else
        {
            _form = new();
        }
        _mostrarModal = true;
    }

    private void CerrarModal() => _mostrarModal = false;

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || _form.CategoryId == 0) return;
        _guardando = true;
        bool ok;
        if (_editando)
        {
            var dto = new UpdateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.MinimumStock, true, _form.CategoryId, _form.SupplierId);
            ok = await Api.UpdateProductoAsync(_editandoId, dto);
        }
        else
        {
            // InternalCode se genera automáticamente para no pedírselo al usuario
            var internalCode = $"PROD-{Guid.NewGuid().ToString()[..8].ToUpper()}";
            var dto = new CreateProductoDto(internalCode, _form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.CurrentStock, _form.MinimumStock, _form.CategoryId, _form.SupplierId);
            ok = await Api.CreateProductoAsync(dto);
        }
        _guardando = false;
        _exito = ok;
        _mensaje = ok ? "Producto guardado." : "Error al guardar el producto.";
        if (ok) { CerrarModal(); await Cargar(); }
    }

    private async Task Eliminar(int id)
    {
        var ok = await Api.DeleteProductoAsync(id);
        _exito = ok;
        _mensaje = ok ? "Producto eliminado." : "No se pudo eliminar el producto.";
        if (ok) await Cargar();
    }

    private async Task ExportarExcel()
    {
        try
        {
            var bytes = await Api.ExportarProductosExcelAsync();
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "productos.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
        }
        catch { _mensaje = "Error al exportar Excel."; _exito = false; }
    }

    private async Task DescargarPlantilla()
    {
        try
        {
            var bytes = await Api.DescargarPlantillaProductosAsync();
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64,
                    "plantilla-productos.xlsx",
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
        }
        catch { _mensaje = "Error al descargar la plantilla."; _exito = false; }
    }

    private void SeleccionarArchivoImportar(InputFileChangeEventArgs e)
    {
        _archivoImport  = e.File;
        _resultadoImport = null;
        _errorImport     = null;
    }

    private void CerrarModalImportar()
    {
        _mostrarModalImportar = false;
        _archivoImport        = null;
        _resultadoImport      = null;
        _errorImport          = null;
    }

    private async Task EjecutarImportacion()
    {
        if (_archivoImport is null) return;
        _importando  = true;
        _errorImport = null;
        try
        {
            await using var stream = _archivoImport.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _resultadoImport = await Api.ImportProductosAsync(stream, _archivoImport.Name);
            if (_resultadoImport is null)
                _errorImport = "Error al procesar el archivo. Verifica que sea un Excel válido.";
            else if (_resultadoImport.Importados > 0)
                await Cargar();
        }
        catch { _errorImport = "Error al comunicarse con la API."; }
        finally { _importando = false; }
    }

    private class ProductoForm
    {
        public string Name { get; set; } = "";
        public string InternalCode { get; set; } = "";
        public string? Sku { get; set; }
        public string? Description { get; set; }
        public string? Unit { get; set; }
        public decimal SalePrice { get; set; }
        public decimal PurchasePrice { get; set; }
        public int CurrentStock { get; set; }
        public int MinimumStock { get; set; } = 5;
        public int CategoryId { get; set; }
        public int? SupplierId { get; set; }
    }
}
