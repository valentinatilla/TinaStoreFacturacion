@page "/productos"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS

<PageTitle>Productos — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-box-seam me-2 text-purple"></i>Productos</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-success btn-sm" @onclick="ExportarExcel">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
        </button>
        <button class="btn bg-purple text-white" @onclick="() => AbrirModal()">
            <i class="bi bi-plus-lg me-1"></i>Nuevo producto
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-3 p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Buscar</label>
                <input class="form-control form-control-sm" placeholder="🔍 Nombre o SKU..."
                       value="@_filtroTexto"
                       @oninput="e => { _filtroTexto = e.Value?.ToString() ?? string.Empty; Filtrar(); }" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Categoría</label>
                <select class="form-select form-select-sm"
                        @onchange="e => { _filtroCategoriaId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; Filtrar(); }">
                    <option value="0">Todas</option>
                    @foreach (var c in _categorias)
                    {
                        <option value="@c.Id" selected="@(_filtroCategoriaId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Proveedor</label>
                <select class="form-select form-select-sm"
                        @onchange="e => { _filtroProveedorId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; Filtrar(); }">
                    <option value="0">Todos</option>
                    @foreach (var s in _proveedores)
                    {
                        <option value="@s.Id" selected="@(_filtroProveedorId == s.Id)">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Estado</label>
                <select class="form-select form-select-sm"
                        @onchange="e => { _filtroEstado = e.Value?.ToString() ?? string.Empty; Filtrar(); }">
                    <option value="">Todos</option>
                    <option value="activo">En stock</option>
                    <option value="bajo">Bajo stock</option>
                    <option value="agotado">Agotado</option>
                    <option value="inactivo">Inactivo</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
        <div class="mt-2 pt-2 border-top d-flex gap-4 flex-wrap">
            <span class="text-muted small"><i class="bi bi-box-seam me-1"></i>@_filtrados.Count producto(s)</span>
            <span class="text-muted small"><i class="bi bi-check-circle me-1 text-success"></i>En stock: @_filtrados.Count(p => p.IsActive && p.CurrentStock > 0 && !p.IsLowStock)</span>
            <span class="text-muted small"><i class="bi bi-exclamation-triangle me-1 text-warning"></i>Bajo stock: @_filtrados.Count(p => p.IsLowStock && p.IsActive)</span>
            <span class="text-muted small"><i class="bi bi-x-circle me-1 text-danger"></i>Agotados: @_filtrados.Count(p => p.CurrentStock == 0 && p.IsActive)</span>
        </div>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th></th>
                        <th style="cursor:pointer" @onclick='() => OrdenarPor("sku")'>SKU <i class="@(SortIconClass("sku")) ms-1 small"></i></th>
                        <th style="cursor:pointer" @onclick='() => OrdenarPor("nombre")'>Producto <i class="@(SortIconClass("nombre")) ms-1 small"></i></th>
                        <th>Categoría</th>
                        <th class="text-end" style="cursor:pointer" @onclick='() => OrdenarPor("costo")'>Costo <i class="@(SortIconClass("costo")) ms-1 small"></i></th>
                        <th class="text-end" style="cursor:pointer" @onclick='() => OrdenarPor("precio")'>Precio venta <i class="@(SortIconClass("precio")) ms-1 small"></i></th>
                        <th class="text-end" style="cursor:pointer" @onclick='() => OrdenarPor("ganancia")'>% Ganancia <i class="@(SortIconClass("ganancia")) ms-1 small"></i></th>
                        <th class="text-center" style="cursor:pointer" @onclick='() => OrdenarPor("stock")'>Stock <i class="@(SortIconClass("stock")) ms-1 small"></i></th>
                        <th>Estado</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _filtrados)
                    {
                        <tr>
                            <td class="ts-thumb-cell">
                                @if (!string.IsNullOrEmpty(p.ImagePath))
                                {
                                    <img src="@(_apiBase + p.ImagePath)" alt="@p.Name" class="ts-product-thumb" />
                                }
                                else
                                {
                                    <span class="ts-thumb-placeholder"><i class="bi bi-image"></i></span>
                                }
                            </td>
                            <td class="text-muted small">@p.Sku</td>
                            <td class="fw-semibold">@p.Name</td>
                            <td>@p.CategoryName</td>
                            <td class="text-end text-muted">@(p.PurchasePrice > 0 ? p.PurchasePrice.ToString("C0") : "—")</td>
                            <td class="text-end">@p.SalePrice.ToString("C0")</td>
                            <td class="text-end small @(p.ProfitMargin > 0 ? "text-success fw-semibold" : "text-muted")">
                                @(p.ProfitMargin > 0 ? p.ProfitMargin.ToString("0.0") + " %" : "—")
                            </td>
                            <td class="text-center">
                                <span class="badge @(p.CurrentStock == 0 && p.IsActive ? "badge-sin-stock" : p.IsLowStock && p.IsActive ? "badge-bajo-stock" : "bg-success")">@p.CurrentStock</span>
                            </td>
                            <td>
                                @if (!p.IsActive)
                                {
                                    <span class="badge badge-estado-inactivo">Inactivo</span>
                                }
                                else if (p.CurrentStock == 0)
                                {
                                    <span class="badge badge-sin-stock">Agotado</span>
                                }
                                else if (p.IsLowStock)
                                {
                                    <span class="badge badge-bajo-stock">Bajo stock</span>
                                }
                                else
                                {
                                    <span class="badge badge-estado-activo">En stock</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(p)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => AbrirModalEliminar(p)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") producto</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-5">
                        <label class="form-label small fw-semibold">Nombre *</label>
                        <input class="form-control" @bind="_form.Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">SKU</label>
                        <input class="form-control" @bind="_form.Sku" placeholder="Ej: SKU-001" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descripción</label>
                        <input class="form-control" @bind="_form.Description" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de venta *</label>
                        <input type="number" class="form-control" @bind="_form.SalePrice" min="0" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de costo</label>
                        <input type="number" class="form-control" @bind="_form.PurchasePrice" min="0" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">% Ganancia</label>
                        <div class="form-control bg-light fw-semibold text-purple" style="border-radius:10px;">
                            @if (_form.PurchasePrice > 0)
                            {
                                @(Math.Round((_form.SalePrice - _form.PurchasePrice) / _form.PurchasePrice * 100, 1).ToString("0.0") + " %")
                            }
                            else
                            {
                                <span class="text-muted small">No calculable</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock inicial</label>
                        <input type="number" class="form-control" @bind="_form.CurrentStock" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock mínimo</label>
                        <input type="number" class="form-control" @bind="_form.MinimumStock" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Unidad</label>
                        <input class="form-control" @bind="_form.Unit" placeholder="Ej: unidad, kg…" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Categoría *</label>
                        <select class="form-select" @bind="_form.CategoryId">
                            <option value="0">Seleccione...</option>
                            @foreach (var c in _categorias)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Proveedor</label>
                        <select class="form-select" @bind="_form.SupplierId">
                            <option value="">Sin proveedor</option>
                            @foreach (var s in _proveedores)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    @if (_editando)
                    {
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Ingresar unidades</label>
                            <input type="number" class="form-control" @bind="_form.StockEntrada" min="0"
                                   placeholder="0" title="Unidades que se están comprando ahora" />
                            @if (_form.StockEntrada > 0 && _form.PurchasePrice > 0)
                            {
                                <p class="text-success small mt-1 mb-0">
                                    <i class="bi bi-bag-check me-1"></i>Egreso: @((_form.StockEntrada * _form.PurchasePrice).ToString("C0"))
                                </p>
                            }
                            else
                            {
                                <p class="text-muted small mt-1 mb-0">Deja en 0 si no hay compra nueva</p>
                            }
                        </div>
                    }
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Imagen del producto</label>
                        <div class="ts-image-upload-area">
                            @if (!string.IsNullOrEmpty(_form.ImagePathActual))
                            {
                                <div class="ts-image-preview-wrap">
                                    <img src="@(_apiBase + _form.ImagePathActual)" alt="Imagen actual" class="ts-image-preview" />
                                    <button type="button" class="btn btn-sm btn-outline-danger ts-image-remove-btn" @onclick="QuitarImagenModal">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else if (_form.ImagenPreviewUrl is not null)
                            {
                                <div class="ts-image-preview-wrap">
                                    <img src="@_form.ImagenPreviewUrl" alt="Nueva imagen" class="ts-image-preview" />
                                    <button type="button" class="btn btn-sm btn-outline-danger ts-image-remove-btn" @onclick="QuitarImagenSeleccionada">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <label class="ts-image-placeholder">
                                    <i class="bi bi-cloud-arrow-up fs-3 d-block mb-1"></i>
                                    <span class="small">Clic para seleccionar imagen</span>
                                    <InputFile OnChange="SeleccionarImagen" accept=".jpg,.jpeg,.png,.webp" class="d-none" />
                                </label>
                            }
                        </div>
                        @if (_form.ImagePathActual is null && _form.ImagenPreviewUrl is null)
                        {
                            <p class="text-muted small mt-1">JPG, PNG o WEBP · Máximo 2 MB</p>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación de eliminación -->
@if (_mostrarModalEliminar && _productoAEliminar is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Eliminar producto</h5>
                    <button class="btn-close" @onclick="CerrarModalEliminar"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">¿Seguro que deseas eliminar a <strong>@_productoAEliminar.Name</strong>? Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModalEliminar">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarEliminar" disabled="@_eliminando">
                        @if (_eliminando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _apiBase = string.Empty;

    private List<ProductoDto> _productos = [];
    private List<ProductoDto> _filtrados = [];
    private List<CategoriaDto> _categorias = [];
    private List<ProveedorDto> _proveedores = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _editando;
    private bool _guardando;
    private int _editandoId;
    private string? _mensaje;
    private bool _exito;
    private ProductoForm _form = new();
    private IBrowserFile? _imagenSeleccionada;
    private byte[]? _imagenBytes;

    // ── Filtros ────────────────────────────────────────────────────────────────────
    private string _filtroTexto       = string.Empty;
    private int    _filtroCategoriaId;
    private int    _filtroProveedorId;
    private string _filtroEstado      = string.Empty;
    private string _ordenCampo        = string.Empty;
    private bool   _ordenDesc;

    [Inject] private IConfiguration Config { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _apiBase = Config["ApiBaseUrl"] ?? string.Empty;
        await Task.WhenAll(Cargar(), CargarCatalogos());
    }

    private async Task Cargar()
    {
        _loading = true;
        _productos = await Api.GetProductosAsync() ?? [];
        Filtrar();
        _loading = false;
    }

    private async Task CargarCatalogos()
    {
        _categorias = await Api.GetCategoriasAsync() ?? [];
        _proveedores = await Api.GetProveedoresAsync() ?? [];
    }

    private void Filtrar()
    {
        var query = _productos
            .Where(p => string.IsNullOrWhiteSpace(_filtroTexto) ||
                        p.Name.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ||
                        (p.Sku?.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(p => _filtroCategoriaId == 0 || p.CategoryId == _filtroCategoriaId)
            .Where(p => _filtroProveedorId == 0 || p.SupplierId == _filtroProveedorId)
            .Where(p => _filtroEstado switch
            {
                "activo"   => p.IsActive && p.CurrentStock > 0 && !p.IsLowStock,
                "bajo"     => p.IsActive && p.IsLowStock && p.CurrentStock > 0,
                "agotado"  => p.IsActive && p.CurrentStock == 0,
                "inactivo" => !p.IsActive,
                _          => true
            });

        _filtrados = _ordenCampo switch
        {
            "sku"      => _ordenDesc ? query.OrderByDescending(p => p.Sku).ToList()          : query.OrderBy(p => p.Sku).ToList(),
            "nombre"   => _ordenDesc ? query.OrderByDescending(p => p.Name).ToList()         : query.OrderBy(p => p.Name).ToList(),
            "costo"    => _ordenDesc ? query.OrderByDescending(p => p.PurchasePrice).ToList(): query.OrderBy(p => p.PurchasePrice).ToList(),
            "precio"   => _ordenDesc ? query.OrderByDescending(p => p.SalePrice).ToList()    : query.OrderBy(p => p.SalePrice).ToList(),
            "ganancia" => _ordenDesc ? query.OrderByDescending(p => p.ProfitMargin).ToList() : query.OrderBy(p => p.ProfitMargin).ToList(),
            "stock"    => _ordenDesc ? query.OrderByDescending(p => p.CurrentStock).ToList() : query.OrderBy(p => p.CurrentStock).ToList(),
            _          => query.ToList()
        };
    }

    private void OrdenarPor(string campo)
    {
        if (_ordenCampo == campo) _ordenDesc = !_ordenDesc;
        else { _ordenCampo = campo; _ordenDesc = false; }
        Filtrar();
    }

    private string SortIconClass(string campo) =>
        _ordenCampo != campo ? "bi bi-arrow-down-up text-muted" :
        _ordenDesc            ? "bi bi-sort-down text-purple"   :
                                "bi bi-sort-up text-purple";

    private void LimpiarFiltros()
    {
        _filtroTexto       = string.Empty;
        _filtroCategoriaId = 0;
        _filtroProveedorId = 0;
        _filtroEstado      = string.Empty;
        _ordenCampo        = string.Empty;
        _ordenDesc         = false;
        _filtrados         = _productos;
    }

    private async Task AbrirModal(ProductoDto? p = null)
    {
        _editando = p is not null;
        _editandoId = p?.Id ?? 0;
        _mensaje = null;
        _imagenSeleccionada = null;

        if (p is null)
        {
            _form = new();
        }
        else
        {
            var completo = await Api.GetProductoAsync(p.Id);
            _form = completo is null
                ? new() { Name = p.Name, Sku = p.Sku }
                : new()
                {
                    Name             = completo.Name,
                    Sku              = completo.Sku,
                    Description      = completo.Description,
                    Unit             = completo.Unit,
                    SalePrice        = completo.SalePrice,
                    PurchasePrice    = completo.PurchasePrice,
                    CurrentStock     = completo.CurrentStock,
                    MinimumStock     = completo.MinimumStock,
                    CategoryId       = completo.CategoryId,
                    SupplierId       = completo.SupplierId,
                    ImagePathActual  = completo.ImagePath
                };
        }

        _mostrarModal = true;
    }

    private void CerrarModal()
    {
        _mostrarModal = false;
        _imagenSeleccionada = null;
        _imagenBytes = null;
    }

    private async Task SeleccionarImagen(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        const long maxBytes = 2 * 1024 * 1024; // 2 MB

        // Validar extensión
        var ext = Path.GetExtension(archivo.Name).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
        {
            _mensaje = "Solo se permiten imágenes JPG, PNG o WEBP.";
            _exito = false;
            return;
        }

        // Validar tamaño
        if (archivo.Size > maxBytes)
        {
            _mensaje = "La imagen no puede superar 2 MB.";
            _exito = false;
            return;
        }

        try
        {
            // Leer el stream completo con CopyToAsync para evitar lecturas parciales
            using var ms = new MemoryStream();
            await using var stream = archivo.OpenReadStream(maxBytes);
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            // Generar preview en base64
            var contentType = ext switch
            {
                ".png"  => "image/png",
                ".webp" => "image/webp",
                _       => "image/jpeg"
            };
            var base64 = Convert.ToBase64String(bytes);
            _form.ImagenPreviewUrl = $"data:{contentType};base64,{base64}";
            _imagenSeleccionada = archivo;
            _imagenBytes = bytes;
            _mensaje = null;
        }
        catch (Exception ex)
        {
            _mensaje = $"Error al cargar la imagen: {ex.Message}";
            _exito = false;
            _imagenSeleccionada = null;
            _imagenBytes = null;
            _form.ImagenPreviewUrl = null;
        }
    }

    private void QuitarImagenSeleccionada()
    {
        _imagenSeleccionada = null;
        _imagenBytes = null;
        _form.ImagenPreviewUrl = null;
    }

    private void QuitarImagenModal()
    {
        _form.ImagePathActual = null;
        _form.ImagenEliminada = true;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || _form.CategoryId == 0) return;
        _guardando = true;
        int idProducto;

        if (_editando)
        {
            var dto = new UpdateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.MinimumStock, true, _form.CategoryId, _form.SupplierId, _form.StockEntrada);
            var ok = await Api.UpdateProductoAsync(_editandoId, dto);
            if (!ok) { _guardando = false; _exito = false; _mensaje = "Error al guardar el producto."; return; }
            idProducto = _editandoId;
        }
        else
        {
            var dto = new CreateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.CurrentStock, _form.MinimumStock, _form.CategoryId, _form.SupplierId);
            var creado = await Api.CreateProductoAsync(dto);
            if (creado is null) { _guardando = false; _exito = false; _mensaje = "Error al crear el producto."; return; }
            idProducto = creado.Id;
        }

        // Gestión de imagen
        if (_imagenSeleccionada is not null && _imagenBytes is not null)
        {
            try
            {
                // Usar los bytes ya leídos durante la selección (IBrowserFile no puede reabrirse)
                using var ms = new MemoryStream(_imagenBytes);
                await Api.SubirImagenProductoAsync(idProducto, ms, _imagenSeleccionada.Name);
            }
            catch
            {
                _guardando = false;
                _mensaje = "Producto guardado, pero no se pudo subir la imagen. Intente editarlo nuevamente.";
                _exito = true;
                CerrarModal();
                await Cargar();
                return;
            }
        }
        else if (_form.ImagenEliminada)
        {
            await Api.EliminarImagenProductoAsync(idProducto);
        }

        _guardando = false;
        _exito = true;
        _mensaje = "Producto guardado.";
        CerrarModal();
        await Cargar();
    }

    private bool        _mostrarModalEliminar;
    private ProductoDto? _productoAEliminar;
    private bool         _eliminando;

    private void AbrirModalEliminar(ProductoDto p)
    {
        _productoAEliminar    = p;
        _mostrarModalEliminar = true;
    }

    private void CerrarModalEliminar()
    {
        _mostrarModalEliminar = false;
        _productoAEliminar    = null;
    }

    private async Task ConfirmarEliminar()
    {
        if (_productoAEliminar is null) return;
        _eliminando = true;
        var ok = await Api.DeleteProductoAsync(_productoAEliminar.Id);
        _exito   = ok;
        _mensaje = ok ? "Producto eliminado." : "No se pudo eliminar el producto.";
        _eliminando = false;
        CerrarModalEliminar();
        if (ok) await Cargar();
    }

    private async Task ExportarExcel()
    {
        try
        {
            var bytes = await Api.ExportarProductosExcelAsync();
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "productos.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
        }
        catch { _mensaje = "Error al exportar Excel."; _exito = false; }
    }

    private class ProductoForm
    {
        public string Name { get; set; } = "";
        public string? Sku { get; set; }
        public string? Description { get; set; }
        public string? Unit { get; set; }
        public decimal SalePrice { get; set; }
        public decimal PurchasePrice { get; set; }
        public int CurrentStock { get; set; }
        public int MinimumStock { get; set; } = 5;
        public int CategoryId { get; set; }
        public int? SupplierId { get; set; }
        public string? ImagePathActual { get; set; }
        public string? ImagenPreviewUrl { get; set; }
        public bool ImagenEliminada { get; set; }
        public int StockEntrada { get; set; }
    }
}
