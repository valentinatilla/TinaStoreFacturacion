                    </div>
                }
                else
                {
                    <!-- ”€”€ PASO 2: resumen y confirmación ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€ -->
                    <div class="modal-body">
                        @{
                            var _resumenNumericos = FilasConCambiosNumericos.ToList();
                            var _resumenImagenes  = FilasConImagenNueva.ToList();
                        }
                        <div class="alert alert-warning py-2 mb-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @if (_resumenNumericos.Count > 0)
                            {
                                <span>Se actualizarán <strong>@_resumenNumericos.Count</strong> producto(s) con cambios de precio/stock.</span>
                            }
                            @if (_resumenImagenes.Count > 0)
                            {
                                <span class="@(_resumenNumericos.Count > 0 ? "ms-2" : "")">Se subirán <strong>@_resumenImagenes.Count</strong> imagen(es).</span>
                            }
                        </div>

                        @if (_resumenNumericos.Count > 0)
                        {
                            <h6 class="fw-semibold text-purple mb-2"><i class="bi bi-pencil-square me-1"></i>Cambios de precio / stock</h6>
                            <div class="table-responsive mb-3">
                                <table class="table table-sm">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Producto</th>
                                            <th class="text-end">Costo</th>
                                            <th class="text-end">Precio venta</th>
                                            <th class="text-center">Stock</th>
                                            <th class="text-end">Valor inventario</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var fila in _resumenNumericos)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@fila.Nombre</td>
                                                <td class="text-end">
                                                    @if (fila.Costo != fila.CostoOriginal)
                                                    {
                                                        <span class="text-muted text-decoration-line-through me-1 small">$@fila.CostoOriginal.ToString("N0")</span>
                                                        <span class="text-success fw-semibold">$@fila.Costo.ToString("N0")</span>
                                                    }
                                                    else { <span class="text-muted">$@fila.Costo.ToString("N0")</span> }
                                                </td>
                                                <td class="text-end">
                                                    @if (fila.PrecioVenta != fila.PrecioOriginal)
                                                    {
                                                        <span class="text-muted text-decoration-line-through me-1 small">$@fila.PrecioOriginal.ToString("N0")</span>
                                                        <span class="text-success fw-semibold">$@fila.PrecioVenta.ToString("N0")</span>
                                                    }
                                                    else { <span class="text-muted">$@fila.PrecioVenta.ToString("N0")</span> }
                                                </td>
                                                <td class="text-center">
                                                    @if (fila.Stock != fila.StockOriginal)
                                                    {
                                                        <span class="text-muted text-decoration-line-through me-1 small">@fila.StockOriginal</span>
                                                        <span class="text-success fw-semibold">@fila.Stock</span>
                                                        <i class="bi bi-arrow-right-short text-muted"></i>
                                                        <span class="badge bg-info text-dark" style="font-size:.7rem;">
                                                            <i class="bi bi-arrow-clockwise me-1"></i>Movimiento
                                                        </span>
                                                    }
                                                    else { <span class="text-muted">@fila.Stock</span> }
                                                </td>
                                                <td class="text-end fw-semibold text-purple">$@fila.ValorInventario.ToString("N0")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        @if (_resumenImagenes.Count > 0)
                        {
                            <h6 class="fw-semibold text-purple mb-2"><i class="bi bi-images me-1"></i>Imágenes a subir</h6>
                            <div class="d-flex flex-wrap gap-3 mb-3">
                                @foreach (var fila in _resumenImagenes)
                                {
                                    <div class="d-flex flex-column align-items-center" style="width:80px;">
                                        <img src="@fila.ImagenPreviewUrl" alt="@fila.Nombre"
                                             style="width:64px;height:64px;object-fit:cover;border-radius:8px;border:1px solid #e2e8f0;" />
                                        <span class="text-muted mt-1" style="font-size:.65rem;text-align:center;word-break:break-word;">@fila.Nombre</span>
                                    </div>
                                }
                            </div>
                        }

                        @if (_bulkResultado is not null)
                        {
                            <div class="alert @(_bulkResultado.TotalErrores == 0 ? "alert-success" : "alert-warning") py-2 mt-2">
                                <i class="bi @(_bulkResultado.TotalErrores == 0 ? "bi-check-circle" : "bi-exclamation-triangle") me-2"></i>
                                Actualizados: <strong>@_bulkResultado.TotalActualizados</strong>
                                @if (_bulkResultado.TotalErrores > 0)
                                {
                                    <span> · Errores: <strong class="text-danger">@_bulkResultado.TotalErrores</strong></span>
                                    @foreach (var e in _bulkResultado.Resultados.Where(r => !r.Ok))
                                    {
                                        <div class="small text-danger mt-1">@e.ProductName: @e.Error</div>
                                    }
                                }
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _bulkPaso = 1" disabled="@_bulkGuardando">
                            <i class="bi bi-arrow-left me-1"></i>Volver
                        </button>
                        <button class="btn bg-purple text-white" @onclick="GuardarEdicionMasiva" disabled="@_bulkGuardando">
                            @if (_bulkGuardando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            <i class="bi bi-check-lg me-1"></i>Guardar cambios
                        </button>
                    </div>
                }

            </div>
        </div>
    </div>
}

@code {
    private string _apiBase = string.Empty;

    // ”€”€ Tarjetas resumen (calculadas desde _productos) ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€
    private int     _refDisponibles  => _productos.Count(p => p.IsActive && p.CurrentStock > 0);
    private decimal _costoInventario => _productos.Where(p => p.IsActive).Sum(p => p.PurchasePrice * p.CurrentStock);

    private List<ProductoDto> _productos = [];
    private List<ProductoDto> _filtrados = [];
    private List<CategoriaDto> _categorias = [];
    private List<ProveedorDto> _proveedores = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _editando;
    private bool _guardando;
    private bool _exportando;
    private int _editandoId;
    private string? _mensaje;
    private bool _exito;
    private string? _errorModal;
    private ProductoForm _form = new();
    private IBrowserFile? _imagenSeleccionada;
    private byte[]? _imagenBytes;

    // ”€”€ Drag & drop JS interop ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€
    private ElementReference _dropZoneRef;
    private DotNetObjectReference<Index>? _dotNetRef;
    private bool _dropZoneIniciada;

    // ”€”€ Filtros ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€
    private string   _filtroTexto       = string.Empty;
    private int      _filtroCategoriaId;
    private int      _filtroProveedorId;
    private string   _filtroEstado      = string.Empty;
    private string   _ordenCampo        = string.Empty;
    private bool     _ordenDesc;

    protected override async Task OnInitializedAsync()
    {
        _apiBase = Api.PublicBaseUrl;
        await Task.WhenAll(Cargar(), CargarCatalogos());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusBtnEliminar) { _focusBtnEliminar = false; await _btnConfirmarEliminar.FocusAsync(); }

        if (_mostrarModal && !_dropZoneIniciada)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                // Pequeño delay para que el <input type="file"> (Blazor lo renderiza
                // de forma asíncrona) ya esté en el DOM antes de que el JS lo busque
                await Task.Delay(50);
                await JS.InvokeVoidAsync("tinaDropZone.init", _dropZoneRef, "nativeImgProducto", _dotNetRef);
                _dropZoneIniciada = true;
            }
            catch { }
        }
        else if (!_mostrarModal && _dropZoneIniciada)
        {
            try { await JS.InvokeVoidAsync("tinaDropZone.dispose", _dropZoneRef); } catch { }
            _dropZoneIniciada = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dropZoneIniciada)
        {
            try { await JS.InvokeVoidAsync("tinaDropZone.dispose", _dropZoneRef); } catch { }
        }
        _dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task RecibirDropBase64(string base64, string mime, string fileName, long fileSize)
    {
        const long maxBytes = 2 * 1024 * 1024;

        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
        {
            _errorModal = "Solo se permiten imágenes JPG, PNG o WEBP.";
            await InvokeAsync(StateHasChanged);
            return;
        }
        if (fileSize > maxBytes)
        {
            _errorModal = "La imagen no puede superar 2 MB.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var bytes = Convert.FromBase64String(base64);
            _imagenBytes = bytes;
            _imagenSeleccionada = null; // drop no genera IBrowserFile
            _form.ImagenPreviewUrl = $"data:{mime};base64,{base64}";
            _errorModal = null;
        }
        catch
        {
            _errorModal = "Error al procesar la imagen arrastrada.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task Cargar()
    {
        _loading = true;
        _productos = await Api.GetProductosAsync() ?? [];
        Filtrar();
        _loading = false;
    }

    private async Task CargarCatalogos()
    {
        _categorias = await Api.GetCategoriasAsync() ?? [];
        _proveedores = await Api.GetProveedoresAsync() ?? [];
    }

    private void Filtrar()
    {
        var query = _productos
            .Where(p => string.IsNullOrWhiteSpace(_filtroTexto) ||
                        p.Name.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ||
                        (p.Sku?.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(p => _filtroCategoriaId == 0 || p.CategoryId == _filtroCategoriaId)
            .Where(p => _filtroProveedorId == 0 || p.SupplierId == _filtroProveedorId)
            .Where(p => _filtroEstado switch
            {
                "activo"   => p.IsActive && p.CurrentStock > 0 && !p.IsLowStock,
                "bajo"     => p.IsActive && p.IsLowStock && p.CurrentStock > 0,
                "agotado"  => p.IsActive && p.CurrentStock == 0,
                "inactivo" => !p.IsActive,
                _          => true
            });

        _filtrados = _ordenCampo switch
        {
            "sku"      => _ordenDesc ? query.OrderByDescending(p => p.Sku).ToList()           : query.OrderBy(p => p.Sku).ToList(),
            "nombre"   => _ordenDesc ? query.OrderByDescending(p => p.Name).ToList()          : query.OrderBy(p => p.Name).ToList(),
            "costo"    => _ordenDesc ? query.OrderByDescending(p => p.PurchasePrice).ToList() : query.OrderBy(p => p.PurchasePrice).ToList(),
            "precio"   => _ordenDesc ? query.OrderByDescending(p => p.SalePrice).ToList()     : query.OrderBy(p => p.SalePrice).ToList(),
            "ganancia" => _ordenDesc ? query.OrderByDescending(p => p.ProfitMargin).ToList()  : query.OrderBy(p => p.ProfitMargin).ToList(),
            "stock"    => _ordenDesc ? query.OrderByDescending(p => p.CurrentStock).ToList()  : query.OrderBy(p => p.CurrentStock).ToList(),
            _          => query.ToList()
        };
    }

    private void OrdenarPor(string campo)
    {
        if (_ordenCampo == campo) _ordenDesc = !_ordenDesc;
        else { _ordenCampo = campo; _ordenDesc = false; }
        Filtrar();
    }

    private string SortIconClass(string campo) =>
        _ordenCampo != campo ? "bi bi-arrow-down-up text-muted" :
        _ordenDesc            ? "bi bi-sort-down text-purple"   :
                                "bi bi-sort-up text-purple";

    private void LimpiarFiltros()
    {
        _filtroTexto       = string.Empty;
        _filtroCategoriaId = 0;
        _filtroProveedorId = 0;
        _filtroEstado      = string.Empty;
        _ordenCampo        = string.Empty;
        _ordenDesc         = false;
        _filtrados         = _productos;
    }

    private int _stockOriginalEdicion;

    private async Task AbrirModal(ProductoDto? p = null)
    {
        _editando = p is not null;
        _editandoId = p?.Id ?? 0;
        _mensaje = null;
        _errorModal = null;
        _imagenSeleccionada = null;
        _stockOriginalEdicion = 0;

        if (p is null)
        {
            _form = new();
        }
        else
        {
            var completo = await Api.GetProductoAsync(p.Id);
            _form = completo is null
                ? new()
                {
                    Name          = p.Name,
                    Sku           = p.Sku,
                    SalePrice     = p.SalePrice,
                    PurchasePrice = p.PurchasePrice,
                    CurrentStock  = p.CurrentStock,
                    MinimumStock  = p.MinimumStock,
                    CategoryId    = p.CategoryId,
                    SupplierId    = p.SupplierId,
                    ImagePathActual = p.ImagePath
                }
                : new()
                {
                    Name             = completo.Name,
                    Sku              = completo.Sku,
                    Description      = completo.Description,
                    Unit             = completo.Unit,
                    SalePrice        = completo.SalePrice,
                    PurchasePrice    = completo.PurchasePrice,
                    CurrentStock     = completo.CurrentStock,
                    MinimumStock     = completo.MinimumStock,
                    CategoryId       = completo.CategoryId,
                    SupplierId       = completo.SupplierId,
                    ImagePathActual  = completo.ImagePath
                };

            _stockOriginalEdicion = _form.CurrentStock;
        }

        _mostrarModal = true;
    }

    private void CerrarModal()
    {
        _mostrarModal = false;
        _imagenSeleccionada = null;
        _imagenBytes = null;
        _dropZoneIniciada = false;
    }

    private async Task SeleccionarImagen(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        const long maxBytes = 2 * 1024 * 1024; // 2 MB

        // Validar extensión
        var ext = Path.GetExtension(archivo.Name).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
        {
            _mensaje = "Solo se permiten imágenes JPG, PNG o WEBP.";
            _exito = false;
            return;
        }

        // Validar tamaño
        if (archivo.Size > maxBytes)
        {
            _mensaje = "La imagen no puede superar 2 MB.";
            _exito = false;
            return;
        }

        try
        {
            // Leer el stream completo con CopyToAsync para evitar lecturas parciales
            using var ms = new MemoryStream();
            await using var stream = archivo.OpenReadStream(maxBytes);
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            // Generar preview en base64
            var contentType = ext switch
            {
                ".png"  => "image/png",
                ".webp" => "image/webp",
                _       => "image/jpeg"
            };
            var base64 = Convert.ToBase64String(bytes);
            _form.ImagenPreviewUrl = $"data:{contentType};base64,{base64}";
            _imagenSeleccionada = archivo;
            _imagenBytes = bytes;
            _mensaje = null;
        }
        catch (Exception ex)
        {
            _mensaje = $"Error al cargar la imagen: {ex.Message}";
            _exito = false;
            _imagenSeleccionada = null;
            _imagenBytes = null;
            _form.ImagenPreviewUrl = null;
        }
    }

    private void QuitarImagenSeleccionada()
    {
        _imagenSeleccionada = null;
        _imagenBytes = null;
        _form.ImagenPreviewUrl = null;
    }

    private void QuitarImagenModal()
    {
        _form.ImagePathActual = null;
        _form.ImagenEliminada = true;
    }

    private async Task Guardar()
    {
        // ”€”€ Validaciones por campo ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€
        _errorModal = null;
        _mensaje = null;
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _errorModal = "El nombre del producto es obligatorio.";
            return;
        }
        if (_form.CategoryId == 0)
        {
            _errorModal = "Debes seleccionar una categoría.";
            return;
        }
        if (_form.SalePrice <= 0)
        {
            _errorModal = "El precio de venta debe ser mayor a cero.";
            return;
        }
        if (_form.SalePrice > 999_999.99m)
        {
            _errorModal = "El precio de venta no puede superar $999.999,99.";
            return;
        }
        if (_form.PurchasePrice < 0)
        {
            _errorModal = "El precio de costo no puede ser negativo.";
            return;
        }
        if (_form.PurchasePrice > 999_999.99m)
        {
            _errorModal = "El precio de costo no puede superar $999.999,99.";
            return;
        }
        if (_form.CurrentStock < 0)
        {
            _errorModal = "El stock no puede ser negativo.";
            return;
        }
        if (_form.MinimumStock < 0)
        {
            _errorModal = "El stock mínimo no puede ser negativo.";
            return;
        }
        if (!string.IsNullOrWhiteSpace(_form.Unit) && System.Text.RegularExpressions.Regex.IsMatch(_form.Unit, @"\d"))
        {
            _errorModal = "La unidad de medida no debe contener números.";
            return;
        }

        _guardando = true;
        int idProducto;

        if (_editando)
        {
            var stockDelta = _form.CurrentStock - _stockOriginalEdicion;
            var dto = new UpdateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.MinimumStock, true, _form.CategoryId, _form.SupplierId, stockDelta);
            var (ok, err) = await Api.UpdateProductoAsync(_editandoId, dto);
            if (!ok) { _guardando = false; _errorModal = err ?? "Error al guardar el producto."; return; }
            idProducto = _editandoId;
        }
        else
        {
            var dto = new CreateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.CurrentStock, _form.MinimumStock, _form.CategoryId, _form.SupplierId);
            var (creado, err) = await Api.CreateProductoAsync(dto);
            if (creado is null) { _guardando = false; _errorModal = err ?? "Error al crear el producto."; return; }
            idProducto = creado.Id;
        }

        // Gestión de imagen
        if (_imagenBytes is not null)
        {
            var nombreArchivo = _imagenSeleccionada?.Name ?? "imagen.jpg";
            try
            {
                using var ms = new MemoryStream(_imagenBytes);
                await Api.SubirImagenProductoAsync(idProducto, ms, nombreArchivo);
            }
            catch
            {
                _guardando = false;
                _mensaje = "Producto guardado, pero no se pudo subir la imagen. Intente editarlo nuevamente.";
                _exito = true;
                CerrarModal();
                await Cargar();
                return;
            }
        }
        else if (_form.ImagenEliminada)
        {
            await Api.EliminarImagenProductoAsync(idProducto);
        }

        _guardando = false;
        _exito = true;
        _mensaje = "Producto guardado.";
        CerrarModal();
        await Cargar();
    }

    private bool        _mostrarModalEliminar;
    private ProductoDto? _productoAEliminar;
    private bool         _eliminando;

    private async Task HandleModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_guardando) await Guardar();
    }

    private void AbrirModalEliminar(ProductoDto p)
    {
        _productoAEliminar    = p;
        _mostrarModalEliminar = true;
        _focusBtnEliminar     = true;
    }

    private void CerrarModalEliminar()
    {
        _mostrarModalEliminar = false;
        _productoAEliminar    = null;
    }

    private async Task ConfirmarEliminar()
    {
        if (_productoAEliminar is null) return;
        _eliminando = true;
        var ok = await Api.DeleteProductoAsync(_productoAEliminar.Id);
        _exito   = ok;
        _mensaje = ok ? "Producto eliminado." : "No se pudo eliminar el producto.";
        _eliminando = false;
        CerrarModalEliminar();
        if (ok) await Cargar();
    }

    private async Task ExportarExcel()
    {
        _exportando = true;
        try
        {
            var bytes = await Api.ExportarProductosExcelAsync();
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "productos.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
        }
        catch { _mensaje = "Error al exportar Excel."; _exito = false; }
        finally { _exportando = false; }
    }

    private class ProductoForm
    {
        public string Name { get; set; } = "";
        public string? Sku { get; set; }
        public string? Description { get; set; }
        public string? Unit { get; set; }
        public decimal SalePrice { get; set; }
        public decimal PurchasePrice { get; set; }
        public int CurrentStock { get; set; }
        public int MinimumStock { get; set; } = 5;
        public int CategoryId { get; set; }
        public int? SupplierId { get; set; }
        public string? ImagePathActual { get; set; }
        public string? ImagenPreviewUrl { get; set; }
        public bool ImagenEliminada { get; set; }
        public int StockEntrada { get; set; }
    }

    // ”€”€ Edición masiva ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€
    private bool               _mostrarEdicionMasiva;
    private int                _bulkPaso = 1;
    private string             _bulkFiltro = "";
    private bool               _bulkGuardando;
    private BulkUpdateResultDto? _bulkResultado;
    private List<BulkFila>     _bulkFilas = [];

    private IEnumerable<BulkFila> FilasFiltradas =>
        string.IsNullOrWhiteSpace(_bulkFiltro)
            ? _bulkFilas
            : _bulkFilas.Where(f =>
                f.Nombre.Contains(_bulkFiltro, StringComparison.OrdinalIgnoreCase) ||
                (f.Sku?.Contains(_bulkFiltro, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<BulkFila> FilasConCambiosNumericos =>
        _bulkFilas.Where(f => !f.TieneError &&
            (f.Costo != f.CostoOriginal || f.PrecioVenta != f.PrecioOriginal || f.Stock != f.StockOriginal));

    private IEnumerable<BulkFila> FilasConImagenNueva =>
        _bulkFilas.Where(f => f.TieneImagenNueva);

    private async Task SeleccionarImagenBulk(InputFileChangeEventArgs e, BulkFila fila)
    {
        var archivo = e.File;
        const long maxBytes = 2 * 1024 * 1024;
        var ext = Path.GetExtension(archivo.Name).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp")) return;
        if (archivo.Size > maxBytes) return;
        try
        {
            using var ms = new MemoryStream();
            await using var stream = archivo.OpenReadStream(maxBytes);
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var contentType = ext switch { ".png" => "image/png", ".webp" => "image/webp", _ => "image/jpeg" };
            var previewUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
            fila.SetImagen(bytes, archivo.Name, previewUrl);
        }
        catch { /* silencioso; la imagen simplemente no se carga */ }
    }

    private void AbrirEdicionMasiva()
    {
        _bulkFilas = _productos
            .Where(p => p.IsActive)
            .Select(p => new BulkFila(p))
            .ToList();
        _bulkFiltro    = "";
        _bulkPaso      = 1;
        _bulkResultado = null;
        _mostrarEdicionMasiva = true;
    }

    private int _bulkImagenesSubidas;
    private int _bulkImagenesErrores;

    private void CerrarEdicionMasiva()
    {
        _mostrarEdicionMasiva = false;
        _bulkResultado        = null;
        _bulkImagenesSubidas  = 0;
        _bulkImagenesErrores  = 0;
    }

    private void IrAPaso2()
    {
        _bulkResultado = null;
        _bulkPaso = 2;
    }

    private async Task GuardarEdicionMasiva()
    {
        var filasConCambios = FilasConCambiosNumericos.ToList();
        var filasConImagen  = FilasConImagenNueva.ToList();
        if (!filasConCambios.Any() && !filasConImagen.Any()) return;

        _bulkGuardando       = true;
        _bulkImagenesSubidas = 0;
        _bulkImagenesErrores = 0;
        try
        {
            // 1) Bulk update numérico
            if (filasConCambios.Any())
            {
                var items = filasConCambios.Select(f => new BulkUpdateItemDto(
                    f.ProductId,
                    f.Costo != f.CostoOriginal       ? f.Costo       : null,
                    f.PrecioVenta != f.PrecioOriginal ? f.PrecioVenta : null,
                    f.Stock != f.StockOriginal        ? f.Stock       : null
                )).ToList();
                _bulkResultado = await Api.BulkUpdateProductosAsync(items);
            }

            // 2) Subida de imágenes
            var erroresImagen = new List<string>();
            foreach (var fila in filasConImagen)
            {
                try
                {
                    using var ms = new MemoryStream(fila.ImagenBytes!);
                    var resultado = await Api.SubirImagenProductoAsync(fila.ProductId, ms, fila.ImagenNombreArchivo!);
                    if (resultado is not null)
                        _bulkImagenesSubidas++;
                    else
                    {
                        _bulkImagenesErrores++;
                        erroresImagen.Add($"{fila.Nombre}: no se pudo subir la imagen.");
                    }
                }
                catch (Exception ex)
                {
                    _bulkImagenesErrores++;
                    erroresImagen.Add($"{fila.Nombre}: {ex.Message}");
                }
            }

            // 3) Evaluar resultado global
            var numErrores  = _bulkResultado?.TotalErrores ?? 0;
            var numActualizados = _bulkResultado?.TotalActualizados ?? 0;
            var hayErrores  = numErrores > 0 || _bulkImagenesErrores > 0;

            _exito = !hayErrores;
            var partes = new List<string>();
            if (numActualizados > 0)
                partes.Add($"{numActualizados} producto(s) actualizados");
            if (_bulkImagenesSubidas > 0)
                partes.Add($"{_bulkImagenesSubidas} imagen(es) subidas");
            if (_bulkImagenesErrores > 0)
                partes.Add($"{_bulkImagenesErrores} imagen(es) con error");
            if (numErrores > 0)
                partes.Add($"{numErrores} error(es) numérico(s)");
            _mensaje = "Edición masiva: " + string.Join(" · ", partes) + ".";

            // Mostrar detalle de errores de imagen en el resultado del bulk
            if (erroresImagen.Count > 0 && _bulkResultado is null)
            {
                _bulkResultado = new BulkUpdateResultDto(
                    filasConImagen.Count, _bulkImagenesSubidas, _bulkImagenesErrores,
                    erroresImagen.Select(e => new BulkUpdateItemResultDto(0, e, false, e)).ToList());
            }

            if (!hayErrores)
            {
                _mostrarEdicionMasiva = false;
                await Cargar();
            }
        }
        catch { _mensaje = "Error al comunicarse con la API."; _exito = false; }
        finally { _bulkGuardando = false; }
    }

    private class BulkFila
    {
        public int     ProductId     { get; }
        public string  Nombre        { get; }
        public string? Sku           { get; }
        public string? ImagePathActual { get; }

        // Valores originales (para detectar cambios y mostrar diff)
        public decimal CostoOriginal  { get; }
        public decimal PrecioOriginal { get; }
        public int     StockOriginal  { get; }

        // Valores editables
        private decimal _costo;
        private decimal _precioVenta;
        private int     _stock;

        public decimal Costo
        {
            get => _costo;
            set { _costo = value; Recalcular(); }
        }
        public decimal PrecioVenta
        {
            get => _precioVenta;
            set { _precioVenta = value; Recalcular(); }
        }
        public int Stock
        {
            get => _stock;
            set { _stock = value; Recalcular(); }
        }

        // Imagen nueva
        public byte[]?  ImagenBytes         { get; private set; }
        public string?  ImagenNombreArchivo { get; private set; }
        public string?  ImagenPreviewUrl    { get; private set; }
        public bool     TieneImagenNueva    => ImagenBytes is not null;

        public void SetImagen(byte[] bytes, string nombre, string previewUrl)
        {
            ImagenBytes         = bytes;
            ImagenNombreArchivo = nombre;
            ImagenPreviewUrl    = previewUrl;
        }

        public void QuitarImagen()
        {
            ImagenBytes         = null;
            ImagenNombreArchivo = null;
            ImagenPreviewUrl    = null;
        }

        // Calculado
        public decimal ValorInventario { get; private set; }

        // Estado
        public bool    Modificada  => Costo != CostoOriginal || PrecioVenta != PrecioOriginal || Stock != StockOriginal || TieneImagenNueva;
        public string? ErrorCosto  { get; private set; }
        public string? ErrorPrecio { get; private set; }
        public string? ErrorStock  { get; private set; }
        public bool    TieneError  => ErrorCosto is not null || ErrorPrecio is not null || ErrorStock is not null;

        public BulkFila(ProductoDto p)
        {
            ProductId       = p.Id;
            Nombre          = p.Name;
            Sku             = p.Sku;
            ImagePathActual = p.ImagePath;
            CostoOriginal   = p.PurchasePrice;
            PrecioOriginal  = p.SalePrice;
            StockOriginal   = p.CurrentStock;
            _costo          = p.PurchasePrice;
            _precioVenta    = p.SalePrice;
            _stock          = p.CurrentStock;
            Recalcular();
        }

        public void Recalcular()
        {
            ErrorCosto  = _costo < 0           ? "El costo no puede ser negativo."
                        : _costo > 999_999m    ? "El precio de costo no puede ser mayor a 999.999."
                        : null;
            ErrorPrecio = _precioVenta <= 0     ? "El precio de venta debe ser mayor a cero."
                        : _precioVenta > 999_999m ? "El precio de venta no puede ser mayor a 999.999."
                        : null;
            ErrorStock  = _stock < 0            ? "El stock no puede ser negativo." : null;
            ValorInventario = _costo * Math.Max(0, _stock);
        }
    }

