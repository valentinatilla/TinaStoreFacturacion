@page "/productos"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS

<PageTitle>Productos — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-box-seam me-2 text-purple"></i>Productos</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-success btn-sm" @onclick="ExportarExcel">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
        </button>
        <button class="btn bg-purple text-white" @onclick="() => AbrirModal()">
            <i class="bi bi-plus-lg me-1"></i>Nuevo producto
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <div class="mb-3">
        <input class="form-control" style="max-width:320px" placeholder="🔍 Buscar producto o SKU..." @oninput="Filtrar" />
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th></th>
                        <th>SKU</th><th>Producto</th><th>Categoría</th>
                        <th class="text-end">Precio venta</th>
                        <th class="text-end">% Ganancia</th>
                        <th class="text-center">Stock</th><th>Estado</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _filtrados)
                    {
                        <tr>
                            <td class="ts-thumb-cell">
                                @if (!string.IsNullOrEmpty(p.ImagePath))
                                {
                                    <img src="@(_apiBase + p.ImagePath)" alt="@p.Name" class="ts-product-thumb" />
                                }
                                else
                                {
                                    <span class="ts-thumb-placeholder"><i class="bi bi-image"></i></span>
                                }
                            </td>
                            <td class="text-muted small">@p.Sku</td>
                            <td class="fw-semibold">@p.Name</td>
                            <td>@p.CategoryName</td>
                            <td class="text-end">@p.SalePrice.ToString("C0")</td>
                            <td class="text-end small @(p.ProfitMargin > 0 ? "text-success fw-semibold" : "text-muted")">
                                @(p.ProfitMargin > 0 ? p.ProfitMargin.ToString("0.0") + " %" : "—")
                            </td>
                            <td class="text-center">
                                <span class="badge @(p.CurrentStock == 0 && p.IsActive ? "badge-sin-stock" : p.IsLowStock && p.IsActive ? "badge-bajo-stock" : "bg-success")">@p.CurrentStock</span>
                            </td>
                            <td>
                                @if (!p.IsActive)
                                {
                                    <span class="badge badge-estado-inactivo">Inactivo</span>
                                }
                                else if (p.CurrentStock == 0)
                                {
                                    <span class="badge badge-sin-stock">Agotado</span>
                                }
                                else if (p.IsLowStock)
                                {
                                    <span class="badge badge-bajo-stock">Bajo stock</span>
                                }
                                else
                                {
                                    <span class="badge badge-estado-activo">Activo</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(p)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(p.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") producto</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-5">
                        <label class="form-label small fw-semibold">Nombre *</label>
                        <input class="form-control" @bind="_form.Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">SKU</label>
                        <input class="form-control" @bind="_form.Sku" placeholder="Ej: SKU-001" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descripción</label>
                        <input class="form-control" @bind="_form.Description" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de venta *</label>
                        <input type="number" class="form-control" @bind="_form.SalePrice" min="0" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de costo</label>
                        <input type="number" class="form-control" @bind="_form.PurchasePrice" min="0" step="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">% Ganancia</label>
                        <div class="form-control bg-light fw-semibold text-purple" style="border-radius:10px;">
                            @if (_form.PurchasePrice > 0)
                            {
                                @(Math.Round((_form.SalePrice - _form.PurchasePrice) / _form.PurchasePrice * 100, 1).ToString("0.0") + " %")
                            }
                            else
                            {
                                <span class="text-muted small">No calculable</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock inicial</label>
                        <input type="number" class="form-control" @bind="_form.CurrentStock" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock mínimo</label>
                        <input type="number" class="form-control" @bind="_form.MinimumStock" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Unidad</label>
                        <input class="form-control" @bind="_form.Unit" placeholder="Ej: unidad, kg…" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Categoría *</label>
                        <select class="form-select" @bind="_form.CategoryId">
                            <option value="0">Seleccione...</option>
                            @foreach (var c in _categorias)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Proveedor</label>
                        <select class="form-select" @bind="_form.SupplierId">
                            <option value="">Sin proveedor</option>
                            @foreach (var s in _proveedores)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Imagen del producto</label>
                        <div class="ts-image-upload-area">
                            @if (!string.IsNullOrEmpty(_form.ImagePathActual))
                            {
                                <div class="ts-image-preview-wrap">
                                    <img src="@(_apiBase + _form.ImagePathActual)" alt="Imagen actual" class="ts-image-preview" />
                                    <button type="button" class="btn btn-sm btn-outline-danger ts-image-remove-btn" @onclick="QuitarImagenModal">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else if (_form.ImagenPreviewUrl is not null)
                            {
                                <div class="ts-image-preview-wrap">
                                    <img src="@_form.ImagenPreviewUrl" alt="Nueva imagen" class="ts-image-preview" />
                                    <button type="button" class="btn btn-sm btn-outline-danger ts-image-remove-btn" @onclick="QuitarImagenSeleccionada">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <label class="ts-image-placeholder">
                                    <i class="bi bi-cloud-arrow-up fs-3 d-block mb-1"></i>
                                    <span class="small">Clic para seleccionar imagen</span>
                                    <InputFile OnChange="SeleccionarImagen" accept=".jpg,.jpeg,.png,.webp" class="d-none" />
                                </label>
                            }
                        </div>
                        @if (_form.ImagePathActual is null && _form.ImagenPreviewUrl is null)
                        {
                            <p class="text-muted small mt-1">JPG, PNG o WEBP · Máximo 2 MB</p>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _apiBase = string.Empty;

    private List<ProductoDto> _productos = [];
    private List<ProductoDto> _filtrados = [];
    private List<CategoriaDto> _categorias = [];
    private List<ProveedorDto> _proveedores = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _editando;
    private bool _guardando;
    private int _editandoId;
    private string? _mensaje;
    private bool _exito;
    private ProductoForm _form = new();
    private IBrowserFile? _imagenSeleccionada;

    [Inject] private IConfiguration Config { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _apiBase = Config["ApiBaseUrl"] ?? string.Empty;
        await Task.WhenAll(Cargar(), CargarCatalogos());
    }

    private async Task Cargar()
    {
        _loading = true;
        _productos = await Api.GetProductosAsync() ?? [];
        _filtrados = _productos;
        _loading = false;
    }

    private async Task CargarCatalogos()
    {
        _categorias = await Api.GetCategoriasAsync() ?? [];
        _proveedores = await Api.GetProveedoresAsync() ?? [];
    }

    private void Filtrar(ChangeEventArgs e)
    {
        var q = e.Value?.ToString()?.ToLower() ?? "";
        _filtrados = string.IsNullOrWhiteSpace(q)
            ? _productos
            : _productos.Where(p => p.Name.ToLower().Contains(q) || (p.Sku?.ToLower().Contains(q) ?? false)).ToList();
    }

    private async Task AbrirModal(ProductoDto? p = null)
    {
        _editando = p is not null;
        _editandoId = p?.Id ?? 0;
        _mensaje = null;
        _imagenSeleccionada = null;

        if (p is null)
        {
            _form = new();
        }
        else
        {
            var completo = await Api.GetProductoAsync(p.Id);
            _form = completo is null
                ? new() { Name = p.Name, Sku = p.Sku }
                : new()
                {
                    Name             = completo.Name,
                    Sku              = completo.Sku,
                    Description      = completo.Description,
                    Unit             = completo.Unit,
                    SalePrice        = completo.SalePrice,
                    PurchasePrice    = completo.PurchasePrice,
                    CurrentStock     = completo.CurrentStock,
                    MinimumStock     = completo.MinimumStock,
                    CategoryId       = completo.CategoryId,
                    SupplierId       = completo.SupplierId,
                    ImagePathActual  = completo.ImagePath
                };
        }

        _mostrarModal = true;
    }

    private void CerrarModal()
    {
        _mostrarModal = false;
        _imagenSeleccionada = null;
    }

    private async Task SeleccionarImagen(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        const long maxBytes = 2 * 1024 * 1024; // 2 MB

        // Validar extensión
        var ext = Path.GetExtension(archivo.Name).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
        {
            _mensaje = "Solo se permiten imágenes JPG, PNG o WEBP.";
            _exito = false;
            return;
        }

        // Validar tamaño
        if (archivo.Size > maxBytes)
        {
            _mensaje = "La imagen no puede superar 2 MB.";
            _exito = false;
            return;
        }

        try
        {
            // Leer el stream completo con CopyToAsync para evitar lecturas parciales
            using var ms = new MemoryStream();
            await using var stream = archivo.OpenReadStream(maxBytes);
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            // Generar preview en base64
            var contentType = ext switch
            {
                ".png"  => "image/png",
                ".webp" => "image/webp",
                _       => "image/jpeg"
            };
            var base64 = Convert.ToBase64String(bytes);
            _form.ImagenPreviewUrl = $"data:{contentType};base64,{base64}";
            _imagenSeleccionada = archivo;
            _mensaje = null;
        }
        catch (Exception ex)
        {
            _mensaje = $"Error al cargar la imagen: {ex.Message}";
            _exito = false;
            _imagenSeleccionada = null;
            _form.ImagenPreviewUrl = null;
        }
    }

    private void QuitarImagenSeleccionada()
    {
        _imagenSeleccionada = null;
        _form.ImagenPreviewUrl = null;
    }

    private void QuitarImagenModal()
    {
        _form.ImagePathActual = null;
        _form.ImagenEliminada = true;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || _form.CategoryId == 0) return;
        _guardando = true;
        int idProducto;

        if (_editando)
        {
            var dto = new UpdateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.MinimumStock, true, _form.CategoryId, _form.SupplierId);
            var ok = await Api.UpdateProductoAsync(_editandoId, dto);
            if (!ok) { _guardando = false; _exito = false; _mensaje = "Error al guardar el producto."; return; }
            idProducto = _editandoId;
        }
        else
        {
            var dto = new CreateProductoDto(_form.Sku, _form.Name, _form.Description, _form.Unit, _form.PurchasePrice, _form.SalePrice, _form.CurrentStock, _form.MinimumStock, _form.CategoryId, _form.SupplierId);
            var creado = await Api.CreateProductoAsync(dto);
            if (creado is null) { _guardando = false; _exito = false; _mensaje = "Error al crear el producto."; return; }
            idProducto = creado.Id;
        }

        // Gestión de imagen
        if (_imagenSeleccionada is not null)
        {
            try
            {
                // Abrir un nuevo stream para el upload (el stream del preview ya fue consumido)
                const long maxBytes = 2 * 1024 * 1024;
                using var ms = new MemoryStream();
                await using var stream = _imagenSeleccionada.OpenReadStream(maxBytes);
                await stream.CopyToAsync(ms);
                ms.Position = 0;
                await Api.SubirImagenProductoAsync(idProducto, ms, _imagenSeleccionada.Name);
            }
            catch
            {
                _mensaje = "Producto guardado, pero no se pudo subir la imagen. Intente editarlo nuevamente.";
                _exito = true;
                CerrarModal();
                await Cargar();
                return;
            }
        }
        else if (_form.ImagenEliminada)
        {
            await Api.EliminarImagenProductoAsync(idProducto);
        }

        _guardando = false;
        _exito = true;
        _mensaje = "Producto guardado.";
        CerrarModal();
        await Cargar();
    }

    private async Task Eliminar(int id)
    {
        var ok = await Api.DeleteProductoAsync(id);
        _exito = ok;
        _mensaje = ok ? "Producto eliminado." : "No se pudo eliminar el producto.";
        if (ok) await Cargar();
    }

    private async Task ExportarExcel()
    {
        try
        {
            var bytes = await Api.ExportarProductosExcelAsync();
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "productos.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
        }
        catch { _mensaje = "Error al exportar Excel."; _exito = false; }
    }

    private class ProductoForm
    {
        public string Name { get; set; } = "";
        public string? Sku { get; set; }
        public string? Description { get; set; }
        public string? Unit { get; set; }
        public decimal SalePrice { get; set; }
        public decimal PurchasePrice { get; set; }
        public int CurrentStock { get; set; }
        public int MinimumStock { get; set; } = 5;
        public int CategoryId { get; set; }
        public int? SupplierId { get; set; }
        public string? ImagePathActual { get; set; }
        public string? ImagenPreviewUrl { get; set; }
        public bool ImagenEliminada { get; set; }
    }
}
