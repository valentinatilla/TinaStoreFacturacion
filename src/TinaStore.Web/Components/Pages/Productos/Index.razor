                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CerrarEdicionMasiva">Cancelar</button>
                        <button class="btn bg-purple text-white"
                                @onclick="IrAPaso2"
                                disabled="@(!_bulkFilas.Any(r => r.Modificada && !r.TieneError))">
                            <i class="bi bi-arrow-right me-1"></i>Revisar cambios
                            @if (_bulkFilas.Any(r => r.Modificada && !r.TieneError))
