@page "/productos"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Productos ” Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h4 class="fw-bold mb-0"><i class="bi bi-box-seam me-2 text-purple"></i>Productos</h4>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-success btn-sm" @onclick="ExportarExcel" disabled="@_exportando">
            @if (_exportando) { <span class="spinner-border spinner-border-sm me-1"></span> }
            else { <i class="bi bi-file-earmark-excel me-1"></i> }
            @(_exportando ? "Exportando..." : "Exportar Excel")
        </button>
        <button class="btn btn-outline-purple btn-sm" @onclick="AbrirEdicionMasiva">
            <i class="bi bi-pencil-square me-1"></i>Edición masiva
        </button>
        <button class="btn bg-purple text-white" @onclick="() => AbrirModal()">
            <i class="bi bi-plus-lg me-1"></i>Nuevo producto
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <!-- Tarjetas resumen -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6">
            <div class="card kpi-card p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon" style="background-color:rgba(244,114,182,.12);color:#DB2777;">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-muted small">Referencias disponibles</div>
                        <div class="fw-bold fs-4 text-purple">@_refDisponibles</div>
                        <div class="text-muted" style="font-size:.75rem;">
                            productos activos con stock &gt; 0
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="card kpi-card p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon" style="background-color:rgba(192,132,252,.12);color:#7C3AED;">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-muted small">Costo total del inventario</div>
                        <div class="fw-bold fs-4 text-purple">$@_costoInventario.ToString("N0")</div>
                        <div class="text-muted" style="font-size:.75rem;">
                            suma de costo — stock por producto activo
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="ts-filter-bar">
        <div class="row g-2 align-items-end">
            <div class="col-sm col-md-4">
                <label class="form-label">Buscar</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control form-control-sm" placeholder="Nombre o SKU..."
                           value="@_filtroTexto"
                           @oninput="e => { _filtroTexto = e.Value?.ToString() ?? string.Empty; Filtrar(); }" />
                </div>
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label">Categoría</label>
                <select class="form-select form-select-sm" @onchange="e => { _filtroCategoriaId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; Filtrar(); }">
                    <option value="0">Todas</option>
                    @foreach (var c in _categorias)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label">Proveedor</label>
                <select class="form-select form-select-sm" @onchange="e => { _filtroProveedorId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; Filtrar(); }">
                    <option value="0">Todos</option>
                    @foreach (var s in _proveedores)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label">Estado</label>
                <select class="form-select form-select-sm" @onchange="e => { _filtroEstado = e.Value?.ToString() ?? string.Empty; Filtrar(); }">
                    <option value="">Todos</option>
                    <option value="activo">En stock</option>
                    <option value="bajo">Bajo stock</option>
                    <option value="agotado">Agotado</option>
                    <option value="inactivo">Inactivo</option>
                </select>
            </div>
            <div class="col-auto d-flex align-items-end">
                <button class="btn-limpiar" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
        <div class="ts-filter-stats">
            <span><i class="bi bi-box-seam me-1"></i>@_filtrados.Count producto(s)</span>
            <span><i class="bi bi-check-circle me-1 text-success"></i>En stock: <strong>@_filtrados.Count(p => p.IsActive && p.CurrentStock > 0 && !p.IsLowStock)</strong></span>
            <span><i class="bi bi-exclamation-triangle me-1 text-warning"></i>Bajo: <strong>@_filtrados.Count(p => p.IsLowStock && p.IsActive)</strong></span>
            <span><i class="bi bi-x-circle me-1 text-danger"></i>Agotados: <strong>@_filtrados.Count(p => p.CurrentStock == 0 && p.IsActive)</strong></span>
        </div>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr class="align-middle">
                        <th></th>
                        <th class="ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("sku")'>SKU <i class="@SortIconClass("sku") ms-1 small"></i></th>
                        <th style="cursor:pointer" @onclick='() => OrdenarPor("nombre")'>Producto <i class="@SortIconClass("nombre") ms-1 small"></i></th>
                        <th class="ts-table-hide-mobile">Categoría</th>
                        <th class="ts-table-hide-mobile">Proveedor</th>
                        <th class="text-end ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("costo")'>Costo <i class="@SortIconClass("costo") ms-1 small"></i></th>
                        <th class="text-end" style="cursor:pointer" @onclick='() => OrdenarPor("precio")'>Precio venta <i class="@SortIconClass("precio") ms-1 small"></i></th>
                        <th class="text-end ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("ganancia")'>% Ganancia <i class="@SortIconClass("ganancia") ms-1 small"></i></th>
                        <th class="text-center" style="cursor:pointer" @onclick='() => OrdenarPor("stock")'>Stock <i class="@SortIconClass("stock") ms-1 small"></i></th>
                        <th class="ts-table-hide-mobile">Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                   @foreach (var p in _filtrados)
                   {
                       <tr class="align-middle">
                            <td class="ts-thumb-cell">
                                @if (!string.IsNullOrEmpty(p.ImagePath))
                                {
                                    <img src="@(_apiBase + p.ImagePath)" alt="@p.Name" class="ts-product-thumb" />
                                }
                                else
                                {
                                    <span class="ts-thumb-placeholder"><i class="bi bi-image"></i></span>
                                }
                            </td>
                            <td class="text-muted small ts-table-hide-mobile">@p.Sku</td>
                            <td class="fw-semibold">@p.Name</td>
                            <td class="ts-table-hide-mobile">@p.CategoryName</td>
                            <td class="ts-table-hide-mobile text-muted small">@(p.SupplierName ?? "”")</td>
                            <td class="text-end text-muted ts-table-hide-mobile">@(p.PurchasePrice > 0 ? p.PurchasePrice.ToString("N0") : "”")</td>
                            <td class="text-end">$@p.SalePrice.ToString("N0")</td>
                            <td class="text-end small ts-table-hide-mobile @(p.ProfitMargin > 0 ? "text-success fw-semibold" : "text-muted")">
                                @(p.ProfitMargin > 0 ? p.ProfitMargin.ToString("0.0") + " %" : "”")
                            </td>
                            <td class="text-center">
                                <span class="badge @(!p.IsActive ? "bg-secondary" : p.CurrentStock == 0 ? "badge-sin-stock" : p.IsLowStock ? "badge-bajo-stock" : "bg-success")">@p.CurrentStock</span>
                            </td>
                            <td class="ts-table-hide-mobile">
                                @if (!p.IsActive)
                                {
                                    <span class="badge badge-estado-inactivo">Inactivo</span>
                                }
                                else if (p.CurrentStock == 0)
                                {
                                    <span class="badge badge-sin-stock">Agotado</span>
                                }
                                else if (p.IsLowStock)
                                {
                                    <span class="badge badge-bajo-stock">Bajo stock</span>
                                }
                                else
                                {
                                    <span class="badge badge-estado-activo">En stock</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => AbrirModal(p)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => AbrirModalEliminar(p)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") producto</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-5">
                        <label class="form-label small fw-semibold">Nombre *</label>
                        <input class="form-control" @bind="_form.Name" maxlength="50" @onkeydown="HandleModalKeyDown" />
                        <div class="form-text text-muted">Máximo 50 caracteres.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">SKU</label>
                        <input class="form-control" @bind="_form.Sku" maxlength="30" placeholder="Ej: SKU-001" @onkeydown="HandleModalKeyDown" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descripción</label>
                        <input class="form-control" @bind="_form.Description" maxlength="300" @onkeydown="HandleModalKeyDown" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de venta *</label>
                        <input type="number" class="form-control" @bind="_form.SalePrice" min="0.01" max="999999.99" step="0.01" @onkeydown="HandleModalKeyDown" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Precio de costo</label>
                        <input type="number" class="form-control" @bind="_form.PurchasePrice" min="0" max="999999.99" step="0.01" @onkeydown="HandleModalKeyDown" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">% Ganancia</label>
                        <div class="form-control bg-light fw-semibold text-purple" style="border-radius:10px;">
                            @if (_form.PurchasePrice > 0)
                            {
                                @(Math.Round((_form.SalePrice - _form.PurchasePrice) / _form.PurchasePrice * 100, 1).ToString("0.0") + " %")
                            }
                            else
                            {
                                <span class="text-muted small">No calculable</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock</label>
                        <input type="number" class="form-control" @bind="_form.CurrentStock" min="0" @onkeydown="HandleModalKeyDown" />
                        <div class="form-text text-muted">Unidades disponibles en inventario.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Stock mínimo</label>
                        <input type="number" class="form-control" @bind="_form.MinimumStock" min="0" @onkeydown="HandleModalKeyDown" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Unidad</label>
                        <input class="form-control @(!string.IsNullOrWhiteSpace(_form.Unit) && System.Text.RegularExpressions.Regex.IsMatch(_form.Unit, @"\d") ? "is-invalid" : "")"
                               @bind="_form.Unit" maxlength="30" placeholder="Ej: unidad, kg…" @onkeydown="HandleModalKeyDown" />
                        <div class="invalid-feedback">La unidad de medida no debe contener números.</div>
                        <div class="form-text text-muted">Solo letras, espacios y tildes.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Categoría *</label>
                        <select class="form-select" @bind="_form.CategoryId">
                            <option value="0">Seleccione...</option>
                            @foreach (var c in _categorias)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Proveedor</label>
                        <select class="form-select" @bind="_form.SupplierId">
                            <option value="">Sin proveedor</option>
                            @foreach (var s in _proveedores)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Imagen del producto</label>
                        <div @ref="_dropZoneRef" class="ts-image-upload-area" style="cursor:pointer">
                            @if (!string.IsNullOrEmpty(_form.ImagePathActual))
                            {
                                <div class="ts-image-preview-wrap">
                                    <img src="@(_apiBase + _form.ImagePathActual)" alt="Imagen actual" class="ts-image-preview" />
                                    <button type="button" class="btn btn-sm btn-outline-danger ts-image-remove-btn" @onclick="QuitarImagenModal">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else if (_form.ImagenPreviewUrl is not null)
                            {
                                <div class="ts-image-preview-wrap">
                                    <img src="@_form.ImagenPreviewUrl" alt="Nueva imagen" class="ts-image-preview" />
                                    <button type="button" class="btn btn-sm btn-outline-danger ts-image-remove-btn" @onclick="QuitarImagenSeleccionada">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="ts-image-placeholder">
                                    <i class="bi bi-cloud-arrow-up fs-3 d-block mb-1"></i>
                                    <span class="small">Arrastra una imagen aquí o haz clic para seleccionar</span>
                                </div>
                            }
                        </div>
                        @* Input nativo oculto fuera del div: el JS lo abre al hacer clic en la zona *@
                        <input type="file" id="nativeImgProducto" accept=".jpg,.jpeg,.png,.webp" style="display:none" />
                        @if (_form.ImagePathActual is null && _form.ImagenPreviewUrl is null)
                        {
                            <p class="text-muted small mt-1">JPG, PNG o WEBP · Máximo 2 MB</p>
                        }
                    </div>
                </div>
                @if (_errorModal is not null)
                {
                    <div class="modal-body pt-0">
                        <div class="alert alert-danger py-2 small mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>@_errorModal
                        </div>
                    </div>
                }
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación de eliminación -->
@if (_mostrarModalEliminar && _productoAEliminar is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Eliminar producto</h5>
                    <button class="btn-close" @onclick="CerrarModalEliminar"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">¿Seguro que deseas eliminar a <strong>@_productoAEliminar.Name</strong>? Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModalEliminar">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarEliminar" disabled="@_eliminando" @ref="_btnConfirmarEliminar">
                        @if (_eliminando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ••• Modal edición masiva ••••••••••••••••••••••••••••••••••••••••••••••• -->
@if (_mostrarEdicionMasiva)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
            <div class="modal-content">

                <!-- Encabezado -->
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-pencil-square me-2 text-purple"></i>Edición masiva de productos
                        @if (_bulkPaso == 2)
                        {
                            <span class="badge bg-purple ms-2" style="font-size:.75rem;">Paso 2 ” Confirmar</span>
                        }
                        else
                        {
                            <span class="badge badge-estado-pendiente ms-2" style="font-size:.75rem;">Paso 1 ” Editar</span>
                        }
                    </h5>
                    <button class="btn-close" @onclick="CerrarEdicionMasiva"></button>
                </div>

                @if (_bulkPaso == 1)
                {
                    <!-- ”€”€ PASO 1: tabla editable ”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€”€ -->
                    <div class="modal-body p-0">

                        <!-- Barra de búsqueda -->
                        <div class="px-3 pt-3 pb-2 border-bottom">
                            <div class="row g-2 align-items-center">
                                <div class="col">
                                    <input class="form-control form-control-sm"
                                           placeholder="ðŸ” Filtrar por nombre o SKU..."
                                           @bind="_bulkFiltro" @bind:event="oninput" />
                                </div>
                                <div class="col-auto text-muted small">
                                    @_bulkFilas.Count(r => r.Modificada) modificada(s) de @_bulkFilas.Count
                                </div>
                            </div>
                        </div>

                        <!-- Tabla -->
                        <div style="max-height:55vh; overflow-y:auto; overflow-x:auto;">
                            <table class="table table-sm mb-0 bulk-table ts-bulk-tabla">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Producto</th>
                                        <th class="text-center" style="width:90px;">SKU</th>
                                        <th class="text-end"   style="width:130px;">Costo</th>
                                        <th class="text-end"   style="width:130px;">Precio venta</th>
                                        <th class="text-center" style="width:100px;">Stock</th>
                                        <th class="text-end"   style="width:140px;">Valor inventario</th>
                                        <th class="text-center" style="width:110px;">Imagen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fila in FilasFiltradas)
                                    {
                                        <tr class="@(fila.Modificada ? "bulk-row-modified" : "")">
                                            <td class="align-middle">
                                                @fila.Nombre
                                                @if (fila.Modificada)
                                                {
                                                    <span class="badge bg-purple ms-1" style="font-size:.65rem;">Modificado</span>
                                                }
                                            </td>
                                            <td class="text-center text-muted small align-middle">@fila.Sku</td>
                                            <td class="align-middle">
                                                <input type="number" class="form-control form-control-sm text-end @(fila.ErrorCosto is not null ? "is-invalid" : "")"
                                                       min="0" step="0.01"
                                                       @bind="fila.Costo" @bind:event="oninput"
                                                       @bind:after="() => fila.Recalcular()" />
                                                @if (fila.ErrorCosto is not null)
                                                {
                                                    <div class="invalid-feedback">@fila.ErrorCosto</div>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <input type="number" class="form-control form-control-sm text-end @(fila.ErrorPrecio is not null ? "is-invalid" : "")"
                                                       min="0" step="0.01"
                                                       @bind="fila.PrecioVenta" @bind:event="oninput"
                                                       @bind:after="() => fila.Recalcular()" />
                                                @if (fila.ErrorPrecio is not null)
                                                {
                                                    <div class="invalid-feedback">@fila.ErrorPrecio</div>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <input type="number" class="form-control form-control-sm text-center @(fila.ErrorStock is not null ? "is-invalid" : "")"
                                                       min="0" step="1"
                                                       @bind="fila.Stock" @bind:event="oninput"
                                                       @bind:after="() => fila.Recalcular()" />
                                                @if (fila.ErrorStock is not null)
                                                {
                                                    <div class="invalid-feedback">@fila.ErrorStock</div>
                                                }
                                            </td>
                                            <td class="text-end align-middle text-muted small fw-semibold">
                                                $@fila.ValorInventario.ToString("N0")
                                            </td>
                                            <td class="text-center align-middle">
                                                @if (fila.TieneImagenNueva)
                                                {
                                                    <div class="d-flex flex-column align-items-center gap-1">
                                                        <img src="@fila.ImagenPreviewUrl" alt="preview"
                                                             style="width:40px;height:40px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;" />
                                                        <button type="button" class="btn btn-link btn-sm text-danger p-0"
                                                                style="font-size:.7rem;" @onclick="() => fila.QuitarImagen()">
                                                            <i class="bi bi-x-circle me-1"></i>Quitar
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <label class="btn btn-outline-secondary btn-sm mb-0" style="cursor:pointer;font-size:.72rem;">
                                                        @if (!string.IsNullOrEmpty(fila.ImagePathActual))
                                                        {
                                                            <i class="bi bi-pencil me-1"></i><span>Cambiar</span>
                                                        }
                                                        else
                                                        {
