@page "/"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IConfiguration Config
@inject SessionStateService Session

<PageTitle>Dashboard -- Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-purple"></i>Dashboard</h4>
    <small class="text-muted">@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy"))</small>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-purple"></div>
        <p class="mt-2 text-muted">Cargando indicadores...</p>
    </div>
}
else if (_data is not null)
{
    <!-- KPIs fila 1 -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <a href="/ventas" class="card kpi-card p-3 kpi-card-link text-decoration-none">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon text-purple" style="background-color:rgba(124,58,237,.10)"><i class="bi bi-graph-up"></i></div>
                    <div>
                        <div class="text-muted small">Ventas hoy</div>
                        <div class="fw-bold fs-5">$@_data.VentasHoy.ToString("N0")</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a href="/ventas" class="card kpi-card p-3 kpi-card-link text-decoration-none">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-success bg-opacity-10 text-success"><i class="bi bi-calendar-check"></i></div>
                    <div>
                        <div class="text-muted small">Ventas del mes</div>
                        <div class="fw-bold fs-5">$@_data.VentasMes.ToString("N0")</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a href="/cuentas-por-cobrar" class="card kpi-card p-3 kpi-card-link text-decoration-none">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-cash-stack"></i></div>
                    <div>
                        <div class="text-muted small">Por cobrar</div>
                        <div class="fw-bold fs-5">$@_data.TotalPorCobrar.ToString("N0")</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a href="/productos" class="card kpi-card p-3 kpi-card-link text-decoration-none">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle"></i></div>
                    <div>
                        <div class="text-muted small">Stock bajo</div>
                        <div class="fw-bold fs-5">@_data.ProductosStockBajo productos</div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- KPIs fila 2: producto estrella + tendencia 7 días -->
    <div class="row g-3 mb-4">
        <!-- Producto estrella del mes -->
        <div class="col-md-6 col-xl-4">
            <div class="card kpi-card p-3 h-100">
                <div class="d-flex align-items-start gap-3">
                    <div class="kpi-icon text-warning" style="background-color:rgba(245,158,11,.10); font-size:1.4rem;">
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="text-muted small mb-1">Producto estrella del mes</div>
                        @if (_data.ProductoEstrella is not null)
                        {
                            <div class="fw-bold text-truncate" title="@_data.ProductoEstrella.ProductName">
                                @_data.ProductoEstrella.ProductName
                            </div>
                            @if (!string.IsNullOrEmpty(_data.ProductoEstrella.Sku))
                            {
                                <div class="text-muted small">SKU: @_data.ProductoEstrella.Sku</div>
                            }
                            <div class="d-flex gap-3 mt-1">
                                <span class="small"><i class="bi bi-box-seam me-1 text-purple"></i><strong>@_data.ProductoEstrella.UnidadesVendidas</strong> uds.</span>
                                <span class="small"><i class="bi bi-currency-dollar me-1 text-success"></i><strong>$@_data.ProductoEstrella.TotalIngresos.ToString("N0")</strong></span>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small fst-italic">Sin ventas registradas este mes</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Mini gráfico de tendencia 7 días -->
        <div class="col-md-6 col-xl-8">
            <div class="card kpi-card p-3 h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="text-muted small">Tendencia de ventas</div>
                        <div class="fw-semibold small">Últimos 7 días</div>
                    </div>
                    <span class="badge bg-purple bg-opacity-10 text-purple small">
                        @_data.VentasUltimos7Dias.Sum(v => v.Total).ToString("N0")
                    </span>
                </div>
                @{
                    var maxVenta = _data.VentasUltimos7Dias.Max(v => v.Total);
                    var alturaMax = 48m;
                }
                <div class="d-flex align-items-end gap-1" style="height:56px">
                    @foreach (var dia in _data.VentasUltimos7Dias)
                    {
                        var altura = maxVenta > 0 ? (int)Math.Max(4, dia.Total / maxVenta * alturaMax) : 4;
                        var esHoy = dia.Fecha.Date == DateTime.Today;
                        <div class="flex-fill d-flex flex-column align-items-center gap-1" title="@dia.Fecha.ToString("ddd dd/MM"): $@dia.Total.ToString("N0")">
                            <div style="width:100%; height:@(altura)px; border-radius:3px 3px 0 0;"
                                 class="@(esHoy ? "bg-purple" : "bg-purple bg-opacity-40")"></div>
                            <span class="text-muted" style="font-size:.6rem;">@dia.Fecha.ToString("dd/MM")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Tablas inferiores -->
    <div class="row g-3">
        <!-- Últimas Ventas -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-receipt me-2"></i>Últimas Ventas
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>N°</th><th>Cliente</th><th>Total</th><th>Estado</th><th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in _data.UltimasFacturas)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@f.InvoiceNumber</span></td>
                                            <td>@f.CustomerName</td>
                                            <td class="fw-semibold">$@f.Total.ToString("N0")</td>
                                            <td><span class="badge badge-estado-@f.StatusName.ToLower()">@f.StatusName</span></td>
                                            <td class="text-muted small">@f.InvoiceDate.ToString("dd/MM/yy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Top deudores -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-people me-2"></i>Top Deudores
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var d in _data.TopDeudores)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@d.CustomerName</span>
                             <span class="badge bg-danger rounded-pill">$@d.Saldo.ToString("N0")</span>
                        </li>
                    }
                    @if (!_data.TopDeudores.Any())
                    {
                        <li class="list-group-item text-muted text-center py-3">
                            <i class="bi bi-check-circle text-success me-1"></i>Sin deudores pendientes
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-start gap-3">
        <i class="bi bi-wifi-off fs-4 mt-1 flex-shrink-0"></i>
        <div class="flex-grow-1">
            <div class="fw-bold">No se pudo cargar el Dashboard</div>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="small mt-1">@_error</div>
            }
            <div class="small text-muted mt-1">
                URL de la API: <code>@Config["ApiBaseUrl"]</code>
            </div>
        </div>
        <button class="btn btn-sm btn-outline-warning flex-shrink-0" @onclick="Recargar" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-arrow-clockwise me-1"></i>Reintentar
        </button>
    </div>
}

@code {
    private DashboardDto? _data;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await CargarDashboard();
    }

    private async Task Recargar()
    {
        _data = null;
        _error = null;
        await CargarDashboard();
    }

    private async Task CargarDashboard()
    {
        if (!Session.IsAuthenticated) { _loading = false; StateHasChanged(); return; }
        _loading = true;
        StateHasChanged();
        try
        {
            var (data, error) = await Api.GetDashboardConDiagnosticoAsync();
            _data = data;
            _error = error;
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 401) { }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }
}
