@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Dashboard — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-purple"></i>Dashboard</h4>
    <small class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</small>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-purple"></div>
        <p class="mt-2 text-muted">Cargando indicadores...</p>
    </div>
}
else if (_data is not null)
{
    <!-- KPIs fila 1 -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-purple bg-opacity-10 text-purple"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <div class="text-muted small">Ventas hoy</div>
                        <div class="fw-bold fs-5">@_data.VentasHoy.ToString("C0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-success bg-opacity-10 text-success"><i class="bi bi-calendar-check"></i></div>
                    <div>
                        <div class="text-muted small">Ventas del mes</div>
                        <div class="fw-bold fs-5">@_data.VentasMes.ToString("C0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-cash-stack"></i></div>
                    <div>
                        <div class="text-muted small">Por cobrar</div>
                        <div class="fw-bold fs-5">@_data.TotalPorCobrar.ToString("C0")</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle"></i></div>
                    <div>
                        <div class="text-muted small">Stock bajo</div>
                        <div class="fw-bold fs-5">@_data.ProductosBajoStock productos</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tablas inferiores -->
    <div class="row g-3">
        <!-- Últimas facturas -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-receipt me-2"></i>Últimas Facturas
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>N°</th><th>Cliente</th><th>Total</th><th>Estado</th><th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in _data.UltimasFacturas)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@f.Numero</span></td>
                                    <td>@f.ClienteNombre</td>
                                    <td class="fw-semibold">@f.Total.ToString("C0")</td>
                                    <td><span class="badge badge-estado-@f.Estado.ToLower()">@f.Estado</span></td>
                                    <td class="text-muted small">@f.Fecha.ToString("dd/MM/yy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Top deudores -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-people me-2"></i>Top Deudores
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var d in _data.TopDeudores)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@d.ClienteNombre</span>
                            <span class="badge bg-danger rounded-pill">@d.SaldoPendiente.ToString("C0")</span>
                        </li>
                    }
                    @if (!_data.TopDeudores.Any())
                    {
                        <li class="list-group-item text-muted text-center py-3">
                            <i class="bi bi-check-circle text-success me-1"></i>Sin deudores pendientes
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-wifi-off me-2"></i>No se pudo conectar con la API. Verifique que esté ejecutándose en @("<ApiBaseUrl>").
    </div>
}

@code {
    private DashboardDto? _data;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _data = await Api.GetDashboardAsync(); }
        catch { }
        finally { _loading = false; }
    }
}
