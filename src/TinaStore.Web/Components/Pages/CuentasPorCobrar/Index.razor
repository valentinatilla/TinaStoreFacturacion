@page "/cuentas-por-cobrar"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Cuentas por Cobrar — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2 text-purple"></i>Cuentas por Cobrar</h4>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else if (_data is not null)
{
    @if (_data.Deudores.Any())
    {
        <div class="alert alert-warning py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Total pendiente: <strong>@_data.TotalPorCobrar.ToString("C0")</strong>
            en @_data.TotalClientes clientes
        </div>
    }

    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Cliente</th><th>Documento</th><th>Teléfono</th><th class="text-center">Facturas pend.</th><th class="text-end">Saldo</th><th>Última factura</th></tr>
                </thead>
                <tbody>
                    @foreach (var cxc in _data.Deudores.OrderByDescending(c => c.SaldoPendiente))
                    {
                        <tr>
                            <td class="fw-semibold">@cxc.CustomerName</td>
                            <td class="text-muted">@cxc.DocumentNumber</td>
                            <td class="text-muted small">@cxc.Phone</td>
                            <td class="text-center"><span class="badge bg-warning text-dark">@cxc.FacturasPendientes</span></td>
                            <td class="text-end fw-bold text-danger fs-6">@cxc.SaldoPendiente.ToString("C0")</td>
                            <td class="text-muted small">@cxc.UltimaFacturaFecha?.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                    @if (!_data.Deudores.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <div>¡Sin cuentas pendientes! Todos los clientes están al día.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private ReporteCuentasPorCobrarDto? _data;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _data = await Api.GetReporteCuentasPorCobrarAsync(); }
        finally { _loading = false; }
    }
}
