@page "/cuentas-por-cobrar"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS

<PageTitle>Cuentas por Cobrar — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2 text-purple"></i>Cuentas por Cobrar</h4>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else if (_data is not null)
{
    @if (_data.Deudores.Any())
    {
        <div class="alert alert-warning py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Total pendiente: <strong>@_data.TotalPorCobrar.ToString("C0")</strong>
            en @_data.TotalClientes clientes
        </div>
    }

    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:32px"></th>
                        <th>Cliente</th>
                        <th class="ts-table-hide-mobile">Documento</th>
                        <th class="ts-table-hide-mobile">Teléfono</th>
                        <th class="text-center ts-table-hide-mobile">Ventas pend.</th>
                        <th class="text-end">Saldo</th>
                        <th class="ts-table-hide-mobile">Última venta</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cxc in _data.Deudores.OrderByDescending(c => c.SaldoPendiente))
                    {
                        var expandido = _expandidos.Contains(cxc.CustomerId);
                        <tr class="@(expandido ? "detalle-expandido" : "")" style="cursor:pointer"
                            @onclick="() => ToggleDetalle(cxc.CustomerId)">
                            <td class="text-center align-middle">
                                <i class="bi @(expandido ? "bi-chevron-down" : "bi-chevron-right") text-purple small"></i>
                            </td>
                            <td class="fw-semibold align-middle">@cxc.CustomerName</td>
                            <td class="text-muted align-middle ts-table-hide-mobile">@cxc.DocumentNumber</td>
                            <td class="text-muted small align-middle ts-table-hide-mobile">@cxc.Phone</td>
                            <td class="text-center align-middle ts-table-hide-mobile">
                                <span class="badge bg-warning text-dark">@cxc.FacturasPendientes</span>
                            </td>
                            <td class="text-end fw-bold text-danger fs-6 align-middle">@cxc.SaldoPendiente.ToString("C0")</td>
                            <td class="text-muted small align-middle ts-table-hide-mobile">@cxc.UltimaFacturaFecha?.ToString("dd/MM/yyyy")</td>
                            <td class="text-end align-middle" @onclick:stopPropagation="true">
                                @if (!string.IsNullOrWhiteSpace(cxc.Phone))
                                {
                                    <button class="btn btn-sm btn-outline-success" title="Enviar recordatorio por WhatsApp"
                                            @onclick="() => EnviarWhatsApp(cxc)">
                                        <i class="bi bi-whatsapp"></i>
                                    </button>
                                }
                            </td>
                        </tr>

                        @if (expandido)
                        {
                            <tr class="detalle-expandido">
                                <td colspan="8" class="p-0 border-0">
                                    <div class="detalle-venta-panel px-4 py-3">
                                        @if (_cargandoDetalle.Contains(cxc.CustomerId))
                                        {
                                            <div class="text-center py-2">
                                                <span class="spinner-border spinner-border-sm text-purple me-2"></span>
                                                <span class="text-muted small">Cargando ventas...</span>
                                            </div>
                                        }
                                        else if (_detallesCache.TryGetValue(cxc.CustomerId, out var facturas))
                                        {
                                            @if (facturas.Any())
                                            {
                                                <table class="table table-sm mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>N° Venta</th>
                                                            <th>Fecha</th>
                                                            <th class="text-end">Total</th>
                                                            <th class="text-end">Pagado</th>
                                                            <th class="text-end text-danger">Saldo</th>
                                                            <th class="text-center">Estado</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var f in facturas)
                                                        {
                                                            <tr>
                                                                <td><span class="badge bg-secondary">@f.InvoiceNumber</span></td>
                                                                <td class="text-muted small">@f.InvoiceDate.ToString("dd/MM/yyyy")</td>
                                                                <td class="text-end fw-semibold">@f.Total.ToString("C0")</td>
                                                                <td class="text-end text-success">@f.AmountPaid.ToString("C0")</td>
                                                                <td class="text-end fw-bold text-danger">@f.Balance.ToString("C0")</td>
                                                                <td class="text-center">
                                                                    <span class="badge badge-estado-@f.StatusName.ToLower()">@f.StatusName</span>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                    <tfoot class="table-light">
                                                        <tr>
                                                            <td colspan="4" class="text-end fw-semibold small">Total pendiente:</td>
                                                            <td class="text-end fw-bold text-danger">
                                                                @facturas.Sum(f => f.Balance).ToString("C0")
                                                            </td>
                                                            <td></td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            }
                                            else
                                            {
                                                <p class="text-muted small mb-0 py-1">
                                                    <i class="bi bi-check-circle text-success me-1"></i>Sin ventas pendientes de cobro.
                                                </p>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (!_data.Deudores.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <div>¡Sin cuentas pendientes! Todos los clientes están al día.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private ReporteCuentasPorCobrarDto? _data;
    private bool _loading = true;
    private string? _reminderMessage;

    private readonly HashSet<int> _expandidos = [];
    private readonly HashSet<int> _cargandoDetalle = [];
    private readonly Dictionary<int, List<FacturaDto>> _detallesCache = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t1 = Api.GetReporteCuentasPorCobrarAsync();
            var t2 = Api.GetConfiguracionAsync();
            _data = await t1;
            var cfg = await t2;
            _reminderMessage = cfg?.ReminderMessage;
        }
        finally { _loading = false; }
    }

    private async Task ToggleDetalle(int customerId)
    {
        if (_expandidos.Contains(customerId))
        {
            _expandidos.Remove(customerId);
            return;
        }

        _expandidos.Add(customerId);

        if (_detallesCache.ContainsKey(customerId)) return;

        _cargandoDetalle.Add(customerId);
        StateHasChanged();

        try
        {
            var facturas = await Api.GetVentasPorClienteAsync(customerId);
            // Solo mostramos facturas con saldo pendiente
            _detallesCache[customerId] = (facturas ?? [])
                .Where(f => f.Balance > 0 && f.Status != 3) // 3 = Cancelled
                .OrderByDescending(f => f.InvoiceDate)
                .ToList();
        }
        finally
        {
            _cargandoDetalle.Remove(customerId);
        }
    }

    private async Task EnviarWhatsApp(DeudorCXCDto cxc)
    {
        var telefono = cxc.Phone?.Replace(" ", "").Replace("-", "").Replace("+", "") ?? "";
        var plantilla = _reminderMessage
            ?? "Hola {nombre}, te recordamos que tienes un saldo pendiente de {saldo}. Por favor comunícate con nosotros. Gracias 🌸";
        var mensaje = plantilla
            .Replace("{nombre}", cxc.CustomerName)
            .Replace("{saldo}", cxc.SaldoPendiente.ToString("C0"));
        var url = $"https://wa.me/{telefono}?text={Uri.EscapeDataString(mensaje)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}
