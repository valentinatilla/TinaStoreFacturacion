@page "/cuentas-por-cobrar"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject IJSRuntime JS

<PageTitle>Cuentas por Cobrar — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2 text-purple"></i>Cuentas por Cobrar</h4>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else if (_data is not null)
{
    @if (_data.Deudores.Any())
    {
        <div class="alert alert-warning py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Total pendiente: <strong>@_data.TotalPorCobrar.ToString("C0")</strong>
            en @_data.TotalClientes clientes
        </div>
    }

    <div class="card border-0 shadow-sm mb-3 p-3">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control form-control-sm" placeholder="Buscar cliente..."
                           @oninput="e => { _filtroTexto = e.Value?.ToString() ?? string.Empty; AplicarFiltros(); }" />
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-sm btn-outline-secondary" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>

    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:32px"></th>
                        <th>
                            <span style="cursor:pointer" @onclick='() => OrdenarPor("cliente")'>Cliente <i class="@SortIconClass("cliente") ms-1 small"></i></span>
                        </th>
                        <th class="ts-table-hide-mobile">Documento</th>
                        <th class="ts-table-hide-mobile">Teléfono</th>
                        <th class="text-center ts-table-hide-mobile">
                            <span style="cursor:pointer" @onclick='() => OrdenarPor("facturas")'>Ventas pend. <i class="@SortIconClass("facturas") ms-1 small"></i></span>
                            <div class="d-flex gap-1 mt-1 justify-content-center">
                                <input type="number" class="form-control form-control-sm text-center" style="width:50px;font-size:.7rem" placeholder="≥"
                                       @oninput="e => { _filtroFacturasMin = int.TryParse(e.Value?.ToString(), out var v) ? v : (int?)null; AplicarFiltros(); }" />
                                <input type="number" class="form-control form-control-sm text-center" style="width:50px;font-size:.7rem" placeholder="≤"
                                       @oninput="e => { _filtroFacturasMax = int.TryParse(e.Value?.ToString(), out var v) ? v : (int?)null; AplicarFiltros(); }" />
                            </div>
                        </th>
                        <th class="text-end">
                            <span style="cursor:pointer" @onclick='() => OrdenarPor("saldo")'>Saldo <i class="@SortIconClass("saldo") ms-1 small"></i></span>
                            <div class="d-flex gap-1 mt-1 justify-content-end">
                                <input type="number" class="form-control form-control-sm text-center" style="width:70px;font-size:.7rem" placeholder="≥"
                                       @oninput="e => { _filtroSaldoMin = decimal.TryParse(e.Value?.ToString(), out var v) ? v : (decimal?)null; AplicarFiltros(); }" />
                                <input type="number" class="form-control form-control-sm text-center" style="width:70px;font-size:.7rem" placeholder="≤"
                                       @oninput="e => { _filtroSaldoMax = decimal.TryParse(e.Value?.ToString(), out var v) ? v : (decimal?)null; AplicarFiltros(); }" />
                            </div>
                        </th>
                        <th class="ts-table-hide-mobile">
                            <span style="cursor:pointer" @onclick='() => OrdenarPor("fecha")'>Última venta <i class="@SortIconClass("fecha") ms-1 small"></i></span>
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cxc in _deudoresFiltrados)
                    {
                        var expandido = _expandidos.Contains(cxc.CustomerId);
                        <tr class="@(expandido ? "detalle-expandido" : "")" style="cursor:pointer"
                            @onclick="() => ToggleDetalle(cxc.CustomerId)">
                            <td class="text-center align-middle">
                                <i class="bi @(expandido ? "bi-chevron-down" : "bi-chevron-right") text-purple small"></i>
                            </td>
                            <td class="fw-semibold align-middle">@cxc.CustomerName</td>
                            <td class="text-muted align-middle ts-table-hide-mobile">@cxc.DocumentNumber</td>
                            <td class="text-muted small align-middle ts-table-hide-mobile">@cxc.Phone</td>
                            <td class="text-center align-middle ts-table-hide-mobile">
                                <span class="badge bg-warning text-dark">@cxc.FacturasPendientes</span>
                            </td>
                            <td class="text-end fw-bold text-danger fs-6 align-middle">@cxc.SaldoPendiente.ToString("C0")</td>
                            <td class="text-muted small align-middle ts-table-hide-mobile">@cxc.UltimaFacturaFecha?.ToString("dd/MM/yyyy")</td>
                            <td class="text-end align-middle" @onclick:stopPropagation="true">
                                @if (!string.IsNullOrWhiteSpace(cxc.Phone))
                                {
                                    <button class="btn btn-sm btn-outline-success" title="Enviar recordatorio por WhatsApp"
                                            @onclick="() => EnviarWhatsApp(cxc)">
                                        <i class="bi bi-whatsapp"></i>
                                    </button>
                                }
                            </td>
                        </tr>

                        @if (expandido)
                        {
                            <tr class="detalle-expandido">
                                <td colspan="8" class="p-0 border-0">
                                    <div class="detalle-venta-panel px-4 py-3">
                                        @if (_cargandoDetalle.Contains(cxc.CustomerId))
                                        {
                                            <div class="text-center py-2">
                                                <span class="spinner-border spinner-border-sm text-purple me-2"></span>
                                                <span class="text-muted small">Cargando ventas...</span>
                                            </div>
                                        }
                                        else if (_detallesCache.TryGetValue(cxc.CustomerId, out var facturas))
                                        {
                                            @if (facturas.Any())
                                            {
                                                <table class="table table-sm mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>N° Venta</th>
                                                            <th>Fecha</th>
                                                            <th class="text-end">Total</th>
                                                            <th class="text-end">Pagado</th>
                                                            <th class="text-end text-danger">Saldo</th>
                                                            <th class="text-center">Estado</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var f in facturas)
                                                        {
                                                            <tr>
                                                                <td><span class="badge bg-secondary">@f.InvoiceNumber</span></td>
                                                                <td class="text-muted small">@f.InvoiceDate.ToString("dd/MM/yyyy")</td>
                                                                <td class="text-end fw-semibold">@f.Total.ToString("C0")</td>
                                                                <td class="text-end text-success">@f.AmountPaid.ToString("C0")</td>
                                                                <td class="text-end fw-bold text-danger">@f.Balance.ToString("C0")</td>
                                                                <td class="text-center">
                                                                    <span class="badge badge-estado-@f.StatusName.ToLower()">@f.StatusName</span>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                    <tfoot class="table-light">
                                                        <tr>
                                                            <td colspan="4" class="text-end fw-semibold small">Total pendiente:</td>
                                                            <td class="text-end fw-bold text-danger">
                                                                @facturas.Sum(f => f.Balance).ToString("C0")
                                                            </td>
                                                            <td></td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            }
                                            else
                                            {
                                                <p class="text-muted small mb-0 py-1">
                                                    <i class="bi bi-check-circle text-success me-1"></i>Sin ventas pendientes de cobro.
                                                </p>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (!_data.Deudores.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-4"></i>
                                <div>¡Sin cuentas pendientes! Todos los clientes están al día.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private ReporteCuentasPorCobrarDto? _data;
    private List<DeudorCXCDto>          _deudoresFiltrados = [];
    private bool    _loading = true;
    private string? _reminderMessage;
    private string  _filtroTexto    = string.Empty;
    private decimal? _filtroSaldoMin;
    private decimal? _filtroSaldoMax;
    private int?     _filtroFacturasMin;
    private int?     _filtroFacturasMax;
    private string  _ordenCampo = "saldo";
    private bool    _ordenDesc  = true;

    private readonly HashSet<int>                       _expandidos      = [];
    private readonly HashSet<int>                       _cargandoDetalle = [];
    private readonly Dictionary<int, List<FacturaDto>>  _detallesCache   = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t1 = Api.GetReporteCuentasPorCobrarAsync();
            var t2 = Api.GetConfiguracionAsync();
            _data = await t1;
            var cfg = await t2;
            _reminderMessage = cfg?.ReminderMessage;
            AplicarFiltros();
        }
        finally { _loading = false; }
    }

    private void AplicarFiltros()
    {
        if (_data is null) return;
        var q = _data.Deudores
            .Where(c => string.IsNullOrWhiteSpace(_filtroTexto) ||
                        c.CustomerName.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ||
                        (c.DocumentNumber?.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(c => _filtroSaldoMin    is null || c.SaldoPendiente    >= _filtroSaldoMin.Value)
            .Where(c => _filtroSaldoMax    is null || c.SaldoPendiente    <= _filtroSaldoMax.Value)
            .Where(c => _filtroFacturasMin is null || c.FacturasPendientes >= _filtroFacturasMin.Value)
            .Where(c => _filtroFacturasMax is null || c.FacturasPendientes <= _filtroFacturasMax.Value);

        _deudoresFiltrados = (_ordenCampo switch
        {
            "cliente"  => _ordenDesc ? q.OrderByDescending(c => c.CustomerName).ToList()        : q.OrderBy(c => c.CustomerName).ToList(),
            "facturas" => _ordenDesc ? q.OrderByDescending(c => c.FacturasPendientes).ToList()  : q.OrderBy(c => c.FacturasPendientes).ToList(),
            "fecha"    => _ordenDesc ? q.OrderByDescending(c => c.UltimaFacturaFecha).ToList()  : q.OrderBy(c => c.UltimaFacturaFecha).ToList(),
            _          => _ordenDesc ? q.OrderByDescending(c => c.SaldoPendiente).ToList()      : q.OrderBy(c => c.SaldoPendiente).ToList()
        });
    }

    private void OrdenarPor(string campo)
    {
        if (_ordenCampo == campo) _ordenDesc = !_ordenDesc;
        else { _ordenCampo = campo; _ordenDesc = true; }
        AplicarFiltros();
    }

    private string SortIconClass(string campo) =>
        _ordenCampo != campo ? "bi bi-arrow-down-up text-muted" :
        _ordenDesc            ? "bi bi-sort-down text-purple"   :
                                "bi bi-sort-up text-purple";

    private void LimpiarFiltros()
    {
        _filtroTexto       = string.Empty;
        _filtroSaldoMin    = null;
        _filtroSaldoMax    = null;
        _filtroFacturasMin = null;
        _filtroFacturasMax = null;
        _ordenCampo        = "saldo";
        _ordenDesc         = true;
        AplicarFiltros();
    }

    private async Task ToggleDetalle(int customerId)
    {
        if (_expandidos.Contains(customerId))
        {
            _expandidos.Remove(customerId);
            return;
        }

        _expandidos.Add(customerId);

        if (_detallesCache.ContainsKey(customerId)) return;

        _cargandoDetalle.Add(customerId);
        StateHasChanged();

        try
        {
            var facturas = await Api.GetVentasPorClienteAsync(customerId);
            // Solo mostramos facturas con saldo pendiente
            _detallesCache[customerId] = (facturas ?? [])
                .Where(f => f.Balance > 0 && f.Status != 3) // 3 = Cancelled
                .OrderByDescending(f => f.InvoiceDate)
                .ToList();
        }
        finally
        {
            _cargandoDetalle.Remove(customerId);
        }
    }

    private async Task EnviarWhatsApp(DeudorCXCDto cxc)
    {
        var telefono = cxc.Phone?.Replace(" ", "").Replace("-", "").Replace("+", "") ?? "";
        var plantilla = _reminderMessage
            ?? "Hola {nombre}, te recordamos que tienes un saldo pendiente de {saldo}. Por favor comunícate con nosotros. Gracias 🌸";
        var mensaje = plantilla
            .Replace("{nombre}", cxc.CustomerName)
            .Replace("{saldo}", cxc.SaldoPendiente.ToString("C0"));
        var url = $"https://wa.me/{telefono}?text={Uri.EscapeDataString(mensaje)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}
