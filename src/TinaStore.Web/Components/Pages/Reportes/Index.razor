@page "/reportes"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Reportes — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart-line me-2 text-purple"></i>Reportes</h4>
</div>

<!-- Selector de período -->
<div class="card border-0 shadow-sm p-3 mb-4">
    <div class="d-flex align-items-end gap-3 flex-wrap">
        <div>
            <label class="form-label small fw-semibold mb-1">Desde</label>
            <input type="date" class="form-control" @bind="_desde" />
        </div>
        <div>
            <label class="form-label small fw-semibold mb-1">Hasta</label>
            <input type="date" class="form-control" @bind="_hasta" />
        </div>
        <button class="btn bg-purple text-white px-4" @onclick="Consultar" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-search me-1"></i>Consultar
        </button>
        <div class="ms-auto d-flex gap-2">
            <NavLink href="/api/reports/accounts-receivable" target="_blank" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-download me-1"></i>Exportar C×C
            </NavLink>
        </div>
    </div>
</div>

@if (_ventasData is not null)
{
    <div class="row g-4">
        <!-- Reporte de ventas -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-graph-up me-2"></i>Ventas por día
                    <span class="ms-2 badge bg-purple">Total: @_ventasData.Sum(v => v.TotalVentas).ToString("C0")</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Fecha</th><th class="text-center">Facturas</th><th class="text-end">Ventas</th><th class="text-end">Cobrado</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var v in _ventasData)
                            {
                                <tr>
                                    <td>@v.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">@v.CantidadFacturas</td>
                                    <td class="text-end fw-semibold">@v.TotalVentas.ToString("C0")</td>
                                    <td class="text-end @(v.TotalCobrado < v.TotalVentas ? "text-warning" : "text-success")">
                                        @v.TotalCobrado.ToString("C0")
                                    </td>
                                </tr>
                            }
                            @if (!_ventasData.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Sin ventas en el período</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Reporte de gastos -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-pie-chart me-2"></i>Gastos por categoría
                    @if (_gastosData is not null)
                    {
                        <span class="ms-2 badge bg-danger">Total: @_gastosData.Sum(g => g.TotalGastos).ToString("C0")</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Categoría</th><th class="text-center">N°</th><th class="text-end">Total</th></tr>
                        </thead>
                        <tbody>
                            @if (_gastosData is not null)
                            {
                                @foreach (var g in _gastosData)
                                {
                                    <tr>
                                        <td>@g.Categoria</td>
                                        <td class="text-center">@g.CantidadGastos</td>
                                        <td class="text-end fw-semibold text-danger">@g.TotalGastos.ToString("C0")</td>
                                    </tr>
                                }
                                @if (!_gastosData.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">Sin gastos en el período</td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Cuentas por cobrar -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-cash-stack me-2"></i>Cuentas por Cobrar
                    @if (_cxcData is not null && _cxcData.Any())
                    {
                        <span class="ms-2 badge bg-warning text-dark">Total: @_cxcData.Sum(c => c.SaldoPendiente).ToString("C0")</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Cliente</th><th>Documento</th><th class="text-center">Facturas</th><th class="text-end">Saldo</th><th>Última factura</th></tr>
                        </thead>
                        <tbody>
                            @if (_cxcData is not null)
                            {
                                @foreach (var cxc in _cxcData)
                                {
                                    <tr>
                                        <td class="fw-semibold">@cxc.ClienteNombre</td>
                                        <td class="text-muted">@cxc.DocumentoCliente</td>
                                        <td class="text-center">@cxc.FacturasPendientes</td>
                                        <td class="text-end text-danger fw-semibold">@cxc.SaldoPendiente.ToString("C0")</td>
                                        <td class="text-muted small">@cxc.UltimaFacturaFecha?.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                                @if (!_cxcData.Any())
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3"><i class="bi bi-check-circle text-success me-1"></i>Sin cuentas pendientes</td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime _desde = DateTime.Today.AddDays(-30);
    private DateTime _hasta = DateTime.Today;
    private List<ReporteVentasDto>? _ventasData;
    private List<ReporteGastosDto>? _gastosData;
    private List<ReporteCuentasPorCobrarDto>? _cxcData;
    private bool _loading;

    protected override async Task OnInitializedAsync() => await Consultar();

    private async Task Consultar()
    {
        _loading = true;
        var t1 = Api.GetReporteVentasAsync(_desde, _hasta).ContinueWith(t => _ventasData = t.Result);
        var t2 = Api.GetReporteGastosAsync(_desde, _hasta).ContinueWith(t => _gastosData = t.Result);
        var t3 = Api.GetReporteCuentasPorCobrarAsync().ContinueWith(t => _cxcData = t.Result);
        await Task.WhenAll(t1, t2, t3);
        _loading = false;
    }
}
