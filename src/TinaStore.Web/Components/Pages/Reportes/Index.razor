@page "/reportes"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Reportes ” Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart-line me-2 text-purple"></i>Reportes</h4>
</div>

<!-- Selector de período -->
<div class="card border-0 shadow-sm p-3 mb-4">
    <div class="d-flex align-items-end gap-3 flex-wrap">
        <div>
            <label class="form-label small fw-semibold mb-1">Desde</label>
            <input type="date" class="form-control" @bind="_desde"
                   min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label class="form-label small fw-semibold mb-1">Hasta</label>
            <input type="date" class="form-control" @bind="_hasta"
                   min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>
        <button class="btn bg-purple text-white px-4" @onclick="Consultar" disabled="@_loading">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-search me-1"></i>Consultar
        </button>
    </div>
    @if (!string.IsNullOrEmpty(_errorRango))
    {
        <div class="alert alert-danger py-2 mt-2 small mb-0">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@_errorRango
        </div>
    }
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else if (_ventasData is null && _gastosData is null && _cxcData is null)
{
    <div class="alert alert-info py-2">
        <i class="bi bi-info-circle me-2"></i>Selecciona un período y pulsa <strong>Consultar</strong> para ver los reportes.
    </div>
}
else
{
    <div class="row g-4">
        <!-- Reporte de ventas -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-graph-up me-2"></i>Ventas por día
                    @if (_ventasData is not null)
                    {
                        <span class="ms-2 badge bg-purple">Total: $@_ventasData.TotalVentas.ToString("N0")</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Fecha</th><th class="text-center">Facturas</th><th class="text-end">Ventas</th><th class="text-end">Cobrado</th></tr>
                        </thead>
                        <tbody>
                            @if (_ventasData is null)
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">No se pudieron cargar las ventas</td></tr>
                            }
                            else
                            {
                                @foreach (var v in _ventasData.VentasPorDia)
                                {
                                    <tr>
                                        <td>@v.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@v.CantidadFacturas</td>
                                        <td class="text-end fw-semibold">$@v.TotalVentas.ToString("N0")</td>
                                        <td class="text-end @(v.TotalCobrado < v.TotalVentas ? "text-warning" : "text-success")">
                                            $@v.TotalCobrado.ToString("N0")
                                        </td>
                                    </tr>
                                }
                                @if (!_ventasData.VentasPorDia.Any())
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-3">Sin ventas en el período</td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Reporte de gastos -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-pie-chart me-2"></i>Gastos por categoría
                    @if (_gastosData is not null)
                    {
                        <span class="ms-2 badge bg-danger">Total: $@_gastosData.TotalGastos.ToString("N0")</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Categoría</th><th class="text-center">N°</th><th class="text-end">Total</th></tr>
                        </thead>
                        <tbody>
                            @if (_gastosData is not null)
                            {
                                @foreach (var g in _gastosData.PorCategoria)
                                {
                                    <tr>
                                        <td>@g.CategoryName</td>
                                        <td class="text-center">@g.TotalEgresos</td>
                                        <td class="text-end fw-semibold text-danger">$@g.TotalMonto.ToString("N0")</td>
                                    </tr>
                                }
                                @if (!_gastosData.PorCategoria.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-3">Sin gastos en el período</td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Cuentas por cobrar -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="bi bi-cash-stack me-2"></i>Cuentas por Cobrar
                    @if (_cxcData is not null && _cxcData.Deudores.Any())
                    {
                        <span class="ms-2 badge bg-warning text-dark">Total: $@_cxcData.TotalPorCobrar.ToString("N0")</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Cliente</th><th>Documento</th><th class="text-center">Facturas</th><th class="text-end">Saldo</th><th>Última factura</th></tr>
                        </thead>
                        <tbody>
                            @if (_cxcData is not null)
                            {
                                @foreach (var cxc in _cxcData.Deudores)
                                {
                                    <tr>
                                        <td class="fw-semibold">@cxc.CustomerName</td>
                                        <td class="text-muted">@cxc.DocumentNumber</td>
                                        <td class="text-center">@cxc.FacturasPendientes</td>
                                        <td class="text-end text-danger fw-semibold">$@cxc.SaldoPendiente.ToString("N0")</td>
                                        <td class="text-muted small">@cxc.UltimaFacturaFecha?.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                                @if (!_cxcData.Deudores.Any())
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3"><i class="bi bi-check-circle text-success me-1"></i>Sin cuentas pendientes</td></tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime _desde = DateTime.Today.AddDays(-30);
    private DateTime _hasta = DateTime.Today;
    private ReporteVentasDto? _ventasData;
    private ReporteGastosDto? _gastosData;
    private ReporteCuentasPorCobrarDto? _cxcData;
    private bool _loading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Consultar();
    }

    private string? _errorRango;

    private async Task Consultar()
    {
        _errorRango = null;
        if (_desde > _hasta)
        {
            _errorRango = "La fecha inicial no puede ser mayor que la fecha final.";
            return;
        }
        if (_desde < new DateTime(2020, 1, 1))
        {
            _desde = new DateTime(2020, 1, 1);
        }
        if (_hasta > DateTime.Today)
        {
            _hasta = DateTime.Today;
        }

        _loading = true;
        StateHasChanged();
        var t1 = Api.GetReporteVentasAsync(_desde, _hasta);
        var t2 = Api.GetReporteGastosAsync(_desde, _hasta);
        var t3 = Api.GetReporteCuentasPorCobrarAsync(_desde, _hasta);
        await Task.WhenAll(t1, t2, t3);
        _ventasData = t1.Result;
        _gastosData = t2.Result;
        _cxcData    = t3.Result;
        _loading = false;
        StateHasChanged();
    }
}
