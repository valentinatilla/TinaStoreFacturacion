@page "/egresos"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Egresos â€” Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-arrow-down-circle me-2 text-purple"></i>Egresos y Gastos</h4>
    <button class="btn bg-purple text-white" @onclick="AbrirModal">
        <i class="bi bi-plus-lg me-1"></i>Registrar egreso
    </button>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <!-- Filtros -->
    <div class="ts-filter-bar">
        <div class="row g-2 align-items-end">
            <div class="col-sm-6 col-md-3">
                <label class="form-label">Desde</label>
                <input type="date" class="form-control form-control-sm"
                       min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       value="@_filtroDesdeStr"
                       @onchange="e => { _filtroDesdeStr = e.Value?.ToString(); Filtrar(); }" />
            </div>
            <div class="col-sm-6 col-md-3">
                <label class="form-label">Hasta</label>
                <input type="date" class="form-control form-control-sm"
                       min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       value="@_filtroHastaStr"
                       @onchange="e => { _filtroHastaStr = e.Value?.ToString(); Filtrar(); }" />
            </div>
            <div class="col-sm-6 col-md-3">
                <label class="form-label">CategorÃ­a <span class="fw-normal">(otros egresos)</span></label>
                <select class="form-select form-select-sm"
                        @onchange="e => { _filtroCategoriaId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; Filtrar(); }">
                    <option value="0">Todas</option>
                    @foreach (var c in _categoriasGasto.Where(c => !c.Name.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase)))
                    {
                        <option value="@c.Id" selected="@(_filtroCategoriaId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-md-3 d-flex align-items-end">
                <button class="btn-limpiar w-100" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
        <div class="ts-filter-stats">
            <span><i class="bi bi-box-seam me-1"></i>Compras: <strong>@TotalCompras</strong></span>
            <span><i class="bi bi-receipt me-1"></i>Otros: <strong>@TotalOtros</strong></span>
            <span style="color: var(--ts-purple); font-weight:700;">Total: @TotalGeneral</span>
        </div>
    </div>

    <!-- Tabla 1: Compras de productos -->
    <h6 class="fw-bold mb-2 mt-3"><i class="bi bi-box-seam me-2 text-purple"></i>Compras de productos</h6>
    <div class="card ts-table border-0 mb-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Fecha</th><th>DescripciÃ³n</th><th>Proveedor</th><th class="text-end">Monto</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var e in _filtradosCompras)
                    {
                        var anulado = e.Status != 0;
                        <tr class="@(anulado ? "text-muted" : "")"
                            style="@(anulado ? "opacity:.55" : "")">
                            <td class="text-muted small">@e.ExpenseDate.ToString("dd/MM/yyyy")</td>
                            <td>@if (anulado){<s>@e.Description</s>}else{@e.Description}</td>
                            <td class="text-muted small">@(e.SupplierName ?? "â€”")</td>
                            <td class="text-end fw-semibold">
                                @if (anulado){<s>$@e.Amount.ToString("N0")</s>}else{<span>$@e.Amount.ToString("N0")</span>}
                            </td>
                            <td class="text-end">
                                @if (e.Status == 0)
                                {
                                    <button class="btn btn-sm btn-outline-danger" title="Anular"
                                            @onclick="() => PedirConfirmacionAnular(e)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Anulado</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!_filtradosCompras.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-3">Sin compras de productos en el perÃ­odo</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tabla 2: Otros egresos -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-purple"></i>Otros egresos</h6>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Fecha</th><th>DescripciÃ³n</th><th>CategorÃ­a</th><th class="ts-table-hide-mobile">MÃ©todo de pago</th><th class="text-end">Monto</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var e in _filtradosOtros)
                    {
                        var anulado = e.Status != 0;
                        <tr class="@(anulado ? "text-muted" : "")"
                            style="@(anulado ? "opacity:.55" : "")">
                            <td class="text-muted small">@e.ExpenseDate.ToString("dd/MM/yyyy")</td>
                            <td>@if (anulado){<s>@e.Description</s>}else{@e.Description}</td>
                            <td><span class="badge @(anulado ? "bg-danger" : "bg-secondary")">@e.ExpenseCategoryName</span></td>
                            <td class="text-muted small ts-table-hide-mobile">
                                @(string.IsNullOrWhiteSpace(e.PaymentMethodName) ? "â€”" : e.PaymentMethodName)
                            </td>
                            <td class="text-end fw-semibold">
                                @if (anulado){<s>$@e.Amount.ToString("N0")</s>}else{<span>$@e.Amount.ToString("N0")</span>}
                            </td>
                            <td class="text-end">
                                @if (e.Status == 0)
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="Editar"
                                            @onclick="() => AbrirEditar(e)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Anular"
                                            @onclick="() => PedirConfirmacionAnular(e)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Anulado</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!_filtradosOtros.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-3">Sin egresos registrados</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editandoId > 0 ? "Editar" : "Registrar") Egreso</h5>
                    <button class="btn-close" @onclick="() => _mostrarModal = false"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">DescripciÃ³n *</label>
                        <input class="form-control" @bind="_form.Descripcion" @onkeydown="HandleModalKeyDown" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Monto *</label>
                        <input type="number" class="form-control" @bind="_form.Monto" min="0" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Fecha</label>
                        <input type="date" class="form-control" @bind="_form.Fecha"
                               min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">CategorÃ­a</label>
                        <select class="form-select" @bind="_form.CategoriaGastoId">
                            <option value="0">Seleccione...</option>
                            @foreach (var c in _categoriasGasto.Where(c => !c.Name.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase)))
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">MÃ©todo de pago</label>
                        <select class="form-select" @bind="_form.MetodoPagoId">
                            <option value="0">Seleccione...</option>
                            @foreach (var mp in _metodosPago)
                            {
                                <option value="@mp.Id">@mp.Name</option>
                            }
                        </select>
                    </div>
                    @if (_errorModal is not null)
                    {
                        <div class="col-12">
                            <div class="alert alert-danger py-2 small mb-0">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>@_errorModal
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModal = false">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_mostrarModalAnular)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Anular egreso
                    </h5>
                    <button class="btn-close" @onclick="() => _mostrarModalAnular = false"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-1">Â¿Confirmas que deseas anular el egreso <strong>@_egresoAAnular?.Description</strong>?</p>
                    <p class="text-muted small mb-0">Esta acciÃ³n no se puede deshacer y el egreso quedarÃ¡ excluido de los totales.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModalAnular = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarAnulacionEgreso" @ref="_btnConfirmarAnular">
                        <i class="bi bi-x-circle me-1"></i>Anular
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const string CategoriaCompras = "Compras a proveedor";

    private List<EgresoDto> _egresos = [];
    private List<EgresoDto> _filtradosCompras = [];
    private List<EgresoDto> _filtradosOtros = [];
    private List<CategoriaGastoDto> _categoriasGasto = [];
    private List<MetodoPagoDto> _metodosPago = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _guardando;
    private string? _mensaje;
    private bool _exito;
    private string? _errorModal;
    private EgresoForm _form = new();

    // â”€â”€ ConfirmaciÃ³n de anulaciÃ³n â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private bool _mostrarModalAnular;
    private EgresoDto? _egresoAAnular;
    private int _editandoId;

    // â”€â”€ Filtros â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private string? _filtroDesdeStr;
    private string? _filtroHastaStr = DateTime.Today.ToString("yyyy-MM-dd");
    private int _filtroCategoriaId;

    private string TotalCompras =>
        $"${_filtradosCompras.Where(e => e.Status == 0).Sum(e => e.Amount):N0}";
    private string TotalOtros =>
        $"${_filtradosOtros.Where(e => e.Status == 0).Sum(e => e.Amount):N0}";
    private string TotalGeneral =>
        $"${(_filtradosCompras.Where(e => e.Status == 0).Sum(e => e.Amount)
           + _filtradosOtros.Where(e => e.Status == 0).Sum(e => e.Amount)):N0}";

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var t1 = Api.GetEgresosAsync();
        var t2 = Api.GetCategoriasGastoAsync();
        var t3 = Api.GetMetodosPagoAsync();
        await Task.WhenAll(t1, t2, t3);
        _egresos         = t1.Result ?? [];
        _categoriasGasto = t2.Result ?? [];
        _metodosPago     = t3.Result ?? [];
        Filtrar();
        _loading = false;
    }

    private void Filtrar()
    {
        var desde = DateTime.TryParse(_filtroDesdeStr, out var d) ? d : (DateTime?)null;
        var hasta = DateTime.TryParse(_filtroHastaStr, out var h) ? h : (DateTime?)null;

        var base_ = _egresos
            .Where(e => desde is null || e.ExpenseDate.Date >= desde.Value.Date)
            .Where(e => hasta is null || e.ExpenseDate.Date <= hasta.Value.Date)
            .OrderByDescending(e => e.ExpenseDate);

        _filtradosCompras = base_
            .Where(e => e.ExpenseCategoryName.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase))
            .ToList();

        _filtradosOtros = base_
            .Where(e => !e.ExpenseCategoryName.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase))
            .Where(e => _filtroCategoriaId == 0 || e.ExpenseCategoryId == _filtroCategoriaId)
            .ToList();
    }

    private void LimpiarFiltros()
    {
        _filtroDesdeStr    = null;
        _filtroHastaStr    = DateTime.Today.ToString("yyyy-MM-dd");
        _filtroCategoriaId = 0;
        Filtrar();
    }

    private async Task RecargarYFiltrar()
    {
        _egresos = await Api.GetEgresosAsync() ?? [];
        Filtrar();
    }

    private void AbrirModal() { _editandoId = 0; _form = new() { Fecha = DateTime.Today }; _errorModal = null; _mostrarModal = true; _mensaje = null; }

    private async Task HandleModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_guardando) await Guardar();
    }

    private void AbrirEditar(EgresoDto e)
    {
        _editandoId = e.Id;
        _form = new()
        {
            Descripcion      = e.Description,
            Monto            = e.Amount,
            Fecha            = e.ExpenseDate,
            CategoriaGastoId = e.ExpenseCategoryId,
            MetodoPagoId     = e.PaymentMethodId ?? 0,
            Notas            = e.Notes
        };
        _mostrarModal = true;
        _errorModal = null;
        _mensaje = null;
    }

    private async Task AnularEgreso(int id)
    {
        var ok = await Api.AnularEgresoAsync(id);
        _exito   = ok;
        _mensaje = ok ? "Egreso anulado." : "No se pudo anular el egreso.";
        if (ok) await RecargarYFiltrar();
    }

    private void PedirConfirmacionAnular(EgresoDto egreso)
    {
        _egresoAAnular     = egreso;
        _mostrarModalAnular = true;
        _focusBtnAnular    = true;
    }

    private async Task ConfirmarAnulacionEgreso()
    {
        _mostrarModalAnular = false;
        if (_egresoAAnular is null) return;
        await AnularEgreso(_egresoAAnular.Id);
        _egresoAAnular = null;
    }

    private async Task Guardar()
    {
        _errorModal = null;
        if (string.IsNullOrWhiteSpace(_form.Descripcion))
        {
            _errorModal = "La descripciÃ³n es obligatoria.";
            return;
        }
        if (_form.Monto <= 0)
        {
            _errorModal = "El monto debe ser mayor a cero.";
            return;
        }
        _guardando = true;
        bool ok;
        if (_editandoId > 0)
        {
            var dto = new UpdateEgresoDto(_form.Fecha, _form.Descripcion, _form.Monto, _form.Notas, _form.CategoriaGastoId, null, _form.MetodoPagoId == 0 ? null : _form.MetodoPagoId);
            ok = await Api.UpdateEgresoAsync(_editandoId, dto);
        }
        else
        {
            var dto = new CreateEgresoDto(_form.Fecha, _form.Descripcion, _form.Monto, _form.Notas, _form.CategoriaGastoId, null, _form.MetodoPagoId == 0 ? null : _form.MetodoPagoId);
            ok = await Api.CreateEgresoAsync(dto);
        }
        _guardando = false;
        if (ok)
        {
            _exito   = ok;
            _mensaje = _editandoId > 0 ? "Egreso actualizado." : "Egreso registrado.";
            _mostrarModal = false;
            await RecargarYFiltrar();
        }
        else
        {
            _errorModal = "Error al guardar el egreso. Verifica los datos e intenta de nuevo.";
        }
    }

    private class EgresoForm
    {
        public string Descripcion { get; set; } = "";
        public decimal Monto { get; set; }
        public DateTime Fecha { get; set; } = DateTime.Today;
        public int CategoriaGastoId { get; set; }
        public int MetodoPagoId { get; set; }
        public string? Notas { get; set; }
    }

    private ElementReference _btnConfirmarAnular;
    private bool _focusBtnAnular;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusBtnAnular) { _focusBtnAnular = false; await _btnConfirmarAnular.FocusAsync(); }
    }
}
