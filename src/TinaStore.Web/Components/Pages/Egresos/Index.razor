@page "/egresos"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Egresos — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-arrow-down-circle me-2 text-purple"></i>Egresos y Gastos</h4>
    <button class="btn bg-purple text-white" @onclick="AbrirModal">
        <i class="bi bi-plus-lg me-1"></i>Registrar egreso
    </button>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-3 p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Desde</label>
                <input type="date" class="form-control form-control-sm"
                       value="@_filtroDesdeStr"
                       @onchange="e => { _filtroDesdeStr = e.Value?.ToString(); Filtrar(); }" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Hasta</label>
                <input type="date" class="form-control form-control-sm"
                       value="@_filtroHastaStr"
                       @onchange="e => { _filtroHastaStr = e.Value?.ToString(); Filtrar(); }" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Categoría <span class="text-muted fw-normal">(otros egresos)</span></label>
                <select class="form-select form-select-sm"
                        @onchange="e => { _filtroCategoriaId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; Filtrar(); }">
                    <option value="0">Todas</option>
                    @foreach (var c in _categoriasGasto.Where(c => !c.Name.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase)))
                    {
                        <option value="@c.Id" selected="@(_filtroCategoriaId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
        <div class="mt-2 pt-2 border-top d-flex gap-4">
            <span class="small text-muted">
                <i class="bi bi-box-seam me-1"></i>Compras: <strong>@TotalCompras</strong>
            </span>
            <span class="small text-muted">
                <i class="bi bi-receipt me-1"></i>Otros: <strong>@TotalOtros</strong>
            </span>
            <span class="small fw-bold" style="color: var(--ts-primary);">
                Total: @TotalGeneral
            </span>
        </div>
    </div>

    <!-- Tabla 1: Compras de productos -->
    <h6 class="fw-bold mb-2 mt-3"><i class="bi bi-box-seam me-2 text-purple"></i>Compras de productos</h6>
    <div class="card ts-table border-0 mb-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Fecha</th><th>Descripción</th><th>Proveedor</th><th class="text-end">Monto</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var e in _filtradosCompras)
                    {
                        <tr>
                            <td class="text-muted small">@e.ExpenseDate.ToString("dd/MM/yyyy")</td>
                            <td>@e.Description</td>
                            <td class="text-muted small">@(e.SupplierName ?? "—")</td>
                            <td class="text-end fw-semibold">@e.Amount.ToString("C0")</td>
                            <td class="text-end">
                                @if (e.Status == 0)
                                {
                                    <button class="btn btn-sm btn-outline-danger" title="Anular"
                                            @onclick="() => AnularEgreso(e.Id)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Anulado</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!_filtradosCompras.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-3">Sin compras de productos en el período</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tabla 2: Otros egresos -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-purple"></i>Otros egresos</h6>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Fecha</th><th>Descripción</th><th>Categoría</th><th class="text-end">Monto</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var e in _filtradosOtros)
                    {
                        <tr>
                            <td class="text-muted small">@e.ExpenseDate.ToString("dd/MM/yyyy")</td>
                            <td>@e.Description</td>
                            <td><span class="badge bg-secondary">@e.ExpenseCategoryName</span></td>
                            <td class="text-end fw-semibold">@e.Amount.ToString("C0")</td>
                            <td class="text-end">
                                @if (e.Status == 0)
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="Editar"
                                            @onclick="() => AbrirEditar(e)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Anular"
                                            @onclick="() => AnularEgreso(e.Id)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Anulado</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!_filtradosOtros.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-3">Sin egresos registrados</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editandoId > 0 ? "Editar" : "Registrar") Egreso</h5>
                    <button class="btn-close" @onclick="() => _mostrarModal = false"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descripción *</label>
                        <input class="form-control" @bind="_form.Descripcion" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Monto *</label>
                        <input type="number" class="form-control" @bind="_form.Monto" min="0" step="0.01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Fecha</label>
                        <input type="date" class="form-control" @bind="_form.Fecha" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Categoría</label>
                        <select class="form-select" @bind="_form.CategoriaGastoId">
                            <option value="0">Seleccione...</option>
                            @foreach (var c in _categoriasGasto.Where(c => !c.Name.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase)))
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Método de pago</label>
                        <select class="form-select" @bind="_form.MetodoPagoId">
                            <option value="0">Seleccione...</option>
                            @foreach (var mp in _metodosPago)
                            {
                                <option value="@mp.Id">@mp.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Notas</label>
                        <input class="form-control" @bind="_form.Notas" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModal = false">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const string CategoriaCompras = "Compras a proveedor";

    private List<EgresoDto> _egresos = [];
    private List<EgresoDto> _filtradosCompras = [];
    private List<EgresoDto> _filtradosOtros = [];
    private List<CategoriaGastoDto> _categoriasGasto = [];
    private List<MetodoPagoDto> _metodosPago = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _guardando;
    private string? _mensaje;
    private bool _exito;
    private EgresoForm _form = new();
    private int _editandoId;

    // ── Filtros ───────────────────────────────────────────────────────────────
    private string? _filtroDesdeStr;
    private string? _filtroHastaStr = DateTime.Today.ToString("yyyy-MM-dd");
    private int _filtroCategoriaId;

    private string TotalCompras =>
        _filtradosCompras.Where(e => e.Status == 0).Sum(e => e.Amount).ToString("C0");
    private string TotalOtros =>
        _filtradosOtros.Where(e => e.Status == 0).Sum(e => e.Amount).ToString("C0");
    private string TotalGeneral =>
        (_filtradosCompras.Where(e => e.Status == 0).Sum(e => e.Amount)
       + _filtradosOtros.Where(e => e.Status == 0).Sum(e => e.Amount)).ToString("C0");

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var t1 = Api.GetEgresosAsync();
        var t2 = Api.GetCategoriasGastoAsync();
        var t3 = Api.GetMetodosPagoAsync();
        await Task.WhenAll(t1, t2, t3);
        _egresos         = t1.Result ?? [];
        _categoriasGasto = t2.Result ?? [];
        _metodosPago     = t3.Result ?? [];
        Filtrar();
        _loading = false;
    }

    private void Filtrar()
    {
        var desde = DateTime.TryParse(_filtroDesdeStr, out var d) ? d : (DateTime?)null;
        var hasta = DateTime.TryParse(_filtroHastaStr, out var h) ? h : (DateTime?)null;

        var base_ = _egresos
            .Where(e => desde is null || e.ExpenseDate.Date >= desde.Value.Date)
            .Where(e => hasta is null || e.ExpenseDate.Date <= hasta.Value.Date)
            .OrderByDescending(e => e.ExpenseDate);

        _filtradosCompras = base_
            .Where(e => e.ExpenseCategoryName.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase))
            .ToList();

        _filtradosOtros = base_
            .Where(e => !e.ExpenseCategoryName.Equals(CategoriaCompras, StringComparison.OrdinalIgnoreCase))
            .Where(e => _filtroCategoriaId == 0 || e.ExpenseCategoryId == _filtroCategoriaId)
            .ToList();
    }

    private void LimpiarFiltros()
    {
        _filtroDesdeStr    = null;
        _filtroHastaStr    = DateTime.Today.ToString("yyyy-MM-dd");
        _filtroCategoriaId = 0;
        Filtrar();
    }

    private async Task RecargarYFiltrar()
    {
        _egresos = await Api.GetEgresosAsync() ?? [];
        Filtrar();
    }

    private void AbrirModal() { _editandoId = 0; _form = new() { Fecha = DateTime.Today }; _mostrarModal = true; _mensaje = null; }

    private void AbrirEditar(EgresoDto e)
    {
        _editandoId = e.Id;
        _form = new()
        {
            Descripcion      = e.Description,
            Monto            = e.Amount,
            Fecha            = e.ExpenseDate,
            CategoriaGastoId = e.ExpenseCategoryId,
            MetodoPagoId     = e.PaymentMethodId ?? 0,
            Notas            = e.Notes
        };
        _mostrarModal = true;
        _mensaje = null;
    }

    private async Task AnularEgreso(int id)
    {
        var ok = await Api.AnularEgresoAsync(id);
        _exito   = ok;
        _mensaje = ok ? "Egreso anulado." : "No se pudo anular el egreso.";
        if (ok) await RecargarYFiltrar();
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_form.Descripcion) || _form.Monto <= 0) return;
        _guardando = true;
        bool ok;
        if (_editandoId > 0)
        {
            var dto = new UpdateEgresoDto(_form.Fecha, _form.Descripcion, _form.Monto, _form.Notas, _form.CategoriaGastoId, null, _form.MetodoPagoId == 0 ? null : _form.MetodoPagoId);
            ok = await Api.UpdateEgresoAsync(_editandoId, dto);
        }
        else
        {
            var dto = new CreateEgresoDto(_form.Fecha, _form.Descripcion, _form.Monto, _form.Notas, _form.CategoriaGastoId, null, _form.MetodoPagoId == 0 ? null : _form.MetodoPagoId);
            ok = await Api.CreateEgresoAsync(dto);
        }
        _guardando = false;
        _exito   = ok;
        _mensaje = ok ? (_editandoId > 0 ? "Egreso actualizado." : "Egreso registrado.") : "Error al guardar el egreso.";
        if (ok)
        {
            _mostrarModal = false;
            await RecargarYFiltrar();
        }
    }

    private class EgresoForm
    {
        public string Descripcion { get; set; } = "";
        public decimal Monto { get; set; }
        public DateTime Fecha { get; set; } = DateTime.Today;
        public int CategoriaGastoId { get; set; }
        public int MetodoPagoId { get; set; }
        public string? Notas { get; set; }
    }
}
