@page "/clientes"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Clientes — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-purple"></i>Clientes</h4>
    <button class="btn bg-purple text-white" @onclick="() => AbrirModal()">
        <i class="bi bi-plus-lg me-1"></i>Nuevo cliente
    </button>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">
        <i class="bi bi-@(_exito ? "check-circle" : "exclamation-triangle") me-1"></i>@_mensaje
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <div class="card border-0 shadow-sm mb-3 p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Buscar cliente</label>
                <input class="form-control form-control-sm" placeholder="Nombre, documento o teléfono..."
                       @oninput="e => { _filtroTexto = e.Value?.ToString() ?? string.Empty; Filtrar(); }" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Compra desde</label>
                <input type="date" class="form-control form-control-sm"
                       @onchange="e => { _filtroDesde = e.Value is string s && !string.IsNullOrEmpty(s) ? DateOnly.Parse(s) : (DateOnly?)null; Filtrar(); }" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Compra hasta</label>
                <input type="date" class="form-control form-control-sm"
                       @onchange="e => { _filtroHasta = e.Value is string s && !string.IsNullOrEmpty(s) ? DateOnly.Parse(s) : (DateOnly?)null; Filtrar(); }" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th><th>Documento</th><th>Teléfono</th><th>Email</th>
                        <th>Estado</th><th>Últ. compra</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _filtrados)
                    {
                        <tr>
                            <td class="fw-semibold">@c.FullName</td>
                            <td>@c.DocumentNumber</td>
                            <td>@c.Phone</td>
                            <td>@c.Email</td>
                            <td>
                                @if (!c.IsActive)
                                {
                                    <span class="badge badge-estado-inactivo">Inactivo</span>
                                }
                                else
                                {
                                    <span class="badge @(c.CommercialStatus == "Activo" ? "badge-estado-activo" : c.CommercialStatus == "Sin compras" ? "badge-estado-inactivo" : "badge-bajo-stock")">
                                        @(c.CommercialStatus == "Sin compras" ? "Sin compras" : c.CommercialStatus)
                                    </span>
                                }
                            </td>
                            <td class="text-muted small">
                                @(c.LastPurchaseDate.HasValue
                                    ? c.LastPurchaseDate.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                    : "—")
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(c)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(c)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!_filtrados.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Sin resultados</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal nuevo / editar -->
@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") cliente</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Nombre completo *</label>
                        <input class="form-control" @bind="_form.FullName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Tipo doc.</label>
                        <select class="form-select" @bind="_form.DocumentType">
                            <option value="">— Selecciona —</option>
                            <option value="CC">CC — Cédula de ciudadanía</option>
                            <option value="NIT">NIT — Número de identificación tributaria</option>
                            <option value="CE">CE — Cédula de extranjería</option>
                            <option value="PP">PP — Pasaporte</option>
                            <option value="TI">TI — Tarjeta de identidad</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Documento</label>
                        <input class="form-control" @bind="_form.DocumentNumber" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Teléfono</label>
                        <input class="form-control" @bind="_form.Phone" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Email</label>
                        <input class="form-control" @bind="_form.Email" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Dirección</label>
                        <input class="form-control" @bind="_form.Address" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Notas</label>
                        <input class="form-control" @bind="_form.Notes" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación de eliminación -->
@if (_mostrarModalEliminar)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Eliminar cliente</h5>
                    <button class="btn-close" @onclick="() => _mostrarModalEliminar = false"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">¿Seguro que deseas eliminar a <strong>@_nombreAEliminar</strong>? Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModalEliminar = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="EjecutarEliminar">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ClienteDto> _clientes = [];
    private List<ClienteDto> _filtrados = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _editando;
    private bool _guardando;
    private int _editandoId;
    private string? _mensaje;
    private bool _exito;
    private ClienteForm _form = new();
    // Confirmación de eliminación
    private bool _mostrarModalEliminar;
    private int _idAEliminar;
    private string _nombreAEliminar = "";

    // ── Filtros ────────────────────────────────────────────────────────────────────
    private string  _filtroTexto  = string.Empty;
    private DateOnly? _filtroDesde;
    private DateOnly? _filtroHasta;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        _loading = true;
        _clientes = await Api.GetClientesAsync() ?? [];
        _filtrados = _clientes;
        _loading = false;
    }

    private void Filtrar()
    {
        _filtrados = _clientes
            .Where(c => string.IsNullOrWhiteSpace(_filtroTexto) ||
                        c.FullName.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ||
                        (c.DocumentNumber?.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (c.Phone?.Contains(_filtroTexto) ?? false))
            .Where(c =>
            {
                if (_filtroDesde is null && _filtroHasta is null) return true;
                if (!c.LastPurchaseDate.HasValue) return false;
                var fecha = DateOnly.FromDateTime(c.LastPurchaseDate.Value.ToLocalTime());
                if (_filtroDesde.HasValue && fecha < _filtroDesde.Value) return false;
                if (_filtroHasta.HasValue && fecha > _filtroHasta.Value) return false;
                return true;
            })
            .ToList();
    }

    private void LimpiarFiltros()
    {
        _filtroTexto = string.Empty;
        _filtroDesde = null;
        _filtroHasta = null;
        _filtrados   = _clientes;
    }

    private void AbrirModal(ClienteDto? c = null)
    {
        _editando = c is not null;
        _editandoId = c?.Id ?? 0;
        _form = c is null
            ? new()
            : new() { FullName = c.FullName, DocumentType = c.DocumentType, DocumentNumber = c.DocumentNumber, Phone = c.Phone, Email = c.Email, Address = c.Address, Notes = c.Notes };
        _mostrarModal = true;
        _mensaje = null;
    }

    private void CerrarModal() => _mostrarModal = false;

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_form.FullName)) return;
        _guardando = true;
        bool ok;
        if (_editando)
        {
            var dto = new UpdateClienteDto(_form.FullName, _form.DocumentType, _form.DocumentNumber, _form.Phone, _form.Email, _form.Address, _form.Notes, true);
            ok = await Api.UpdateClienteAsync(_editandoId, dto);
        }
        else
        {
            var dto = new CreateClienteDto(_form.FullName, _form.DocumentType, _form.DocumentNumber, _form.Phone, _form.Email, _form.Address, _form.Notes);
            ok = await Api.CreateClienteAsync(dto);
        }
        _guardando = false;
        _exito = ok;
        _mensaje = ok ? "Cliente guardado correctamente." : "Error al guardar el cliente.";
        if (ok) { CerrarModal(); await Cargar(); }
    }

    private void ConfirmarEliminar(ClienteDto c)
    {
        _idAEliminar = c.Id;
        _nombreAEliminar = c.FullName;
        _mostrarModalEliminar = true;
    }

    private async Task EjecutarEliminar()
    {
        _mostrarModalEliminar = false;
        var ok = await Api.DeleteClienteAsync(_idAEliminar);
        _exito = ok;
        _mensaje = ok ? "Cliente eliminado." : "No se pudo eliminar el cliente.";
        if (ok) await Cargar();
    }

    private class ClienteForm
    {
        public string FullName { get; set; } = "";
        public string? DocumentType { get; set; }
        public string? DocumentNumber { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? Address { get; set; }
        public string? Notes { get; set; }
    }
}
