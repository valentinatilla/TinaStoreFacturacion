@page "/clientes"
@attribute [Authorize]
@inject TinaStoreApiClient Api

<PageTitle>Clientes — Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-purple"></i>Clientes</h4>
    <button class="btn bg-purple text-white" @onclick="() => AbrirModal()">
        <i class="bi bi-plus-lg me-1"></i>Nuevo cliente
    </button>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">
        <i class="bi bi-@(_exito ? "check-circle" : "exclamation-triangle") me-1"></i>@_mensaje
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <div class="card border-0 shadow-sm mb-3 p-3">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control form-control-sm" placeholder="Nombre, documento o teléfono..."
                           @oninput="e => { _filtroTexto = e.Value?.ToString() ?? string.Empty; Filtrar(); }" />
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-sm btn-outline-secondary" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>
    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => OrdenarPor("nombre")'>
                            Nombre <i class="@SortIconClass("nombre") ms-1 small"></i>
                        </th>
                        <th class="ts-table-hide-mobile">Documento</th>
                        <th class="ts-table-hide-mobile">Teléfono</th>
                        <th class="ts-table-hide-mobile">Email</th>
                        <th>Estado</th>
                        <th class="ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("saldo")'>
                            Saldo <i class="@SortIconClass("saldo") ms-1 small"></i>
                        </th>
                        <th class="ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("compra")'>
                            Últ. compra <i class="@SortIconClass("compra") ms-1 small"></i>
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _filtrados)
                    {
                        <tr>
                            <td class="fw-semibold">@c.FullName</td>
                            <td class="ts-table-hide-mobile">@c.DocumentNumber</td>
                            <td class="ts-table-hide-mobile">@c.Phone</td>
                            <td class="ts-table-hide-mobile">@c.Email</td>
                            <td>
                                @if (!c.IsActive)
                                {
                                    <span class="badge badge-estado-inactivo">Inactivo</span>
                                }
                                else
                                {
                                    <span class="badge @(c.CommercialStatus == "Activo" ? "badge-estado-activo" : c.CommercialStatus == "Sin compras" ? "badge-estado-inactivo" : "badge-bajo-stock")">
                                        @(c.CommercialStatus == "Sin compras" ? "Sin compras" : c.CommercialStatus)
                                    </span>
                                }
                            </td>
                            <td class="text-end fw-semibold ts-table-hide-mobile @(c.PendingBalance > 0 ? "text-danger" : "text-muted")">
                                @(c.PendingBalance > 0 ? c.PendingBalance.ToString("C0") : "—")
                            </td>
                            <td class="text-muted small ts-table-hide-mobile">
                                @(c.LastPurchaseDate.HasValue
                                    ? c.LastPurchaseDate.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                    : "—")
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(c)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(c)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!_filtrados.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Sin resultados</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal nuevo / editar -->
@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") cliente</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (_erroresModal.Any())
                    {
                        <div class="alert alert-danger py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                            <strong>Revisa los campos marcados antes de guardar:</strong>
                            <ul class="mb-0 mt-1 ps-3">
                                @foreach (var err in _erroresModal)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Nombre completo *</label>
                            <input class="form-control @(_errNombre is not null ? "is-invalid" : "")" @bind="_form.FullName" />
                            @if (_errNombre is not null)
                            {
                                <div class="invalid-feedback">@_errNombre</div>
                            }
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold">Tipo doc.</label>
                            <select class="form-select" @bind="_form.DocumentType">
                                <option value="">— Selecciona —</option>
                                <option value="CC">CC — Cédula de ciudadanía</option>
                                <option value="NIT">NIT — Número de identificación tributaria</option>
                                <option value="CE">CE — Cédula de extranjería</option>
                                <option value="PP">PP — Pasaporte</option>
                                <option value="TI">TI — Tarjeta de identidad</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold">Documento</label>
                            <input class="form-control" @bind="_form.DocumentNumber" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold">Teléfono</label>
                            <input class="form-control @(_errTelefono is not null ? "is-invalid" : "")" @bind="_form.Phone" placeholder="Ej: 3001234567" />
                            @if (_errTelefono is not null)
                            {
                                <div class="invalid-feedback">@_errTelefono</div>
                            }
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold">Email</label>
                            <input class="form-control @(_errEmail is not null ? "is-invalid" : "")" @bind="_form.Email" placeholder="Ej: cliente@correo.com" />
                            @if (_errEmail is not null)
                            {
                                <div class="invalid-feedback">@_errEmail</div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Dirección</label>
                            <input class="form-control" @bind="_form.Address" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Notas</label>
                            <input class="form-control" @bind="_form.Notes" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn bg-purple text-white" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación de eliminación -->
@if (_mostrarModalEliminar)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Eliminar cliente</h5>
                    <button class="btn-close" @onclick="() => _mostrarModalEliminar = false"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">¿Seguro que deseas eliminar a <strong>@_nombreAEliminar</strong>? Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _mostrarModalEliminar = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="EjecutarEliminar">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ClienteDto> _clientes = [];
    private List<ClienteDto> _filtrados = [];
    private bool _loading = true;
    private bool _mostrarModal;
    private bool _editando;
    private bool _guardando;
    private int _editandoId;
    private string? _mensaje;
    private bool _exito;
    private ClienteForm _form = new();
    // Confirmación de eliminación
    private bool _mostrarModalEliminar;
    private int _idAEliminar;
    private string _nombreAEliminar = "";

    // ── Errores de validación del modal ────────────────────────────────────────────
    private string? _errNombre;
    private string? _errEmail;
    private string? _errTelefono;
    private List<string> _erroresModal = [];

    // ── Filtros ────────────────────────────────────────────────────────────────────
    private string _filtroTexto = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        _loading = true;
        _clientes = await Api.GetClientesAsync() ?? [];
        _filtrados = _clientes;
        _loading = false;
    }

    private void Filtrar()
    {
        _filtrados = _clientes
            .Where(c => string.IsNullOrWhiteSpace(_filtroTexto) ||
                        c.FullName.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ||
                        (c.DocumentNumber?.Contains(_filtroTexto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (c.Phone?.Contains(_filtroTexto) ?? false))
            .ToList();
    }

    private void LimpiarFiltros()
    {
        _filtroTexto = string.Empty;
        _filtrados   = _clientes;
    }

    // ── Ordenamiento por columna ───────────────────────────────────────────────────
    private string  _ordenCampo = string.Empty;
    private bool    _ordenDesc;

    private void OrdenarPor(string campo)
    {
        if (_ordenCampo == campo)
            _ordenDesc = !_ordenDesc;
        else
        {
            _ordenCampo = campo;
            _ordenDesc  = true;
        }
        _filtrados = _ordenCampo switch
        {
            "nombre" => _ordenDesc ? _filtrados.OrderByDescending(c => c.FullName).ToList()         : _filtrados.OrderBy(c => c.FullName).ToList(),
            "saldo"  => _ordenDesc ? _filtrados.OrderByDescending(c => c.PendingBalance).ToList()   : _filtrados.OrderBy(c => c.PendingBalance).ToList(),
            "compra" => _ordenDesc ? _filtrados.OrderByDescending(c => c.LastPurchaseDate).ToList() : _filtrados.OrderBy(c => c.LastPurchaseDate).ToList(),
            _        => _filtrados.ToList()
        };
    }

    private string SortIconClass(string campo) =>
        _ordenCampo != campo ? "bi bi-arrow-down-up text-muted" :
        _ordenDesc            ? "bi bi-sort-down text-purple"   :
                                "bi bi-sort-up text-purple";

    private void AbrirModal(ClienteDto? c = null)
    {
        _editando = c is not null;
        _editandoId = c?.Id ?? 0;
        _form = c is null
            ? new()
            : new() { FullName = c.FullName, DocumentType = c.DocumentType, DocumentNumber = c.DocumentNumber, Phone = c.Phone, Email = c.Email, Address = c.Address, Notes = c.Notes };
        LimpiarErroresModal();
        _mostrarModal = true;
        _mensaje = null;
    }

    private void CerrarModal()
    {
        _mostrarModal = false;
        LimpiarErroresModal();
    }

    private void LimpiarErroresModal()
    {
        _errNombre   = null;
        _errEmail    = null;
        _errTelefono = null;
        _erroresModal = [];
    }

    private async Task Guardar()
    {
        LimpiarErroresModal();

        if (string.IsNullOrWhiteSpace(_form.FullName))
            _errNombre = "El nombre completo es obligatorio.";

        if (!EsEmailValido(_form.Email))
            _errEmail = "Ingresa un correo válido, por ejemplo: cliente@correo.com.";

        if (!EsTelefonoValido(_form.Phone))
            _errTelefono = "Ingresa un número de teléfono válido. Para Colombia debe tener 10 dígitos.";

        if (_errNombre   is not null) _erroresModal.Add(_errNombre);
        if (_errEmail    is not null) _erroresModal.Add(_errEmail);
        if (_errTelefono is not null) _erroresModal.Add(_errTelefono);

        if (_erroresModal.Any()) return;

        _guardando = true;
        bool ok;
        if (_editando)
        {
            var dto = new UpdateClienteDto(_form.FullName, _form.DocumentType, _form.DocumentNumber, _form.Phone, _form.Email, _form.Address, _form.Notes, true);
            ok = await Api.UpdateClienteAsync(_editandoId, dto);
        }
        else
        {
            var dto = new CreateClienteDto(_form.FullName, _form.DocumentType, _form.DocumentNumber, _form.Phone, _form.Email, _form.Address, _form.Notes);
            ok = await Api.CreateClienteAsync(dto);
        }
        _guardando = false;

        if (ok)
        {
            _exito = true;
            _mensaje = "Cliente guardado correctamente.";
            CerrarModal();
            await Cargar();
        }
        else
        {
            _erroresModal.Add("Error al guardar el cliente. Verifica los datos e intenta de nuevo.");
        }
    }

    private void ConfirmarEliminar(ClienteDto c)
    {
        _idAEliminar = c.Id;
        _nombreAEliminar = c.FullName;
        _mostrarModalEliminar = true;
    }

    private async Task EjecutarEliminar()
    {
        _mostrarModalEliminar = false;
        var ok = await Api.DeleteClienteAsync(_idAEliminar);
        _exito = ok;
        _mensaje = ok ? "Cliente eliminado." : "No se pudo eliminar el cliente.";
        if (ok) await Cargar();
    }

    private static bool EsEmailValido(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return true;
        return System.Text.RegularExpressions.Regex.IsMatch(
            email.Trim(),
            @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
    }

    private static bool EsTelefonoValido(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return true;
        return System.Text.RegularExpressions.Regex.IsMatch(
            phone.Trim(),
            @"^\+?[\d\s\-]{7,20}$");
    }

    private class ClienteForm
    {
        public string FullName { get; set; } = "";
        public string? DocumentType { get; set; }
        public string? DocumentNumber { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? Address { get; set; }
        public string? Notes { get; set; }
    }
}
