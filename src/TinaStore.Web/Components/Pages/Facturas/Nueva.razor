@page "/facturas/nueva"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject TinaStoreApiClient Api
@inject NavigationManager Nav

<PageTitle>Nueva Factura — Tina Store</PageTitle>

<div class="d-flex align-items-center mb-4 gap-3">
    <NavLink href="/facturas" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </NavLink>
    <h4 class="fw-bold mb-0"><i class="bi bi-receipt-cutoff me-2 text-purple"></i>Nueva Factura</h4>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger py-2">@_error</div>
}

<div class="row g-4">
    <!-- Columna izquierda: cliente y pago -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-3 mb-3">
            <h6 class="fw-bold mb-3">Cliente</h6>
            <select class="form-select mb-2" @bind="_clienteId">
                <option value="0">Seleccione un cliente...</option>
                @foreach (var c in _clientes)
                {
                    <option value="@c.Id">@c.FullName</option>
                }
            </select>
        </div>

        <div class="card border-0 shadow-sm p-3">
            <h6 class="fw-bold mb-3">Pago</h6>
            <div class="mb-2">
                <label class="form-label small fw-semibold">Método de pago</label>
                <select class="form-select" @bind="_metodoPagoId">
                    <option value="0">Seleccione...</option>
                    @foreach (var mp in _metodosPago)
                    {
                        <option value="@mp.Id">@mp.Name</option>
                    }
                </select>
            </div>
            <div class="mb-2">
                <label class="form-label small fw-semibold">Pago inicial (opcional)</label>
                <input type="number" class="form-control" @bind="_pagoInicial" min="0" step="0.01" />
            </div>
            <div>
                <label class="form-label small fw-semibold">Notas</label>
                <textarea class="form-control" rows="2" @bind="_notas"></textarea>
            </div>
        </div>
    </div>

    <!-- Columna derecha: productos -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Detalle de productos</h6>
                <div class="d-flex gap-2" style="max-width:400px; flex:1; margin-left:1rem;">
                    <input class="form-control form-control-sm" placeholder="🔍 Buscar producto..."
                           @bind="_busquedaProducto" @oninput="FiltrarProductos" />
                </div>
            </div>

            @if (_productosFiltrados.Any() && !string.IsNullOrEmpty(_busquedaProducto))
            {
                <div class="list-group mb-3" style="max-height:180px; overflow-y:auto;">
                    @foreach (var p in _productosFiltrados.Take(8))
                    {
                        <button class="list-group-item list-group-item-action d-flex justify-content-between py-2"
                                @onclick="() => AgregarProducto(p)">
                            <span>@p.Name <small class="text-muted">(@p.SKU)</small></span>
                            <span class="text-purple fw-semibold">@p.SalePrice.ToString("C0") — Stock: @p.Stock</span>
                        </button>
                    }
                </div>
            }

            @if (_detalles.Any())
            {
                <table class="table table-sm mb-3">
                    <thead class="table-light">
                        <tr><th>Producto</th><th class="text-center">Cant.</th><th class="text-end">P. Unit.</th><th class="text-end">Subtotal</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _detalles)
                        {
                            <tr>
                                <td>@d.NombreProducto</td>
                                <td class="text-center">
                                    <input type="number" class="form-control form-control-sm text-center" style="width:70px"
                                           min="1" @bind="d.Cantidad" @bind:after="() => RecalcularTotales()" />
                                </td>
                                <td class="text-end">@d.PrecioUnitario.ToString("C0")</td>
                                <td class="text-end fw-semibold">@((d.Cantidad * d.PrecioUnitario).ToString("C0"))</td>
                                <td>
                                    <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => QuitarProducto(d)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total:</td>
                            <td class="text-end fw-bold fs-5 text-purple">@_total.ToString("C0")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            }
            else
            {
                <p class="text-muted text-center py-3">
                    <i class="bi bi-box-seam me-2"></i>Busca y agrega productos a la factura
                </p>
            }

            <div class="d-flex justify-content-end">
                <button class="btn bg-purple text-white px-4" @onclick="CrearFactura"
                        disabled="@(!_detalles.Any() || _clienteId == 0 || _metodoPagoId == 0 || _creando)">
                    @if (_creando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-check-lg me-1"></i>Emitir Factura
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ClienteDto> _clientes = [];
    private List<MetodoPagoDto> _metodosPago = [];
    private List<ProductoDto> _productos = [];
    private List<ProductoDto> _productosFiltrados = [];
    private List<DetalleLinea> _detalles = [];

    private int _clienteId;
    private int _metodoPagoId;
    private decimal? _pagoInicial;
    private string? _notas;
    private string _busquedaProducto = "";
    private decimal _total;
    private bool _creando;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var tasks = Task.WhenAll(
            Api.GetClientesAsync().ContinueWith(t => _clientes = t.Result ?? []),
            Api.GetMetodosPagoAsync().ContinueWith(t => _metodosPago = t.Result ?? []),
            Api.GetProductosAsync().ContinueWith(t => _productos = t.Result ?? []));
        await tasks;
    }

    private void FiltrarProductos(ChangeEventArgs e)
    {
        _busquedaProducto = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(_busquedaProducto)) { _productosFiltrados = []; return; }
        var q = _busquedaProducto.ToLower();
        _productosFiltrados = _productos
            .Where(p => p.IsActive && (p.Name.ToLower().Contains(q) || (p.SKU?.ToLower().Contains(q) ?? false)))
            .ToList();
    }

    private void AgregarProducto(ProductoDto p)
    {
        var existente = _detalles.FirstOrDefault(d => d.ProductoId == p.Id);
        if (existente is not null) { existente.Cantidad++; }
        else _detalles.Add(new DetalleLinea { ProductoId = p.Id, NombreProducto = p.Name, PrecioUnitario = p.SalePrice, Cantidad = 1 });
        _busquedaProducto = "";
        _productosFiltrados = [];
        RecalcularTotales();
    }

    private void QuitarProducto(DetalleLinea d) { _detalles.Remove(d); RecalcularTotales(); }

    private void RecalcularTotales() => _total = _detalles.Sum(d => d.Cantidad * d.PrecioUnitario);

    private async Task CrearFactura()
    {
        _creando = true;
        _error = null;
        try
        {
            var dto = new CreateFacturaDto(
                _clienteId, _metodoPagoId,
                _detalles.Select(d => new CreateDetalleFacturaDto(d.ProductoId, d.Cantidad, d.PrecioUnitario)).ToList(),
                _pagoInicial, _notas);

            var ok = await Api.CreateFacturaAsync(dto);
            if (ok) Nav.NavigateTo("/facturas");
            else _error = "Error al crear la factura. Verifique stock y campos requeridos.";
        }
        catch { _error = "Error al comunicarse con la API."; }
        finally { _creando = false; }
    }

    private class DetalleLinea
    {
        public int ProductoId { get; set; }
        public string NombreProducto { get; set; } = "";
        public decimal PrecioUnitario { get; set; }
        public int Cantidad { get; set; }
    }
}
