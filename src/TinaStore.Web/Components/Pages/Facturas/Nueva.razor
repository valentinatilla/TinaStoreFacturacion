@page "/ventas/nueva"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject NavigationManager Nav

<PageTitle>Nueva Venta " Tina Store</PageTitle>

<div class="d-flex align-items-center mb-4 gap-3">
    <NavLink href="/ventas" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </NavLink>
    <h4 class="fw-bold mb-0"><i class="bi bi-receipt-cutoff me-2 text-purple"></i>Nueva Venta</h4>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger py-2">@_error</div>
}

<div class="row g-4" style="overflow-x:hidden;">
    <!-- Columna izquierda: cliente y pago -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-3 mb-3">
            <h6 class="fw-bold mb-3">Cliente</h6>
            <select class="form-select mb-2" @bind="_clienteId">
                <option value="0">Seleccione un cliente...</option>
                @foreach (var c in _clientes)
                {
                    <option value="@c.Id">@c.FullName</option>
                }
            </select>
        </div>

        <div class="card border-0 shadow-sm p-3">
            <h6 class="fw-bold mb-3">Pago</h6>
            <div class="mb-2">
                <label class="form-label small fw-semibold">Método de pago</label>
                <select class="form-select" @bind="_metodoPagoId">
                    <option value="0">Seleccione...</option>
                    @foreach (var mp in _metodosPago)
                    {
                        <option value="@mp.Id">@mp.Name</option>
                    }
                </select>
            </div>
            <div class="mb-2">
                <label class="form-label small fw-semibold">Pago inicial (opcional)</label>
                <input type="number" class="form-control" @bind="_pagoInicial" min="0" step="0.01" @onkeydown="HandleVentaKeyDown" />
            </div>
            <div>
                <label class="form-label small fw-semibold">Notas</label>
                <textarea class="form-control" rows="2" @bind="_notas"></textarea>
            </div>
        </div>
    </div>

    <!-- Columna derecha: productos -->
    <div class="col-lg-8" style="min-width:0;">
        <div class="card border-0 shadow-sm p-3">
            <div class="mb-3">
                <h6 class="fw-bold mb-2">Detalle de productos</h6>
                <!-- Chips de categoría -->
                <div class="d-flex flex-wrap gap-1 mb-2">
                    <button type="button"
                            class="btn btn-sm @(_filtroCategoriaId == 0 ? "bg-purple text-white" : "btn-outline-secondary")"
                            style="border-radius:20px; font-size:.78rem;"
                            @onclick="() => SeleccionarCategoria(0)">
                        <i class="bi bi-grid-fill me-1"></i>Todas
                    </button>
                    @foreach (var c in _categorias)
                    {
                        <button type="button"
                                class="btn btn-sm @(_filtroCategoriaId == c.Id ? "bg-purple text-white" : "btn-outline-secondary")"
                                style="border-radius:20px; font-size:.78rem;"
                                @onclick="() => SeleccionarCategoria(c.Id)">
                            @c.Name
                        </button>
                    }
                </div>
                <!-- Búsqueda -->
                <input class="form-control form-control-sm" placeholder="🔍 Buscar producto..."
                       @bind="_busquedaProducto" @oninput="FiltrarProductos" />
            </div>

            @if (_productosFiltrados.Any() && (!string.IsNullOrEmpty(_busquedaProducto) || _filtroCategoriaId > 0))
            {
                <div class="list-group mb-3" style="max-height:260px; overflow-y:auto;">
                    @foreach (var p in string.IsNullOrWhiteSpace(_busquedaProducto)
                        ? _productosFiltrados
                        : _productosFiltrados.Take(10))
                    {
                        <button class="list-group-item list-group-item-action d-flex flex-wrap justify-content-between align-items-center py-2 gap-1"
                                style="min-width:0;"
                                @onclick="() => AgregarProducto(p)">
                            <span class="d-flex align-items-center gap-2" style="min-width:0; flex:1;">
                                @if (!string.IsNullOrEmpty(p.ImagePath))
                                                {
                                                    <img src="/proxy/img/productos/@(Path.GetFileName(p.ImagePath))" alt="@p.Name"
                                                         style="width:32px;height:32px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;flex-shrink:0;" />
                                                }
                                                else
                                                {
                                                    <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;background:#f1f5f9;color:#94a3b8;font-size:.75rem;flex-shrink:0;"><i class="bi bi-image"></i></span>
                                                }
                                <span style="min-width:0; overflow:hidden; text-overflow:ellipsis;">
                                    @p.Name <small class="text-muted">(@p.Sku)</small>
                                    @if (p.IsLowStock)
                                    {
                                        <span class="badge bg-warning text-dark ms-1 small">Stock bajo</span>
                                    }
                                </span>
                            </span>
                            <span class="d-flex align-items-center gap-2 flex-shrink-0">
                                <span class="text-purple fw-semibold">$@p.SalePrice.ToString("N0")</span>
                                <span class="text-muted small">Stock: @p.CurrentStock</span>
                                @if (p.CurrentStock == 0)
                                {
                                    <button class="btn btn-xs btn-outline-warning py-0 px-1"
                                            title="Añadir stock"
                                            @onclick:stopPropagation="true"
                                            @onclick="() => AbrirModalStock(p)">
                                        <i class="bi bi-plus-circle"></i>
                                    </button>
                                }
                            </span>
                        </button>
                    }
                </div>
            }

            @if (_advertenciaStock is not null)
            {
                <div class="alert alert-warning py-1 small mb-2">
                    <i class="bi bi-exclamation-triangle me-1"></i>@_advertenciaStock
                </div>
            }

            @if (_detalles.Any())
            {
                <!-- Vista desktop: tabla -->
                <div class="d-none d-md-block table-responsive">
                <table class="table table-sm mb-3">
                        <thead class="table-light">
                            <tr><th style="width:44px"></th><th>Producto</th><th class="text-center" style="width:80px">Cant.</th><th class="text-end" style="width:90px">P. Unit.</th><th class="text-end" style="width:100px">Dto. (%)</th><th class="text-end" style="width:90px">Subtotal</th><th style="width:32px"></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var d in _detalles)
                            {
                                <tr>
                                    <td class="align-middle text-center">
                                        @if (!string.IsNullOrEmpty(d.ImagePath))
                                        {
                                            <img src="/proxy/img/productos/@(Path.GetFileName(d.ImagePath))" alt="@d.NombreProducto"
                                                 style="width:32px;height:32px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;" />
                                        }
                                        else
                                        {
                                            <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;background:#f1f5f9;color:#94a3b8;font-size:.75rem;"><i class="bi bi-image"></i></span>
                                        }
                                    </td>
                                    <td class="align-middle">@d.NombreProducto</td>
                                <td class="text-center">
                                    <input type="number"
                                           class="form-control form-control-sm text-center @(d.Cantidad > d.StockDisponible ? "is-invalid" : "")"
                                           style="width:70px"
                                           min="1" max="@d.StockDisponible"
                                           @bind="d.Cantidad" @bind:after="() => RecalcularTotales()" />
                                    @if (d.Cantidad > d.StockDisponible)
                                    {
                                        <div class="text-danger" style="font-size:0.7rem;">Máx. @d.StockDisponible</div>
                                    }
                                </td>
                                <td class="text-end">$@d.PrecioUnitario.ToString("N0")</td>
                                <td class="text-end">
                                    <input type="number" class="form-control form-control-sm text-end w-100"
                                           min="0" max="100" step="0.01"
                                           placeholder="0"
                                           @bind="d.DescuentoPct" @bind:after="() => RecalcularTotales()" />
                                    @if (d.DescuentoMonto > 0)
                                    {
                                        <div class="text-muted" style="font-size:.7rem;">-$@d.DescuentoMonto.ToString("N0")</div>
                                    }
                                </td>
                                <td class="text-end fw-semibold">$@d.Subtotal.ToString("N0")</td>
                                <td>
                                    <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => QuitarProducto(d)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="5" class="text-end text-muted small">Subtotal:</td>
                            <td class="text-end text-muted small">$@_subtotal.ToString("N0")</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td colspan="5" class="text-end text-muted small">Descuento (%):</td>
                            <td class="text-end text-muted small">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    <input type="number" class="form-control form-control-sm text-end @(_advertenciaDescuento is not null ? "is-invalid" : "")"
                                           style="width:80px;display:inline-block"
                                           min="0" max="100" step="0.01"
                                           @bind="_descuentoPct" @bind:after="RecalcularTotales" />
                                    @if (_descuento > 0)
                                    {
                                        <span class="text-muted small text-nowrap">-$@_descuento.ToString("N0")</span>
                                    }
                                </div>
                                @if (_advertenciaDescuento is not null)
                                {
                                    <div class="invalid-feedback d-block small">@_advertenciaDescuento</div>
                                }
                            </td>
                            <td></td>
                        </tr>
                        <tr>
                            <td colspan="5" class="text-end text-muted small">Impuesto (%):</td>
                            <td class="text-end text-muted small">
                                <input type="number" class="form-control form-control-sm text-end"
                                       style="width:80px;display:inline-block"
                                       min="0" max="100" step="0.01"
                                       @bind="_impuestoPct" @bind:after="RecalcularTotales" />
                            </td>
                            <td></td>
                        </tr>
                        <tr class="fw-bold border-top">
                            <td colspan="5" class="text-end fw-bold">Total:</td>
                            <td class="text-end fw-bold fs-5 text-purple">$@_total.ToString("N0")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
                </div>

                <!-- Vista móvil: cards de productos -->
                <div class="d-md-none">
                    @foreach (var d in _detalles)
                    {
                        <div class="ts-mobile-cart-card">
                            <div class="ts-cart-remove">
                                <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => QuitarProducto(d)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            <div class="ts-cart-top">
                                @if (!string.IsNullOrEmpty(d.ImagePath))
                                {
                                    <img src="/proxy/img/productos/@(Path.GetFileName(d.ImagePath))" alt="@d.NombreProducto"
                                         class="ts-cart-img" />
                                }
                                else
                                {
                                    <span class="ts-cart-img-placeholder"><i class="bi bi-image"></i></span>
                                }
                                <span class="ts-cart-name">@d.NombreProducto</span>
                            </div>
                            <div class="ts-cart-fields">
                                <div>
                                    <div class="ts-field-label">Cantidad</div>
                                    <input type="number"
                                           class="form-control form-control-sm text-center @(d.Cantidad > d.StockDisponible ? "is-invalid" : "")"
                                           style="width:65px"
                                           min="1" max="@d.StockDisponible"
                                           @bind="d.Cantidad" @bind:after="() => RecalcularTotales()" />
                                    @if (d.Cantidad > d.StockDisponible)
                                    {
                                        <div class="text-danger" style="font-size:0.7rem;">Máx. @d.StockDisponible</div>
                                    }
                                </div>
                                <div>
                                    <div class="ts-field-label">P. Unitario</div>
                                    <div class="ts-field-value">$@d.PrecioUnitario.ToString("N0")</div>
                                </div>
                                <div>
                                    <div class="ts-field-label">Dto. (%)</div>
                                    <input type="number" class="form-control form-control-sm text-center"
                                           style="width:65px"
                                           min="0" max="100" step="0.01"
                                           placeholder="0"
                                           @bind="d.DescuentoPct" @bind:after="() => RecalcularTotales()" />
                                    @if (d.DescuentoMonto > 0)
                                    {
                                        <div class="text-muted" style="font-size:.7rem;">-$@d.DescuentoMonto.ToString("N0")</div>
                                    }
                                </div>
                                <div>
                                    <div class="ts-field-label">Subtotal</div>
                                    <div class="ts-field-value">$@d.Subtotal.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="ts-cart-subtotal">$@d.Subtotal.ToString("N0")</div>
                        </div>
                    }

                    <!-- Totales móvil -->
                    <div class="ts-mobile-totals">
                        <div class="ts-total-row">
                            <span>Subtotal:</span>
                            <span class="fw-semibold">$@_subtotal.ToString("N0")</span>
                        </div>
                        <div class="ts-total-row">
                            <span>Descuento (%):</span>
                            <span class="d-flex align-items-center gap-2">
                                <input type="number" class="form-control form-control-sm text-end @(_advertenciaDescuento is not null ? "is-invalid" : "")"
                                       style="width:70px"
                                       min="0" max="100" step="0.01"
                                       @bind="_descuentoPct" @bind:after="RecalcularTotales" />
                                @if (_descuento > 0)
                                {
                                    <span class="text-muted small">-$@_descuento.ToString("N0")</span>
                                }
                            </span>
                        </div>
                        @if (_advertenciaDescuento is not null)
                        {
                            <div class="text-danger small">@_advertenciaDescuento</div>
                        }
                        <div class="ts-total-row">
                            <span>Impuesto (%):</span>
                            <input type="number" class="form-control form-control-sm text-end"
                                   style="width:70px"
                                   min="0" max="100" step="0.01"
                                   @bind="_impuestoPct" @bind:after="RecalcularTotales" />
                        </div>
                        <div class="ts-total-row ts-total-final">
                            <span>Total:</span>
                            <span>$@_total.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted text-center py-3">
                    <i class="bi bi-box-seam me-2"></i>Busca y agrega productos a la venta
                </p>
            }

            <div class="d-flex justify-content-end">
                <button class="btn bg-purple text-white px-4" @onclick="CrearFactura"
                        disabled="@(!_detalles.Any() || _clienteId == 0 || _creando || _detalles.Any(d => d.Cantidad > d.StockDisponible))">
                    @if (_creando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-check-lg me-1"></i>Registrar Venta
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Añadir stock rápido -->
@if (_modalStockVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-plus-circle me-1 text-warning"></i>Añadir stock
                    </h6>
                    <button class="btn-close" @onclick="CerrarModalStock"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-2">
                        <strong>@_stockProducto?.Name</strong><br />
                        Stock actual: <span class="fw-semibold text-danger">@(_stockProducto?.CurrentStock ?? 0)</span>
                    </p>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Cantidad a ingresar</label>
                        <input type="number" class="form-control form-control-sm" min="1"
                               @bind="_stockCantidad" />
                    </div>
                    <div>
                        <label class="form-label small fw-semibold">Notas (opcional)</label>
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Ej.: Compra de emergencia" @bind="_stockNotas" />
                    </div>
                    @if (_stockError is not null)
                    {
                        <div class="alert alert-danger py-1 small mt-2">@_stockError</div>
                    }
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-sm btn-secondary" @onclick="CerrarModalStock">Cancelar</button>
                    <button class="btn btn-sm btn-warning text-dark" @onclick="ConfirmarAjusteStock"
                            disabled="@_stockGuardando">
                        @if (_stockGuardando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Añadir
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ClienteDto> _clientes = [];
    private List<MetodoPagoDto> _metodosPago = [];
    private List<ProductoDto> _productos = [];
    private List<ProductoDto> _productosFiltrados = [];
    private List<DetalleLinea> _detalles = [];
    private List<CategoriaDto> _categorias = [];

    private int _clienteId;
    private int _metodoPagoId;
    private decimal? _pagoInicial;
    private string? _notas;
    private string _busquedaProducto = "";
    private int _filtroCategoriaId;
    private decimal _subtotal;
    private decimal _descuentoPct;  // porcentaje ingresado por el usuario (0-100)
    private decimal _descuento;     // monto calculado = subtotal * descuentoPct / 100
    private decimal _impuestoPct;
    private decimal _total;
    private bool _creando;
    private string? _error;
    private string? _advertenciaDescuento;

    // Modal ajuste stock
    private bool _modalStockVisible;
    private ProductoDto? _stockProducto;
    private int _stockCantidad = 1;
    private string? _stockNotas;
    private string? _stockError;
    private bool _stockGuardando;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t1 = Api.GetClientesAsync();
            var t2 = Api.GetMetodosPagoAsync();
            var t3 = Api.GetProductosAsync();
            var t4 = Api.GetCategoriasAsync();
            await Task.WhenAll(t1, t2, t3, t4);
            _clientes     = t1.Result ?? [];
            // Excluir "Fiado / Crédito" (Type == 5) del selector de pago inicial
            _metodosPago  = (t2.Result ?? []).Where(m => m.Type != 5).ToList();
            _productos    = t3.Result ?? [];
            _categorias   = t4.Result ?? [];
        }
        catch
        {
            _error = "No se pudieron cargar los datos necesarios. Recarga la página e inténtalo de nuevo.";
        }
    }

    private async Task HandleVentaKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_creando) await CrearFactura();
    }

    private void FiltrarProductos(ChangeEventArgs e)
    {
        _busquedaProducto = e.Value?.ToString() ?? "";
        AplicarFiltros();
    }

    private void FiltrarProductosActual() => AplicarFiltros();

    private void AplicarFiltros()
    {
        if (string.IsNullOrWhiteSpace(_busquedaProducto) && _filtroCategoriaId == 0)
        {
            _productosFiltrados = [];
            return;
        }

        var q = _busquedaProducto.ToLower();
        _productosFiltrados = _productos
            .Where(p => p.IsActive
                && (_filtroCategoriaId == 0 || p.CategoryId == _filtroCategoriaId)
                && (string.IsNullOrWhiteSpace(q) || p.Name.ToLower().Contains(q) || (p.Sku?.ToLower().Contains(q) ?? false)))
            .ToList();
    }

    private void SeleccionarCategoria(int categoriaId)
    {
        _filtroCategoriaId = categoriaId;
        AplicarFiltros();
    }

    private string? _advertenciaStock;

    private void AgregarProducto(ProductoDto p)
    {
        var existente = _detalles.FirstOrDefault(d => d.ProductoId == p.Id);
        if (existente is not null)
        {
            if (existente.Cantidad >= existente.StockDisponible)
            {
                _advertenciaStock = $"Stock máximo alcanzado para '{p.Name}' ({existente.StockDisponible} unid.)";
                return;
            }
            existente.Cantidad++;
        }
        else
        {
            if (p.CurrentStock <= 0)
            {
                _advertenciaStock = $"'{p.Name}' no tiene stock disponible. Añade stock antes de facturar.";
                return;
            }
            _detalles.Add(new DetalleLinea
            {
                ProductoId       = p.Id,
                NombreProducto   = p.Name,
                PrecioUnitario   = p.SalePrice,
                Cantidad         = 1,
                StockDisponible  = p.CurrentStock,
                ImagePath        = p.ImagePath
            });
        }
        _advertenciaStock = null;
        _busquedaProducto = "";
        AplicarFiltros();
        RecalcularTotales();
    }

    private void QuitarProducto(DetalleLinea d) { _detalles.Remove(d); _advertenciaStock = null; RecalcularTotales(); }

    private void RecalcularTotales()
    {
        // Clamp del descuento por línea (Fix #1)
        foreach (var d in _detalles)
        {
            if (d.DescuentoPct < 0)   d.DescuentoPct = 0;
            else if (d.DescuentoPct > 100) d.DescuentoPct = 100;
        }

        _subtotal = _detalles.Sum(d => d.Subtotal);

        // Clamp del porcentaje de descuento global
        if (_descuentoPct < 0)
        {
            _descuentoPct = 0;
            _advertenciaDescuento = "El descuento no puede ser negativo.";
        }
        else if (_descuentoPct > 100)
        {
            _descuentoPct = 100;
            _advertenciaDescuento = "El descuento no puede superar el 100%.";
        }
        else
        {
            _advertenciaDescuento = null;
        }

        // Clamp del impuesto (Fix #5)
        if (_impuestoPct < 0) _impuestoPct = 0;

        _descuento = Math.Round(_subtotal * (_descuentoPct / 100m), 2);
        var baseImponible = Math.Max(0, _subtotal - _descuento);
        var impuesto = Math.Round(baseImponible * (_impuestoPct / 100m), 2);
        _total = baseImponible + impuesto;
    }

    private async Task CrearFactura()
    {
        _error = null;

        // -- Validaciones de negocio -------------------------------------------
        if (_clienteId == 0)            { _error = "Selecciona un cliente antes de registrar la venta.";      return; }
        if (!_detalles.Any())           { _error = "Agrega al menos un producto a la venta.";              return; }
        if (_detalles.Any(d => d.Cantidad <= 0))
                                        { _error = "La cantidad de cada producto debe ser mayor a cero.";    return; }
        if (_detalles.Any(d => d.Cantidad > d.StockDisponible))
                                        { _error = "Una o más líneas superan el stock disponible. Corrija las cantidades antes de registrar."; return; }
        if (_detalles.Any(d => d.PrecioUnitario <= 0))
                                        { _error = "El precio unitario debe ser mayor a cero.";               return; }
        if (_detalles.Any(d => d.DescuentoPct < 0 || d.DescuentoPct > 100))
                                        { _error = "El descuento por línea debe estar entre 0 y 100.";        return; }
        if (_descuentoPct < 0)         { _error = "El descuento no puede ser negativo.";                    return; }
        if (_descuentoPct > 100)        { _error = "El descuento no puede superar el 100%.";                 return; }
        if (_impuestoPct < 0)           { _error = "El porcentaje de impuesto no puede ser negativo.";       return; }
        if (_pagoInicial.HasValue && _pagoInicial.Value < 0)
                                        { _error = "El pago inicial no puede ser negativo.";                 return; }
        if (_pagoInicial.HasValue && _pagoInicial.Value > _total)
                                        { _error = "El pago inicial no puede ser mayor al total de la factura."; return; }

        _creando = true;
        try
        {
            CreatePagoInicialDto? pagoInicial = null;
            if (_metodoPagoId > 0 && _pagoInicial.HasValue && _pagoInicial.Value > 0)
                pagoInicial = new CreatePagoInicialDto(_metodoPagoId, _pagoInicial.Value, null, null);

            var baseImponible = Math.Max(0, _subtotal - _descuento);
            var taxAmount     = Math.Round(baseImponible * (_impuestoPct / 100m), 2);

            var dto = new CreateFacturaDto(
                CustomerId:     _clienteId,
                DiscountAmount: _descuento,
                TaxAmount:      taxAmount,
                Notes:          _notas,
                Details:        _detalles.Select(d => new CreateDetalleFacturaDto(d.ProductoId, d.Cantidad, d.PrecioUnitario, d.DescuentoMonto)).ToList(),
                PagoInicial:    pagoInicial);

            var ok = await Api.CreateFacturaAsync(dto);
            if (ok) Nav.NavigateTo("/ventas");
            else _error = "Error al registrar la venta. Verifique stock y campos requeridos.";
        }
        catch { _error = "Error al comunicarse con la API."; }
        finally { _creando = false; }
    }

    private void AbrirModalStock(ProductoDto p)
    {
        _stockProducto  = p;
        _stockCantidad  = 1;
        _stockNotas     = null;
        _stockError     = null;
        _modalStockVisible = true;
    }

    private void CerrarModalStock()
    {
        _modalStockVisible = false;
        _stockProducto = null;
    }

    private async Task ConfirmarAjusteStock()
    {
        if (_stockProducto is null) return;
        if (_stockCantidad <= 0) { _stockError = "La cantidad debe ser mayor a cero."; return; }

        _stockGuardando = true;
        _stockError = null;
        try
        {
            var actualizado = await Api.AjustarStockAsync(
                _stockProducto.Id,
                new AjusteStockDto(_stockCantidad, _stockNotas));

            if (actualizado is null)
            {
                _stockError = "No se pudo actualizar el stock. Inténtalo de nuevo.";
                return;
            }

            // Refrescar el producto en la lista local
            var idx = _productos.FindIndex(p => p.Id == actualizado.Id);
            if (idx >= 0) _productos[idx] = actualizado;

            CerrarModalStock();
            AplicarFiltros();
        }
        catch { _stockError = "Error al comunicarse con la API."; }
        finally { _stockGuardando = false; }
    }

    private class DetalleLinea
    {
        public int ProductoId { get; set; }
        public string NombreProducto { get; set; } = "";
        public string? ImagePath { get; set; }
        public decimal PrecioUnitario { get; set; }
        public int Cantidad { get; set; }
        public int StockDisponible { get; set; }
        public decimal DescuentoPct { get; set; }  // porcentaje 0-100
        public decimal DescuentoMonto => Math.Round(PrecioUnitario * Cantidad * (DescuentoPct / 100m), 2);
        public decimal Subtotal => Math.Max(0, PrecioUnitario * Cantidad - DescuentoMonto);
    }
}
