@page "/ventas"
@attribute [Authorize]
@inject TinaStoreApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Ventas " Tina Store</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h4 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-purple"></i>Ventas</h4>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-purple" @onclick="ExportarExcel" disabled="@_exportandoVentas">
            @if (_exportandoVentas) { <span class="spinner-border spinner-border-sm me-1"></span> }
            else { <i class="bi bi-file-earmark-excel me-1"></i> }
            Exportar ventas
        </button>
        <NavLink href="/ventas/libre" class="btn btn-outline-purple">
            <i class="bi bi-lightning-charge me-1"></i>Venta libre
        </NavLink>
        <NavLink href="/ventas/nueva" class="btn bg-purple text-white">
            <i class="bi bi-plus-lg me-1"></i>Nueva venta
        </NavLink>
    </div>
</div>

@if (!string.IsNullOrEmpty(_mensaje))
{
    <div class="alert @(_exito ? "alert-success" : "alert-danger") py-2">@_mensaje</div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-purple"></div></div>
}
else
{
    <div class="ts-filter-bar">
        <div class="row g-2 align-items-end">
            <div class="col-sm-6 col-md-3">
                <label class="form-label">N° o cliente</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control form-control-sm" placeholder="Buscar..." @oninput="Filtrar" />
                </div>
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label">Estado</label>
                <select class="form-select form-select-sm" @onchange="FiltrarEstado">
                    <option value="">Todos</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Parcial">Parcial</option>
                    <option value="Anulada">Anulada</option>
                </select>
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label">Desde</label>
                <input type="date" class="form-control form-control-sm"
                       min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       @onchange="FiltrarDesde" />
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label">Hasta</label>
                <input type="date" class="form-control form-control-sm"
                       min="2020-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")"
                       @onchange="FiltrarHasta" />
            </div>
            <div class="col-sm-auto d-flex align-items-end">
                <button class="btn-limpiar" @onclick="LimpiarFiltros">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </button>
            </div>
        </div>
    </div>

    <div class="card ts-table border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 ts-tabla-ventas">
                <thead>
                    <tr>
                        <th style="width:32px"></th>
                        <th class="ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("numero")'>
                            N° Venta <i class="@(SortIconClass("numero")) ms-1 small"></i>
                        </th>
                        <th>Cliente</th>
                        <th class="text-end" style="cursor:pointer" @onclick='() => OrdenarPor("total")'>
                            Total <i class="@(SortIconClass("total")) ms-1 small"></i>
                        </th>
                        <th class="text-end ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("pagado")'>
                            Pagado <i class="@(SortIconClass("pagado")) ms-1 small"></i>
                        </th>
                        <th class="text-end ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("saldo")'>
                            Saldo <i class="@(SortIconClass("saldo")) ms-1 small"></i>
                        </th>
                        <th>Estado</th>
                        <th class="ts-table-hide-mobile" style="cursor:pointer" @onclick='() => OrdenarPor("fecha")'>
                            Fecha <i class="@(SortIconClass("fecha")) ms-1 small"></i>
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in _filtradas)
                    {
                        var expandida = _expandidas.Contains(f.Id);
                        <tr class="@(expandida ? "table-active" : "")" style="cursor:pointer" @onclick="() => ToggleDetalle(f.Id)">
                            <td class="text-center align-middle px-2">
                                <i class="bi @(expandida ? "bi-chevron-up text-purple" : "bi-chevron-down text-muted") small"></i>
                            </td>
                            <td class="ts-table-hide-mobile"><span class="badge bg-dark">@f.InvoiceNumber</span></td>
                            <td>
                                <span class="d-block">@f.CustomerName</span>
                                <span class="d-md-none text-muted" style="font-size:.72rem;">@f.InvoiceNumber · @f.InvoiceDate.ToLocalTime().ToString("dd/MM/yy")</span>
                            </td>
                            <td class="text-end fw-semibold">$@f.Total.ToString("N0")</td>
                            <td class="text-end ts-table-hide-mobile @(f.AmountPaid < f.Total ? "text-danger" : "text-success")">
                                $@f.AmountPaid.ToString("N0")
                            </td>
                            <td class="text-end ts-table-hide-mobile @(f.Balance > 0 ? "text-danger fw-semibold" : "text-muted")">
                                $@f.Balance.ToString("N0")
                            </td>
                            <td>
                                <span class="badge badge-estado-@f.StatusName.ToLower()">@f.StatusName</span>
                            </td>
                            <td class="text-muted small ts-table-hide-mobile">@f.InvoiceDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td class="text-end" @onclick:stopPropagation="true">
                                <div class="d-flex gap-1 justify-content-end align-items-center">
                                @if (_pdfDescargando.Contains(f.Id))
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled title="Generando PDF...">
                                        <span class="spinner-border spinner-border-sm"></span>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" title="Descargar PDF"
                                            @onclick="() => DescargarPdf(f.Id)">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </button>
                                }
                                @if (f.StatusName != "Anulada")
                                {
                                    @if (f.Balance > 0)
                                    {
                                        <button class="btn btn-sm btn-outline-success" title="Registrar pago"
                                                @onclick="() => AbrirPago(f)">
                                            <i class="bi bi-cash-coin"></i>
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-outline-danger" title="Anular"
                                            @onclick="() => Anular(f.Id)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                </div>
                            </td>
                        </tr>

                        @if (expandida)
                        {
                            <tr class="detalle-expandido">
                                <td colspan="9" class="p-0">
                                    <div class="detalle-venta-panel px-4 py-3">
                                        @if (_detallesCargando.Contains(f.Id))
                                        {
                                            <div class="text-center py-3">
                                                <span class="spinner-border spinner-border-sm text-purple me-2"></span>
                                                <span class="text-muted small">Cargando detalle...</span>
                                            </div>
                                        }
                                        else if (_detallesCache.TryGetValue(f.Id, out var detalle))
                                        {
                                            <!-- Productos de la venta -->
                                            @if (detalle.Details.Any())
                                            {
                                                @* Determinar si es venta libre: todas las líneas sin ProductId *@
                                                var esVentaLibre = detalle.Details.All(d => d.ProductId == null);

                                                @if (esVentaLibre)
                                                {
                                                    <!-- Venta libre: mostrar descripción por línea -->
                                                    <div class="fw-semibold small text-purple mb-2">
                                                        <i class="bi bi-lightning-charge me-1"></i>Venta libre
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm mb-2" style="font-size:.87rem">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th>Descripción</th>
                                                                    <th class="text-center">Cant.</th>
                                                                    <th class="text-end">Valor unit.</th>
                                                                    <th class="text-end">Subtotal</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var linea in detalle.Details)
                                                                {
                                                                    <tr>
                                                                        <td class="align-middle">@linea.ProductName</td>
                                                                        <td class="text-center align-middle">@linea.Quantity</td>
                                                                        <td class="text-end text-muted align-middle">$@linea.UnitPrice.ToString("N0")</td>
                                                                        <td class="text-end fw-semibold align-middle">$@linea.Subtotal.ToString("N0")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                            <tfoot class="table-light">
                                                                <tr>
                                                                    <td colspan="3" class="text-end fw-bold small">Total:</td>
                                                                    <td class="text-end fw-bold text-purple small">$@detalle.Total.ToString("N0")</td>
                                                                </tr>
                                                            </tfoot>
                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <!-- Venta normal: tabla de productos -->
                                                    <div class="fw-semibold small text-purple mb-2">
                                                        <i class="bi bi-box-seam me-1"></i>Productos vendidos
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm mb-2 ts-detalle-venta-tabla" style="font-size:.87rem">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th style="width:44px"></th>
                                                                    <th>Producto</th>
                                                                    <th class="text-center">Cant.</th>
                                                                    <th class="text-end">P. Unit.</th>
                                                                    <th class="text-end">Descuento</th>
                                                                    <th class="text-end">Subtotal</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var linea in detalle.Details)
                                                                {
                                                                    <tr>
                                                                        <td class="align-middle text-center">
                                                                            @if (!string.IsNullOrEmpty(linea.ImagePath))
                                                                            {
                                                                                <img src="@(_apiBase + linea.ImagePath)" alt="@linea.ProductName"
                                                                                     style="width:32px;height:32px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;" />
                                                                            }
                                                                            else
                                                                            {
                                                                                <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;background:#f1f5f9;color:#94a3b8;font-size:.8rem;"><i class="bi bi-image"></i></span>
                                                                            }
                                                                        </td>
                                                                        <td class="align-middle">@linea.ProductName</td>
                                                                        <td class="text-center align-middle">@linea.Quantity</td>
                                                                        <td class="text-end text-muted align-middle">$@linea.UnitPrice.ToString("N0")</td>
                                                                        <td class="text-end text-muted align-middle">
                                                                            @(linea.DiscountAmount > 0 ? "$" + linea.DiscountAmount.ToString("N0") : string.Empty)
                                                                        </td>
                                                                        <td class="text-end fw-semibold align-middle">$@linea.Subtotal.ToString("N0")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                            <tfoot class="table-light">
                                                                <tr>
                                                                    <td colspan="5" class="text-end text-muted small">Subtotal:</td>
                                                                    <td class="text-end text-muted small">$@detalle.Subtotal.ToString("N0")</td>
                                                                </tr>
                                                                @if (detalle.DiscountAmount > 0)
                                                                {
                                                                    <tr>
                                                                        <td colspan="5" class="text-end text-muted small">Descuento:</td>
                                                                        <td class="text-end text-muted small">-$@detalle.DiscountAmount.ToString("N0")</td>
                                                                    </tr>
                                                                }
                                                                @if (detalle.TaxAmount > 0)
                                                                {
                                                                    <tr>
                                                                        <td colspan="5" class="text-end text-muted small">Impuesto:</td>
                                                                        <td class="text-end text-muted small">$@detalle.TaxAmount.ToString("N0")</td>
                                                                    </tr>
                                                                }
                                                                <tr>
                                                                    <td colspan="5" class="text-end fw-bold small">Total:</td>
                                                                    <td class="text-end fw-bold text-purple small">$@detalle.Total.ToString("N0")</td>
                                                                </tr>
                                                            </tfoot>
                                                        </table>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <p class="text-muted small mb-2">
                                                    <i class="bi bi-lightning-charge me-1 text-purple"></i>
                                                    <strong>Venta libre:</strong>
                                                    @(detalle.Notes ?? "Sin descripción registrada.")
                                                </p>
                                            }

                                            <!-- Notas -->
                                            @if (!string.IsNullOrWhiteSpace(detalle.Notes))
                                            {
                                                <div class="text-muted small mb-2">
                                                    <i class="bi bi-sticky me-1"></i><strong>Nota de creación:</strong> @detalle.Notes
                                                </div>
                                            }

                                            <!-- Nota de anulación -->
                                            @if (!string.IsNullOrWhiteSpace(detalle.CancellationReason))
                                            {
                                                <div class="alert alert-danger py-1 small mb-2">
                                                    <i class="bi bi-slash-circle me-1"></i><strong>Motivo de anulación:</strong> @detalle.CancellationReason
                                                </div>
                                            }

                                            <!-- Pagos registrados -->
                                            @if (detalle.Payments.Any())
                                            {
                                                <div class="fw-semibold small text-purple mt-2 mb-2">
                                                    <i class="bi bi-cash-coin me-1"></i>Pagos registrados
                                                </div>
                                                <div class="d-flex flex-wrap gap-2">
                                                    @foreach (var pago in detalle.Payments)
                                                    {
                                                        <div class="pago-chip">
                                                            <span class="fw-semibold">$@pago.Amount.ToString("N0")</span>
                                                            <span class="text-muted ms-1 small">@pago.PaymentMethodName</span>
                                                            <span class="text-muted ms-1 small">·</span>
                                                            <span class="text-muted small">@pago.PaymentDate.ToString("dd/MM/yyyy")</span>
                                                            @if (!string.IsNullOrWhiteSpace(pago.Reference))
                                                            {
                                                                <span class="text-muted small ms-1">· Ref: @pago.Reference</span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="text-muted small py-2">
                                                <i class="bi bi-exclamation-circle me-1"></i>No se pudo cargar el detalle de esta venta.
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (!_filtradas.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">Sin ventas</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal de motivo de anulación -->
@if (_mostrarModalAnular)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-x-circle text-danger me-2"></i>Anular venta</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Esta acción revertirá el stock y las cuentas por cobrar asociadas.</p>
                    <label class="form-label fw-semibold">Motivo de anulación <span class="text-danger">*</span></label>
                    <textarea class="form-control" rows="3" placeholder="Indique el motivo..."
                              @bind="_motivoAnulacion" @bind:event="oninput"
                              @onkeydown="HandleAnulacionKeyDown"
                              maxlength="300"></textarea>
                    @if (_errorModal is not null)
                    {
                        <div class="text-danger small mt-1">@_errorModal</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-danger btn-sm" @onclick="ConfirmarAnulacion" disabled="@_anulando">
                        @if (_anulando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Confirmar anulación
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de registrar pago -->
@if (_mostrarModalPago)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-cash-coin text-success me-2"></i>Registrar pago</h5>
                    <button class="btn-close" @onclick="CerrarModalPago"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">
                        Venta <strong>@_pagoFacturaNumero</strong> &mdash;
                        Saldo pendiente: <strong class="text-danger">$@_pagoSaldo.ToString("N0")</strong>
                    </p>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Método de pago *</label>
                            <select class="form-select" @bind="_pagoForm.MetodoPagoId">
                                <option value="0">Seleccione...</option>
                                @foreach (var mp in _metodosPago)
                                {
                                    <option value="@mp.Id">@mp.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Monto *</label>
                            <input type="number" class="form-control" @bind="_pagoForm.Monto"
                                   min="0.01" step="0.01" @onkeydown="HandlePagoKeyDown" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Referencia</label>
                            <input class="form-control" @bind="_pagoForm.Referencia" placeholder="N° cheque, transf..." @onkeydown="HandlePagoKeyDown" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Notas</label>
                            <input class="form-control" @bind="_pagoForm.Notas" @onkeydown="HandlePagoKeyDown" />
                        </div>
                    </div>
                    @if (_errorPago is not null)
                    {
                        <div class="text-danger small mt-2">@_errorPago</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModalPago">Cancelar</button>
                    <button class="btn btn-success btn-sm" @onclick="ConfirmarPago" disabled="@_registrandoPago">
                        @if (_registrandoPago) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Confirmar pago
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _apiBase = string.Empty;
    private List<FacturaDto> _facturas = [];
    private List<FacturaDto> _filtradas = [];
    private bool _loading = true;
    private string? _mensaje;
    private bool _exito;
    private string    _busqueda     = "";
    private string    _estadoFiltro = "";
    private DateTime? _filtroDesde;
    private DateTime? _filtroHasta;
    private string    _ordenCampo   = "fecha";
    private bool      _ordenDesc    = true;
    private HashSet<int> _pdfDescargando = [];

    // -- Detalle expandible -----------------------------------------------------
    private HashSet<int>                         _expandidas      = [];
    private HashSet<int>                         _detallesCargando = [];
    private Dictionary<int, VentaDetalleDto>     _detallesCache   = [];

    private bool   _mostrarModalAnular;
    private int    _idFacturaAnular;
    private string _motivoAnulacion = "";
    private bool   _anulando;
    private string? _errorModal;
    private bool _exportandoVentas;

    private async Task ExportarExcel()
    {
        _exportandoVentas = true;
        _mensaje = null;
        try
        {
            var bytes = await Api.ExportarVentasExcelAsync(_filtroDesde, _filtroHasta);
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64,
                    $"ventas-{DateTime.Now:yyyyMMdd}.xlsx",
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
                _exito   = true;
                _mensaje = "Ventas exportadas correctamente.";
            }
            else { _exito = false; _mensaje = "No se pudo generar el archivo Excel."; }
        }
        catch { _exito = false; _mensaje = "Error al exportar ventas."; }
        finally { _exportandoVentas = false; }
    }

    private bool   _mostrarModalPago;
    private int    _idFacturaPago;
    private string _pagoFacturaNumero = "";
    private decimal _pagoSaldo;
    private bool   _registrandoPago;
    private string? _errorPago;
    private List<MetodoPagoDto> _metodosPago = [];
    private PagoForm _pagoForm = new();

    private class PagoForm
    {
        public int     MetodoPagoId { get; set; }
        public decimal Monto        { get; set; }
        public string? Referencia   { get; set; }
        public string? Notas        { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _apiBase = Api.PublicBaseUrl;
        var t1 = Api.GetFacturasAsync();
        var t2 = Api.GetMetodosPagoAsync();
        await Task.WhenAll(t1, t2);
        _facturas    = t1.Result ?? [];
        // Excluir "Fiado / Crédito" (Type == 5 = Credit) del selector de abonos
        _metodosPago = (t2.Result ?? [])
            .Where(m => m.Type != 5)
            .ToList();
        AplicarFiltros();
        _loading = false;
    }

    private async Task Cargar()
    {
        _loading = true;
        _facturas = await Api.GetFacturasAsync() ?? [];
        // Limpiar caché de detalles al recargar la lista
        _expandidas.Clear();
        _detallesCache.Clear();
        _detallesCargando.Clear();
        AplicarFiltros();
        _loading = false;
    }

    private async Task ToggleDetalle(int id)
    {
        if (_expandidas.Contains(id))
        {
            _expandidas.Remove(id);
            return;
        }

        _expandidas.Add(id);

        // Cargar solo si no está en caché
        if (!_detallesCache.ContainsKey(id))
        {
            _detallesCargando.Add(id);
            StateHasChanged();
            var detalle = await Api.GetVentaDetalleAsync(id);
            _detallesCargando.Remove(id);
            if (detalle is not null)
                _detallesCache[id] = detalle;
        }
    }

    private void Filtrar(ChangeEventArgs e)
    {
        _busqueda = e.Value?.ToString() ?? "";
        AplicarFiltros();
    }

    private void FiltrarEstado(ChangeEventArgs e)
    {
        _estadoFiltro = e.Value?.ToString() ?? "";
        AplicarFiltros();
    }

    private void FiltrarDesde(ChangeEventArgs e)
    {
        _filtroDesde = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;
        AplicarFiltros();
    }

    private void FiltrarHasta(ChangeEventArgs e)
    {
        _filtroHasta = DateTime.TryParse(e.Value?.ToString(), out var d) ? d.AddDays(1).AddSeconds(-1) : null;
        AplicarFiltros();
    }

    private void LimpiarFiltros()
    {
        _busqueda     = "";
        _estadoFiltro = "";
        _filtroDesde  = null;
        _filtroHasta  = null;
        _ordenCampo   = "fecha";
        _ordenDesc    = true;
        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        // Validar rango de fechas
        if (_filtroDesde.HasValue && _filtroHasta.HasValue && _filtroDesde > _filtroHasta)
        {
            _exito = false;
            _mensaje = "La fecha inicial no puede ser mayor que la fecha final.";
            _filtradas = [];
            return;
        }
        _mensaje = null;

        _filtradas = _facturas
            .Where(f =>
                (string.IsNullOrEmpty(_busqueda) ||
                 f.InvoiceNumber.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ||
                 f.CustomerName.Contains(_busqueda, StringComparison.OrdinalIgnoreCase))
             && (string.IsNullOrEmpty(_estadoFiltro) || f.StatusName == _estadoFiltro)
             && (_filtroDesde is null || f.InvoiceDate >= _filtroDesde)
             && (_filtroHasta is null || f.InvoiceDate <= _filtroHasta))
            .ToList();
        AplicarOrden();
    }

    private void AbrirPago(FacturaDto f)
    {
        _idFacturaPago      = f.Id;
        _pagoFacturaNumero  = f.InvoiceNumber;
        _pagoSaldo          = f.Balance;
        _pagoForm           = new() { Monto = f.Balance };
        _errorPago          = null;
        _mostrarModalPago   = true;
    }

    private void CerrarModalPago()
    {
        _mostrarModalPago = false;
        _errorPago = null;
    }

    private async Task ConfirmarPago()
    {
        if (_pagoForm.MetodoPagoId == 0) { _errorPago = "Seleccione un método de pago."; return; }
        if (_pagoForm.Monto <= 0)        { _errorPago = "El monto debe ser mayor a cero."; return; }
        if (_pagoForm.Monto > _pagoSaldo)
        {
            _errorPago = $"El abono no puede ser mayor al saldo pendiente de la factura (${_pagoSaldo:N0}).";
            return;
        }

        _registrandoPago = true;
        _errorPago = null;
        try
        {
            var dto = new RegisterPagoDto(_pagoForm.MetodoPagoId, _pagoForm.Monto, _pagoForm.Referencia, _pagoForm.Notas);
            var ok  = await Api.RegisterPagoAsync(_idFacturaPago, dto);
            _mostrarModalPago = false;
            _exito   = ok;
            _mensaje = ok ? "Pago registrado correctamente." : "Error al registrar el pago.";
            if (ok) await Cargar();
        }
        catch { _errorPago = "Error al comunicarse con la API."; }
        finally { _registrandoPago = false; }
    }

    private void Anular(int id)
    {
        _idFacturaAnular  = id;
        _motivoAnulacion  = "";
        _errorModal       = null;
        _mostrarModalAnular = true;
    }

    private void CerrarModal()
    {
        _mostrarModalAnular = false;
        _errorModal = null;
    }

    private async Task ConfirmarAnulacion()
    {
        if (string.IsNullOrWhiteSpace(_motivoAnulacion))
        {
            _errorModal = "El motivo de anulación es obligatorio.";
            return;
        }

        _anulando = true;
        _errorModal = null;
        try
        {
            // Detectar si había productos de inventario para enriquecer el mensaje
            var tieneProductosInventario = _detallesCache.TryGetValue(_idFacturaAnular, out var detallePrevio)
                && detallePrevio.Details.Any(d => d.ProductId > 0);

            var ok = await Api.AnularFacturaAsync(_idFacturaAnular, _motivoAnulacion.Trim());
            _mostrarModalAnular = false;
            _exito = ok;
            if (ok)
            {
                _mensaje = tieneProductosInventario
                    ? "Factura anulada correctamente. Los productos de esta factura fueron devueltos nuevamente al stock."
                    : "Venta anulada correctamente.";
            }
            else
            {
                _mensaje = "No se pudo anular la venta.";
            }
            if (ok) await Cargar();
        }
        catch { _errorModal = "Error al comunicarse con la API."; }
        finally { _anulando = false; }
    }

    private async Task DescargarPdf(int id)
    {
        _pdfDescargando.Add(id);
        _mensaje = null;
        try
        {
            var bytes = await Api.DescargarPdfFacturaAsync(id);
            if (bytes is not null)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, $"factura-{id}.pdf", "application/pdf");
                _exito   = true;
                _mensaje = "PDF generado correctamente.";
            }
            else
            {
                _exito   = false;
                _mensaje = "No se pudo generar el PDF.";
            }
        }
        catch
        {
            _exito   = false;
            _mensaje = "Error al generar el PDF.";
        }
        finally
        {
            _pdfDescargando.Remove(id);
        }
    }

    // -- Ordenamiento de columnas ----------------------------------------------------
    private void OrdenarPor(string campo)
    {
        if (_ordenCampo == campo)
            _ordenDesc = !_ordenDesc;
        else
        {
            _ordenCampo = campo;
            _ordenDesc  = true;
        }
        AplicarOrden();
    }

    private void AplicarOrden()
    {
        _filtradas = (_ordenCampo switch
        {
            "numero" => _ordenDesc ? _filtradas.OrderByDescending(f => f.InvoiceNumber) : _filtradas.OrderBy(f => f.InvoiceNumber),
            "total"  => _ordenDesc ? _filtradas.OrderByDescending(f => f.Total)         : _filtradas.OrderBy(f => f.Total),
            "pagado" => _ordenDesc ? _filtradas.OrderByDescending(f => f.AmountPaid)    : _filtradas.OrderBy(f => f.AmountPaid),
            "saldo"  => _ordenDesc ? _filtradas.OrderByDescending(f => f.Balance)       : _filtradas.OrderBy(f => f.Balance),
            "fecha"  => _ordenDesc ? _filtradas.OrderByDescending(f => f.InvoiceDate)   : _filtradas.OrderBy(f => f.InvoiceDate),
            _        => _filtradas.OrderByDescending(f => f.InvoiceDate)
        }).ToList();
    }

    private string SortIconClass(string campo) =>
        _ordenCampo != campo ? "bi bi-arrow-down-up text-muted" :
        _ordenDesc            ? "bi bi-sort-down text-purple"   :
                                "bi bi-sort-up text-purple";

    private async Task HandleAnulacionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await ConfirmarAnulacion();
    }

    private async Task HandlePagoKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_registrandoPago)
            await ConfirmarPago();
    }
}
